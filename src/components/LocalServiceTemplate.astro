---
import BaseLayout from '../layouts/BaseLayout.astro';
import type { City } from '../data/cities';

interface Chip { label: string; slug: string; }
interface Faq { q: string; a: string; }
interface Props {
  seoTitle: string;
  seoDescription: string;
  service: { name: string; label: string; slug: string }; // name "Paver driveways", label "Driveways"
  city: City;
  lede: string;
  intro: string[];
  localNote: string;
  handles: string[];
  faqs: Faq[];
  heroImg: string;
  heroAlt: string;
  heroBg?: string;  // optional full-bleed hero background photo (with dark overlay)
  services: Chip[]; // all services, for "every service in this city"
  cities: Chip[];   // all cities, for "this service across the county"
}
const {
  seoTitle, seoDescription, service, city, lede, intro, localNote, handles, faqs,
  heroImg, heroAlt, heroBg, services, cities,
} = Astro.props as Props;

const hoaLabel =
  city.hoa === 'none' ? 'No HOA · city / district review' :
  city.hoa === 'hoa' ? 'HOA / architectural review board' :
  'Mixed — HOA on some streets';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: service.name,
  name: `${service.name} in ${city.name}`,
  areaServed: { '@type': 'City', name: `${city.name}, FL` },
  provider: {
    '@type': 'LocalBusiness',
    name: 'Perfect Pavers of Palm Beach',
    image: new URL('/apple-touch-icon.png', Astro.site).href,
    url: new URL('/', Astro.site).href,
    telephone: '+1-561-834-8880',
    priceRange: '$$',
    address: { '@type': 'PostalAddress', addressLocality: city.name, addressRegion: 'FL', addressCountry: 'US' },
    areaServed: 'Palm Beach County, FL',
  },
};
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
};
---
<BaseLayout title={seoTitle} description={seoDescription} bodyClass="lg-page">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqLd)} />

  <!-- ===== HERO: dark, centered — deliberately unlike the split service hero ===== -->
  <section class:list={['lg-hero', { 'lg-hero-photo': heroBg }]} style={heroBg ? `--lg-hero-bg:url('${heroBg}')` : undefined}>
    <div class="wrap">
      <nav class="lg-crumbs" aria-label="Breadcrumb">
        <a href="/">Home</a><span>/</span>
        <a href={`/services/${service.slug}/`}>{service.label}</a><span>/</span>
        <span>{city.name}</span>
      </nav>
      <p class="lg-eyebrow">Palm Beach County · {city.name}</p>
      <h1 class="lg-h1">{service.name}<br /><em>in {city.name}.</em></h1>
      <p class="lg-lede">{lede}</p>
      <div class="lg-hero-cta">
        <a href="/contact/" class="btn btn-brass">Request a free visit</a>
        <a href="tel:+15618348880" class="lg-callink">Call (561) 834-8880</a>
      </div>
    </div>
  </section>

  <!-- ===== SIGNATURE ELEMENT: the per-city "dossier" card, overlapping the hero ===== -->
  <div class="wrap">
    <div class="lg-dossier">
      <div class="lg-doss-cell">
        <span class="lg-doss-k">Where we work</span>
        <span class="lg-doss-v">{city.neighborhoods.join(' · ')}</span>
      </div>
      <div class="lg-doss-cell">
        <span class="lg-doss-k">Typical homes</span>
        <span class="lg-doss-v">{city.homeEra} · {city.setting}</span>
      </div>
      <div class="lg-doss-cell">
        <span class="lg-doss-k">Approvals</span>
        <span class="lg-doss-v">{hoaLabel}</span>
      </div>
      <div class="lg-doss-cell">
        <span class="lg-doss-k">Permitting</span>
        <span class="lg-doss-v">{city.permitAuthority.replace('the ', '').replace(/^./, (m) => m.toUpperCase())}</span>
      </div>
    </div>
  </div>

  <!-- ===== BODY: editorial two-column with a sticky local sidebar ===== -->
  <section class="wrap lg-body">
    <div class="lg-main">
      {intro.map((p, i) => <p class={i === 0 ? 'lg-lead-para' : ''} set:html={p} />)}

      <div class="lg-note">
        <span class="lg-note-tag">Local note</span>
        <p set:html={localNote} />
      </div>

      <h2 class="lg-h2">What we handle in {city.name}</h2>
      <ul class="lg-handles">
        {handles.map((h) => <li set:html={h} />)}
      </ul>
    </div>

    <aside class="lg-side">
      <div class="lg-side-card">
        <span class="lg-eyebrow">Why {city.name}</span>
        <p class="lg-why">{city.blurb}</p>
        <div class="lg-hero-img" style={`background-image:url('${heroImg}')`} role="img" aria-label={heroAlt}></div>
        <a href="/contact/" class="btn btn-brass lg-side-btn">Book your on-site visit</a>
        <a href="tel:+15618348880" class="lg-side-call">or call (561) 834-8880</a>
      </div>
    </aside>
  </section>

  <!-- ===== LOCAL FAQ: numbered, distinct from the accordion elsewhere ===== -->
  <section class="lg-faq-band">
    <div class="wrap">
      <h2 class="lg-h2 lg-faq-title">{city.name} questions, answered</h2>
      <div class="lg-faqs">
        {faqs.map((f, i) => (
          <div class="lg-faq">
            <span class="lg-faq-n">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3 class="lg-faq-q">{f.q}</h3>
              <p class="lg-faq-a">{f.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== MATRIX CHIPS: internal-linking grid unique to this cluster ===== -->
  <section class="wrap lg-matrix">
    <div class="lg-mx-col">
      <span class="lg-eyebrow">Every service in {city.name}</span>
      <div class="lg-chips">
        {services.map((s) => (
          s.slug === service.slug
            ? <span class="lg-chip lg-chip-on">{s.label}</span>
            : <a class="lg-chip" href={`/services/${s.slug}/${city.slug}/`}>{s.label}</a>
        ))}
      </div>
    </div>
    <div class="lg-mx-col">
      <span class="lg-eyebrow">{service.label} across Palm Beach County</span>
      <div class="lg-chips">
        {cities.map((c) => (
          c.slug === city.slug
            ? <span class="lg-chip lg-chip-on">{c.label}</span>
            : <a class="lg-chip" href={`/services/${service.slug}/${c.slug}/`}>{c.label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CLOSING CTA ===== -->
  <section class="lg-cta">
    <div class="wrap">
      <p class="lg-eyebrow" style="color:var(--brass)">Your free on-site visit</p>
      <h2 class="lg-cta-h">{service.label.replace(/s$/, '')} in {city.name}? <em>Let's walk it.</em></h2>
      <p class="lg-cta-p">We come out within a day or two, measure the space, and send an itemized written estimate — no charge, no pressure.</p>
      <div class="lg-hero-cta">
        <a href="/contact/" class="btn btn-brass">Request a visit</a>
        <a href="tel:+15618348880" class="btn btn-ghost" style="color:var(--ivory)">Call (561) 834-8880</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ===== Local-guide cluster — its own visual identity, on brand but a different layout ===== */
  .lg-page { background: var(--ivory); }

  .lg-hero { background: var(--green-deep); color: var(--ivory); padding: clamp(46px, 8vw, 92px) 0 clamp(90px, 12vw, 150px); text-align: center; }
  /* Optional photo backdrop with a dark film so the text stays readable */
  .lg-hero-photo { background-image: linear-gradient(rgba(16,44,36,.72), rgba(13,34,28,.86)), var(--lg-hero-bg); background-size: cover; background-position: center; }
  .lg-crumbs { font-family: var(--sans); font-size: 12px; letter-spacing: .04em; color: rgba(246,241,231,.6); margin-bottom: 26px; }
  .lg-crumbs a { color: rgba(246,241,231,.8); }
  .lg-crumbs a:hover { color: var(--ivory); }
  .lg-crumbs span { margin: 0 9px; opacity: .5; }
  .lg-eyebrow { font-family: var(--sans); font-weight: 500; font-size: 12px; letter-spacing: .28em; text-transform: uppercase; color: var(--brass); }
  .lg-hero .lg-eyebrow { color: #cBA36a; }
  .lg-h1 { font-family: var(--serif); font-weight: 500; font-size: clamp(38px, 6.4vw, 76px); line-height: 1.02; margin: 16px 0 0; }
  .lg-h1 em { color: var(--brass); font-style: italic; }
  .lg-lede { max-width: 620px; margin: 22px auto 0; font-size: clamp(16px, 2vw, 19px); color: rgba(246,241,231,.82); line-height: 1.6; }
  .lg-hero-cta { display: flex; gap: 20px; align-items: center; justify-content: center; margin-top: 32px; flex-wrap: wrap; }
  .lg-callink { font-family: var(--sans); font-size: 16px; letter-spacing: .08em; color: var(--ivory); border-bottom: 1px solid rgba(246,241,231,.4); padding-bottom: 3px; }
  .lg-callink:hover { border-color: var(--brass); }

  /* Signature dossier card */
  .lg-dossier { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0; background: var(--ivory); border: 1px solid var(--line); border-radius: 4px; margin-top: clamp(-70px, -8vw, -110px); position: relative; box-shadow: 0 30px 60px -30px rgba(16,44,36,.4); }
  .lg-doss-cell { padding: 26px 28px; border-right: 1px solid var(--line); }
  .lg-doss-cell:last-child { border-right: 0; }
  .lg-doss-k { display: block; font-family: var(--sans); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--brass-dark); margin-bottom: 10px; }
  .lg-doss-v { display: block; font-family: var(--serif); font-size: 18px; line-height: 1.32; color: var(--ink); }

  /* Body */
  .lg-body { display: grid; grid-template-columns: 1fr 340px; gap: clamp(40px, 6vw, 80px); padding: clamp(50px, 8vw, 90px) 30px; align-items: start; }
  .lg-main { font-size: 17px; line-height: 1.78; color: var(--ink); font-weight: 300; }
  .lg-main p { margin-bottom: 20px; }
  .lg-lead-para { font-size: 20px; line-height: 1.6; color: #2c2b26; }
  .lg-lead-para::first-letter { font-family: var(--serif); font-size: 62px; float: left; line-height: .82; padding: 6px 12px 0 0; color: var(--brass); }
  .lg-note { border-left: 3px solid var(--brass); background: var(--ivory-2); padding: 20px 24px; margin: 30px 0; border-radius: 0 4px 4px 0; }
  .lg-note-tag { font-family: var(--sans); font-size: 11px; letter-spacing: .18em; text-transform: uppercase; color: var(--brass-dark); }
  .lg-note p { margin: 8px 0 0; font-size: 15.5px; line-height: 1.6; color: var(--muted); }
  .lg-h2 { font-size: clamp(24px, 3.2vw, 32px); margin: 40px 0 18px; }
  .lg-handles { list-style: none; padding: 0; }
  .lg-handles li { position: relative; padding: 12px 0 12px 30px; border-bottom: 1px solid var(--line); font-size: 16px; }
  .lg-handles li::before { content: '✓'; position: absolute; left: 0; top: 11px; color: var(--brass); font-size: 15px; }

  .lg-side { position: sticky; top: 100px; }
  .lg-side-card { background: var(--green); color: var(--ivory); border-radius: 6px; padding: 26px; }
  .lg-side-card .lg-eyebrow { color: var(--brass); }
  .lg-why { font-family: var(--serif); font-size: 20px; line-height: 1.42; margin: 12px 0 20px; color: var(--ivory); }
  .lg-hero-img { height: 168px; border-radius: 4px; background-size: cover; background-position: center; margin-bottom: 22px; }
  .lg-side-btn { width: 100%; justify-content: center; }
  .lg-side-call { display: block; text-align: center; margin-top: 14px; font-size: 13px; letter-spacing: .06em; color: rgba(246,241,231,.75); }

  /* FAQ band */
  .lg-faq-band { background: var(--ivory-2); padding: clamp(50px, 7vw, 84px) 0; border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .lg-faq-title { text-align: center; margin: 0 0 40px; }
  .lg-faqs { max-width: 820px; margin: 0 auto; display: grid; gap: 4px; }
  .lg-faq { display: grid; grid-template-columns: 54px 1fr; gap: 8px; padding: 22px 0; border-bottom: 1px solid var(--line); }
  .lg-faq-n { font-family: var(--serif); font-size: 24px; color: var(--brass); }
  .lg-faq-q { font-family: var(--serif); font-size: 20px; margin: 0 0 8px; color: var(--ink); }
  .lg-faq-a { font-size: 15.5px; line-height: 1.62; color: var(--muted); margin: 0; }

  /* Matrix chips */
  .lg-matrix { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; padding: clamp(46px, 7vw, 78px) 30px; }
  .lg-chips { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 16px; }
  .lg-chip { font-family: var(--sans); font-size: 13.5px; letter-spacing: .02em; padding: 9px 16px; border: 1px solid var(--line); border-radius: 40px; color: var(--ink); transition: .2s; }
  .lg-chip:hover { border-color: var(--brass); color: var(--brass-dark); }
  .lg-chip-on { background: var(--green); color: var(--ivory); border-color: var(--green); }

  /* CTA */
  .lg-cta { background: var(--green-deep); color: var(--ivory); text-align: center; padding: clamp(56px, 9vw, 104px) 0; }
  .lg-cta-h { font-size: clamp(30px, 4.4vw, 50px); margin: 14px 0 0; }
  .lg-cta-h em { color: var(--brass); font-style: italic; }
  .lg-cta-p { max-width: 560px; margin: 18px auto 0; color: rgba(246,241,231,.8); font-size: 17px; }

  @media (max-width: 900px) {
    .lg-dossier { grid-template-columns: 1fr 1fr; }
    .lg-doss-cell:nth-child(2) { border-right: 0; }
    .lg-doss-cell:nth-child(1), .lg-doss-cell:nth-child(2) { border-bottom: 1px solid var(--line); }
    .lg-body { grid-template-columns: 1fr; }
    .lg-side { position: static; }
    .lg-matrix { grid-template-columns: 1fr; gap: 30px; }
  }
  @media (max-width: 560px) {
    .lg-dossier { grid-template-columns: 1fr; margin-top: -60px; }
    .lg-doss-cell { border-right: 0; border-bottom: 1px solid var(--line); }
    .lg-doss-cell:last-child { border-bottom: 0; }
    .lg-faq { grid-template-columns: 38px 1fr; }
  }
</style>
