---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Faq { q: string; a: string; }
interface Benefit { k: string; h: string; p: string; }
interface Props {
  seoTitle: string;
  seoDescription: string;
  name: string;            // e.g. "Paver driveways"
  crumb: string;           // e.g. "Driveways"
  eyebrow: string;
  h1: string;
  h1em?: string;           // optional italic/brass tail of the headline
  lede: string;
  heroImg: string;
  heroAlt: string;
  heroLabel: string;
  intro: string[];         // paragraphs
  benefits: Benefit[];
  included: string[];      // "our standard" checklist
  includedNote?: string;   // local-code note
  materials: string[];
  faqs: Faq[];
}
const {
  seoTitle, seoDescription, name, crumb, eyebrow, h1, h1em, lede,
  heroImg, heroAlt, heroLabel, intro, benefits, included, includedNote, materials, faqs,
} = Astro.props as Props;

const url = (p: string) => new URL(p, Astro.site).href;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: name,
    name: name,
    areaServed: { '@type': 'AdministrativeArea', name: 'Palm Beach County, Florida' },
    provider: {
      '@type': 'LocalBusiness',
      name: 'Perfect Pavers of Palm Beach',
      telephone: '+1-954-779-1855',
      areaServed: 'Palm Beach County, FL',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: url('/') },
      { '@type': 'ListItem', position: 2, name: crumb, item: url(Astro.url.pathname) },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---
<BaseLayout title={seoTitle} description={seoDescription}>

  <nav class="crumbs">
    <div class="wrap">
      <a href="/">Home</a> <span>/</span> <a href="/#services">Services</a> <span>/</span> <strong>{crumb}</strong>
    </div>
  </nav>

  <section class="wrap hero">
    <div class="hero-text">
      <div class="eyebrow">{eyebrow}</div>
      <h1>{h1} {h1em && <em>{h1em}</em>}</h1>
      <p class="lede">{lede}</p>
      <div class="hero-cta">
        <a href="/contact" class="btn btn-brass">Request your on-site visit</a>
        <a href="tel:+19547791855" class="btn btn-ghost">Call (954) 779-1855</a>
      </div>
    </div>
    <div class="hero-img">
      <div class="ph" data-label={heroLabel}><img src={heroImg} alt={heroAlt} width="1200" height="900" fetchpriority="high" /></div>
    </div>
  </section>

  <section class="block wrap svc-intro">
    <div class="svc-intro-grid">
      <div class="svc-intro-main">
        <div class="sec-head">
          <span class="sec-num">Why pavers</span>
          <h2>{name} done the right way.</h2>
        </div>
        <div class="intro-copy">
          {intro.map((p) => <p>{p}</p>)}
        </div>
      </div>
      <aside class="svc-intro-stats">
        <div class="sis"><span class="sis-n">35+</span><span class="sis-l">Years in South Florida</span></div>
        <div class="sis"><span class="sis-n">500+</span><span class="sis-l">Projects in Palm Beach</span></div>
        <div class="sis"><span class="sis-n">24&ndash;48 hrs</span><span class="sis-l">Estimate turnaround</span></div>
        <div class="sis"><span class="sis-n">100%</span><span class="sis-l">Permits handled by us</span></div>
      </aside>
    </div>
  </section>

  <section class="block wrap" style="padding-top:0">
    <div class="props">
      {benefits.map((b) => (
        <div class="card">
          <div class="k">{b.k}</div>
          <h3>{b.h}</h3>
          <p>{b.p}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="incl">
    <div class="wrap incl-grid">
      <div>
        <div class="eyebrow" style="color:var(--brass)">Our standard</div>
        <h2>What every install includes.</h2>
        <p class="incl-lede">No corners cut beneath the surface. Every project is built on the same foundation, written into your estimate up front.</p>
        {includedNote && <p class="incl-note"><i>✦</i> {includedNote}</p>}
      </div>
      <ul class="incl-list">
        {included.map((it) => <li><i>✓</i> {it}</li>)}
      </ul>
    </div>
  </section>

  <section class="block wrap">
    <div class="sec-head">
      <span class="sec-num">Materials</span>
      <h2>Choose your finish.</h2>
    </div>
    <div class="materials">
      {materials.map((m) => <span class="mat">{m}</span>)}
    </div>
  </section>

  <section class="block wrap faq">
    <div class="sec-head">
      <span class="sec-num">Questions</span>
      <h2>Good to know.</h2>
    </div>
    <div class="faq-list">
      {faqs.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="cta">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Your free on-site visit</div>
      <h2>Let&rsquo;s walk your property.</h2>
      <p>Tell us the surface, the size, and your timeline. We&rsquo;ll be at your door within a day or two, samples in hand, no charge, no pressure.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a href="/contact" class="btn btn-brass">Request a visit</a>
        <a href="tel:+19547791855" class="btn btn-ghost" style="color:var(--ivory)">Call (954) 779-1855</a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <style>
    .crumbs{border-bottom:1px solid var(--line);background:var(--ivory)}
    .crumbs .wrap{padding-top:16px;padding-bottom:16px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
    .crumbs a:hover{color:var(--brass-dark)}
    .crumbs span{margin:0 8px;color:var(--brass)}
    .crumbs strong{font-weight:500;color:var(--ink)}

    .svc-intro-grid{display:flex;align-items:center}
    .svc-intro-main{flex:0 1 auto;max-width:60ch}
    .svc-intro .intro-copy{max-width:60ch;margin-top:34px}
    .intro-copy p{font-size:17px;color:var(--muted);font-weight:300;margin-bottom:18px}
    .svc-intro-stats{flex:0 0 auto;margin:0 110px 0 auto;display:grid;grid-template-columns:1fr 1fr;gap:26px;width:360px;max-width:42vw}
    .svc-intro-stats .sis{aspect-ratio:1/1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;border:1px solid var(--line);border-radius:8px;background:var(--ivory);padding:12px}
    .svc-intro-stats .sis-n{flex:0 0 60%;display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-weight:600;color:var(--green);line-height:1;letter-spacing:-.01em;font-size:clamp(24px,2.4vw,36px);white-space:nowrap}
    .svc-intro-stats .sis-l{font-family:var(--sans);font-size:10.5px;font-weight:400;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);line-height:1.55;max-width:15ch}

    .incl{background:var(--green-deep);color:var(--ivory)}
    .incl-grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:60px;align-items:start;padding:96px 40px}
    .incl h2{color:var(--ivory);font-size:42px;margin-top:14px}
    .incl-lede{opacity:.85;font-weight:300;margin-top:18px;font-size:16px}
    .incl-note{margin-top:22px;font-size:14px;opacity:.9;font-weight:300;border-left:2px solid var(--brass);padding-left:16px}
    .incl-note i{color:var(--brass);font-style:normal;margin-right:6px}
    .incl-list{list-style:none;display:grid;gap:14px}
    .incl-list li{display:grid;grid-template-columns:auto 1fr;gap:14px;align-items:start;padding-bottom:14px;border-bottom:1px solid var(--line-light);font-size:15px;font-weight:300}
    .incl-list i{color:var(--brass);font-style:normal;font-size:15px}

    .materials{display:flex;flex-wrap:wrap;gap:12px}
    .mat{font-family:var(--serif);font-size:18px;font-style:italic;color:var(--ink);border:1px solid var(--line);border-radius:40px;padding:10px 24px;background:var(--ivory);transition:transform .35s cubic-bezier(.16,1,.3,1),border-color .35s ease,color .35s ease,box-shadow .35s ease}
    .mat:hover{transform:translateY(-3px);border-color:var(--brass);color:var(--brass-dark);box-shadow:0 10px 26px rgba(35,35,31,.12)}

    .faq-list{max-width:820px;border-top:1px solid var(--line)}
    .faq-list details{border-bottom:1px solid var(--line);padding:4px 0}
    .faq-list summary{cursor:pointer;list-style:none;padding:22px 0;font-family:var(--serif);font-size:22px;color:var(--ink);display:flex;justify-content:space-between;align-items:center}
    .faq-list summary::-webkit-details-marker{display:none}
    .faq-list summary::after{content:'+';color:var(--brass-dark);font-family:var(--sans);font-weight:400}
    .faq-list details[open] summary::after{content:'–'}
    .faq-list details p{padding:0 0 24px;color:var(--muted);font-weight:300;font-size:16px;max-width:70ch}

    @media(max-width:980px){
      .incl-grid{grid-template-columns:1fr;gap:34px;padding:60px 22px}
      .incl h2{font-size:32px}
      .faq-list summary{font-size:19px}
      .svc-intro-grid{grid-template-columns:1fr;gap:8px}
      .svc-intro-stats{margin-top:30px}
    }
    @media(prefers-reduced-motion:reduce){
      .mat{transition:none}
      .mat:hover{transform:none}
    }
  </style>

</BaseLayout>
