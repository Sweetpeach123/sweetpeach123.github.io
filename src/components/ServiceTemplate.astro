---
import BaseLayout from '../layouts/BaseLayout.astro';

interface Faq { q: string; a: string; }
interface Benefit { k: string; h: string; p: string; }
interface RelLink { href: string; label: string; note?: string; }
interface Props {
  seoTitle: string;
  seoDescription: string;
  name: string;            // e.g. "Paver driveways"
  crumb: string;           // e.g. "Driveways"
  eyebrow: string;
  h1: string;
  h1em?: string;           // optional italic/brass tail of the headline
  lede: string;
  heroImg: string;
  heroAlt: string;
  heroLabel: string;
  intro: string[];         // paragraphs
  benefits: Benefit[];
  included: string[];      // "our standard" checklist
  includedNote?: string;   // local-code note
  materials: string[];
  faqs: Faq[];
  relatedProjects?: RelLink[];  // contextual links to portfolio items
  relatedReading?: RelLink[];   // contextual links to blog / other services
  materialImages?: Record<string, string>;  // per-page override of the shared finish photos
  materialsLabel?: string;   // section eyebrow, default "Materials"
  materialsHeading?: string; // section h2, default "Choose your finish."
}
const {
  seoTitle, seoDescription, name, crumb, eyebrow, h1, h1em, lede,
  heroImg, heroAlt, heroLabel, intro, benefits, included, includedNote, materials, faqs,
  relatedProjects = [], relatedReading = [], materialImages = {},
  materialsLabel = 'Materials', materialsHeading = 'Choose your finish.',
} = Astro.props as Props;
const hasRelated = relatedProjects.length > 0 || relatedReading.length > 0;

interface MatInfo {
  img?: string;
  tagline: string;
  properties: string[];
  why: string;
  bestFor: string[];
  pricing: string;
}
// Central material reference, shared across every service page. Pricing is an
// approximate installed range for Palm Beach County — placeholder figures the
// client should confirm. Photos are placeholders until real swatch shots arrive.
const MATERIAL_INFO: Record<string, MatInfo> = {
  'Concrete pavers': {
    img: '/images/mat-concrete.jpg',
    tagline: 'The versatile workhorse — every color, shape and budget.',
    properties: ['Manufactured to a consistent size and strength', 'The widest range of colors, shapes and patterns', 'Individually replaceable if one is ever stained or cracked', 'Holds up to vehicle weight when the base is built right'],
    why: 'It gives you the broadest design freedom at the friendliest price, and because the surface is made of individual units it flexes with the ground instead of cracking like poured concrete.',
    bestFor: ['Driveways and parking aprons', 'Walkways and patios', 'Large areas where budget matters', 'Matching an existing paver look'],
    pricing: '$13–$22 / sq ft installed',
  },
  'Brick pavers': {
    img: '/images/mat-brick.jpg',
    tagline: 'Classic clay color that never fades.',
    properties: ['Color runs all the way through — it will not fade in the sun', 'Naturally slip-resistant texture', 'Timeless, traditional appearance', 'Extremely durable, lasts for decades'],
    why: 'Real clay brick keeps its warm color permanently because the color is baked in, not coated on, so it suits classic and historic homes that want a finish that ages gracefully.',
    bestFor: ['Traditional and colonial homes', 'Walkways and garden paths', 'Accent borders around other pavers', 'Patios with a timeless look'],
    pricing: '$15–$25 / sq ft installed',
  },
  'Porcelain pavers': {
    img: '/images/mat-porcelain.jpg',
    tagline: 'Modern, ultra-low-maintenance and stain-proof.',
    properties: ['Nearly zero water absorption — resists stains and mold', 'Fade-proof, scratch-resistant surface', 'Cool underfoot, even in full sun', 'Clean, modern lines and consistent color'],
    why: 'Porcelain is the easiest finish to live with: it shrugs off wine, grease and chlorine, stays cool by the pool, and keeps its exact color for the life of the install.',
    bestFor: ['Pool decks and patios', 'Modern and contemporary homes', 'Dining and entertaining terraces', 'Anyone wanting minimal upkeep'],
    pricing: '$20–$32 / sq ft installed',
  },
  'Travertine': {
    img: '/images/mat-travertine.jpg',
    tagline: 'The resort standard — cool, natural, elegant.',
    properties: ['Stays cool underfoot in direct sun', 'Naturally grippy, ideal for wet areas', 'Each piece is unique natural stone', 'Soft, neutral tones that suit any home'],
    why: 'It is the go-to around Florida pools because it reflects heat instead of absorbing it, so the deck stays comfortable barefoot at midday, with a high-end natural look.',
    bestFor: ['Pool decks and surrounds', 'Patios and courtyards', 'Luxury and Mediterranean homes', 'Walkways in shaded gardens'],
    pricing: '$18–$30 / sq ft installed',
  },
  'Permeable systems': {
    tagline: 'Drains rain through the surface — great for code and drainage.',
    properties: ['Lets stormwater pass through the joints into the base', 'Reduces puddling and runoff', 'Often helps meet drainage and swale requirements', 'Same durable paver surface on top'],
    why: 'A permeable system manages water on your own property instead of sheeting it onto the street, which solves drainage problems and can satisfy Palm Beach County stormwater rules.',
    bestFor: ['Driveways with drainage limits', 'Low-lying or flood-prone lots', 'Properties with swale requirements', 'Eco-conscious projects'],
    pricing: '$17–$28 / sq ft installed',
  },
  'Natural stone': {
    tagline: 'One-of-a-kind stone with unmatched depth and character.',
    properties: ['Every piece is unique — no two alike', 'Naturally cool and slip-resistant', 'Rich, varied tones that change with the light', 'Ages beautifully with a periodic seal'],
    why: 'Nothing matches the depth and texture of real quarried stone; it gives a property a sense of permanence and quiet luxury that manufactured products imitate but never equal.',
    bestFor: ['Pool decks and patios', 'Feature walkways and entries', 'High-end and estate homes', 'Wall facing and accents'],
    pricing: '$22–$40 / sq ft installed',
  },
  'Marble': {
    tagline: 'Bright, luminous stone with a refined finish.',
    properties: ['Reflects heat and stays cool underfoot', 'Bright, light tones open up a space', 'Smooth, refined natural surface', 'Premium, high-end appearance'],
    why: 'Marble brings a luminous, polished elegance to a pool deck or patio while staying cool in the Florida sun, the choice when the look needs to feel truly upscale.',
    bestFor: ['Luxury pool decks', 'Formal patios and entries', 'Estate and contemporary homes', 'Shaded courtyards'],
    pricing: '$25–$45 / sq ft installed',
  },
  'Limestone': {
    tagline: 'Soft, earthy tones with a calm, natural feel.',
    properties: ['Even, understated color', 'Comfortable and cool underfoot', 'Natural slip resistance', 'Pairs well with greenery and water'],
    why: 'Limestone offers the serenity of natural stone in soft, consistent tones, perfect when you want an organic, calming surface that blends into the landscape.',
    bestFor: ['Pool decks and patios', 'Garden walkways', 'Mediterranean and coastal homes', 'Courtyards and seating areas'],
    pricing: '$20–$36 / sq ft installed',
  },
  'Natural stone pavers': {
    tagline: 'Quarried stone cut to a uniform, easy-to-lay size.',
    properties: ['Real stone with consistent dimensions', 'Naturally cool and slip-resistant', 'Unique color and veining in every piece', 'Durable and long-lasting'],
    why: 'You get the genuine character of natural stone with the predictable sizing of a paver, which makes for clean lines and easier matching across a large area.',
    bestFor: ['Driveways and walkways', 'Pool decks and patios', 'Large areas needing consistency', 'Upscale whole-yard designs'],
    pricing: '$22–$40 / sq ft installed',
  },
  'Segmental wall block': {
    tagline: 'Engineered block for strong, lasting retaining and seating walls.',
    properties: ['Interlocking units engineered for load', 'Built-in drainage when installed correctly', 'Available in several colors and textures', 'No mortar needed — flexes with the ground'],
    why: 'Segmental block is the proven way to build a wall that holds its line for decades, because the system is designed around drainage and backfill, the parts you never see.',
    bestFor: ['Retaining walls', 'Seating walls around patios', 'Raised planters and terraces', 'Grade changes in the yard'],
    pricing: '$40–$70 / sq ft of wall face',
  },
  'Stacked stone veneer': {
    tagline: 'A natural stone face for a rich, textured wall.',
    properties: ['Real stone facing over a solid structure', 'Deep texture and natural shadow lines', 'Ties walls into stone elsewhere on the home', 'Durable, weather-resistant finish'],
    why: 'Veneer wraps a structural wall in genuine stacked stone, giving you the rugged, high-end look of a dry-stone wall with the strength of an engineered core.',
    bestFor: ['Seating and feature walls', 'Terrace and patio borders', 'Entry columns and pillars', 'Matching home stonework'],
    pricing: '$30–$55 / sq ft of wall face',
  },
  'Finished concrete block': {
    tagline: 'A clean, structural wall finish that complements pavers.',
    properties: ['Strong structural core', 'Smooth or textured finished face', 'Color-matched to your hardscape', 'Cost-effective and durable'],
    why: 'Finished block gives you a solid, good-looking wall at a sensible price, and we color and cap it to belong to the same design as your pavers.',
    bestFor: ['Retaining and boundary walls', 'Seating walls', 'Budget-conscious projects', 'Clean, modern lines'],
    pricing: '$30–$50 / sq ft of wall face',
  },
};
const matSlug = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
const matCards = materials.map((m) => {
  const base = MATERIAL_INFO[m] ?? null;
  const info = base ? { ...base, img: materialImages[m] ?? base.img } : null;
  return { name: m, info, id: matSlug(m) };
});
const hasMatModals = matCards.some((m) => m.info);

const url = (p: string) => new URL(p, Astro.site).href;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    serviceType: name,
    name: name,
    areaServed: { '@type': 'AdministrativeArea', name: 'Palm Beach County, Florida' },
    provider: {
      '@type': 'LocalBusiness',
      name: 'Perfect Pavers of Palm Beach',
      telephone: '+1-954-779-1855',
      areaServed: 'Palm Beach County, FL',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: url('/') },
      { '@type': 'ListItem', position: 2, name: crumb, item: url(Astro.url.pathname) },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---
<BaseLayout title={seoTitle} description={seoDescription}>

  <nav class="crumbs">
    <div class="wrap">
      <a href="/">Home</a> <span>/</span> <a href="/#services">Services</a> <span>/</span> <strong>{crumb}</strong>
    </div>
  </nav>

  <section class="wrap hero">
    <div class="hero-text">
      <div class="eyebrow">{eyebrow}</div>
      <h1>{h1} {h1em && <em>{h1em}</em>}</h1>
      <p class="lede">{lede}</p>
      <div class="hero-cta">
        <a href="/contact/" class="btn btn-brass">Request your on-site visit</a>
        <a href="tel:+19547791855" class="btn btn-ghost">Call (954) 779-1855</a>
      </div>
    </div>
    <div class="hero-img">
      <div class="ph" data-label={heroLabel}><img src={heroImg} alt={heroAlt} width="1200" height="900" fetchpriority="high" /></div>
    </div>
  </section>

  <section class="block wrap svc-intro">
    <div class="svc-intro-grid">
      <div class="svc-intro-main">
        <div class="sec-head">
          <span class="sec-num">Why pavers</span>
          <h2>{name} done the right way.</h2>
        </div>
        <div class="intro-copy">
          {intro.map((p) => <p>{p}</p>)}
        </div>
      </div>
      <aside class="svc-intro-stats">
        <div class="sis"><span class="sis-n">35+</span><span class="sis-l">Years in South Florida</span></div>
        <div class="sis"><span class="sis-n">500+</span><span class="sis-l">Projects in Palm Beach</span></div>
        <div class="sis"><span class="sis-n">24&ndash;48 hrs</span><span class="sis-l">Estimate turnaround</span></div>
        <div class="sis"><span class="sis-n">100%</span><span class="sis-l">Permits handled by us</span></div>
      </aside>
    </div>
  </section>

  <section class="block wrap" style="padding-top:0">
    <div class="props">
      {benefits.map((b) => (
        <div class="card">
          <div class="k">{b.k}</div>
          <h3>{b.h}</h3>
          <p>{b.p}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="incl">
    <div class="wrap incl-grid">
      <div>
        <div class="eyebrow" style="color:var(--brass)">Our standard</div>
        <h2>What every install includes.</h2>
        <p class="incl-lede">No corners cut beneath the surface. Every project is built on the same foundation, written into your estimate up front.</p>
        {includedNote && <p class="incl-note"><i>✦</i> {includedNote}</p>}
      </div>
      <ul class="incl-list">
        {included.map((it) => <li><i>✓</i> {it}</li>)}
      </ul>
    </div>
  </section>

  {materials.length > 0 && (
  <section class="block wrap" style="padding-bottom:44px">
    <div class="sec-head">
      <span class="sec-num">{materialsLabel}</span>
      <h2>{materialsHeading}</h2>
    </div>
    <div class="materials">
      {matCards.map((m) => m.info
        ? <button type="button" class="mat mat-btn" data-mat={m.id}>{m.name}</button>
        : <span class="mat">{m.name}</span>)}
    </div>
  </section>
  )}

  {hasMatModals && (
    <div class="mat-overlay" id="matOverlay" hidden>
      <div class="mat-backdrop" data-mat-close></div>
      {matCards.filter((m) => m.info).map((m) => (
        <div class="mat-sheet" id={`sheet-${m.id}`} role="dialog" aria-modal="true" aria-label={m.name} hidden>
          <button type="button" class="mat-x" data-mat-close aria-label="Close">&times;</button>
          <div class="mat-scroll">
            <div class="mat-ph ph" data-label={m.name}>
              {m.info.img ? <img src={m.info.img} alt={m.name} /> : <i>{m.name}</i>}
            </div>
            <div class="mat-body">
              <div class="eyebrow" style="color:var(--brass)">Material</div>
              <h3>{m.name}</h3>
              <p class="mat-tag">{m.info.tagline}</p>

              <div class="mat-sec">
                <h4>Properties</h4>
                <ul>{m.info.properties.map((x) => <li>{x}</li>)}</ul>
              </div>
              <div class="mat-sec">
                <h4>Why people choose it</h4>
                <p>{m.info.why}</p>
              </div>
              <div class="mat-sec">
                <h4>Best used for</h4>
                <ul>{m.info.bestFor.map((x) => <li>{x}</li>)}</ul>
              </div>
              <div class="mat-sec">
                <h4>Approximate pricing</h4>
                <p class="mat-price">{m.info.pricing}</p>
                <p class="mat-note">Approximate installed range in Palm Beach County. Your free on-site visit and written estimate are exact and itemized.</p>
              </div>

              <a href="/contact/" class="btn btn-brass mat-cta">Request your free on-site visit</a>
            </div>
          </div>
        </div>
      ))}
    </div>
  )}

  <script is:inline>
      (function () {
        const overlay = document.getElementById('matOverlay');
        if (!overlay) return;
        const sheets = overlay.querySelectorAll('.mat-sheet');
        let openId = null;

        function open(id) {
          const sheet = document.getElementById('sheet-' + id);
          if (!sheet) return;
          sheets.forEach((s) => { s.hidden = s !== sheet; });
          overlay.hidden = false;
          requestAnimationFrame(() => overlay.classList.add('is-open'));
          document.body.style.overflow = 'hidden';
          sheet.querySelector('.mat-scroll').scrollTop = 0;
          openId = id;
        }
        function close() {
          overlay.classList.remove('is-open');
          document.body.style.overflow = '';
          openId = null;
          setTimeout(() => { overlay.hidden = true; }, 280);
        }

        document.querySelectorAll('.mat-btn').forEach((b) => {
          b.addEventListener('click', () => open(b.getAttribute('data-mat')));
        });
        overlay.querySelectorAll('[data-mat-close]').forEach((el) => {
          el.addEventListener('click', close);
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && openId) close();
        });
      })();
    </script>

  <section class="block wrap faq" style="padding-top:52px">
    <div class="sec-head">
      <span class="sec-num">Questions</span>
      <h2>Good to know.</h2>
    </div>
    <div class="faq-list">
      {faqs.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  {hasRelated && (
    <section class="block wrap related">
      <div class="rel-grid">
        {relatedProjects.length > 0 && (
          <div class="rel-col">
            <div class="eyebrow" style="color:var(--brass-dark)">See it in our work</div>
            <h2>Related projects.</h2>
            <ul class="rel-list">
              {relatedProjects.map((r) => (
                <li><a href={r.href}>{r.label} <span aria-hidden="true">→</span></a>{r.note && <span class="rel-note">{r.note}</span>}</li>
              ))}
            </ul>
          </div>
        )}
        {relatedReading.length > 0 && (
          <div class="rel-col">
            <div class="eyebrow" style="color:var(--brass-dark)">Keep reading</div>
            <h2>Helpful next steps.</h2>
            <ul class="rel-list">
              {relatedReading.map((r) => (
                <li><a href={r.href}>{r.label} <span aria-hidden="true">→</span></a>{r.note && <span class="rel-note">{r.note}</span>}</li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>
  )}

  <section class="cta">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Your free on-site visit</div>
      <h2>Let&rsquo;s walk your property.</h2>
      <p>Tell us the surface, the size, and your timeline. We&rsquo;ll be at your door within a day or two, no charge, no pressure.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a href="/contact/" class="btn btn-brass">Request a visit</a>
        <a href="tel:+19547791855" class="btn btn-ghost" style="color:var(--ivory)">Call (954) 779-1855</a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <style>
    .crumbs{border-bottom:1px solid var(--line);background:var(--ivory)}
    .crumbs .wrap{padding-top:16px;padding-bottom:16px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
    .crumbs a:hover{color:var(--brass-dark)}
    .crumbs span{margin:0 8px;color:var(--brass)}
    .crumbs strong{font-weight:500;color:var(--ink)}

    /* Mirror the hero's column split so the 2×2 grid centers under the hero image */
    .svc-intro-grid{display:grid;grid-template-columns:1.05fr .95fr;align-items:center;gap:0}
    .svc-intro-main{max-width:60ch;padding-right:56px}
    .svc-intro .intro-copy{max-width:60ch;margin-top:34px}
    .intro-copy p{font-size:17px;color:var(--muted);font-weight:300;margin-bottom:18px}
    .svc-intro-stats{margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:26px;width:360px;max-width:100%}
    .svc-intro-stats .sis{aspect-ratio:1/1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;border:1px solid var(--line);border-radius:8px;background:var(--ivory);padding:12px;transition:transform .4s cubic-bezier(.16,1,.3,1),border-color .1s linear,box-shadow .4s ease,opacity .6s cubic-bezier(.16,1,.3,1)}
    .svc-intro-stats .sis:hover{transform:translateY(-5px);border-color:var(--brass);box-shadow:0 14px 30px rgba(35,35,31,.12)}
    .svc-intro-stats .sis:hover .sis-n{color:var(--brass-dark)}
    .svc-intro-stats .sis-n{flex:0 0 60%;display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-weight:600;color:var(--green);line-height:1;letter-spacing:-.01em;font-size:clamp(24px,2.4vw,36px);white-space:nowrap;transition:color .1s linear}
    .svc-intro-stats .sis-l{font-family:var(--sans);font-size:10.5px;font-weight:400;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);line-height:1.55;max-width:15ch}

    .incl{background:var(--green-deep);color:var(--ivory)}
    .incl-grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:60px;align-items:start;padding:96px 40px}
    .incl h2{color:var(--ivory);font-size:clamp(30px,3.8vw,42px);margin-top:14px}
    .incl-lede{opacity:.85;font-weight:300;margin-top:18px;font-size:16px}
    .incl-note{margin-top:22px;font-size:14px;opacity:.9;font-weight:300;border-left:2px solid var(--brass);padding-left:16px}
    .incl-note i{color:var(--brass);font-style:normal;margin-right:6px}
    .incl-list{list-style:none;display:grid;gap:14px}
    .incl-list li{display:grid;grid-template-columns:auto 1fr;gap:14px;align-items:start;padding-bottom:14px;border-bottom:1px solid var(--line-light);font-size:15px;font-weight:300;transition:border-color .08s linear,background-color .08s linear}
    .incl-list li:hover{border-color:var(--brass);background:rgba(176,138,79,.10)}
    .incl-list i{color:var(--brass);font-style:normal;font-size:15px}

    .materials{display:flex;flex-wrap:wrap;gap:12px}
    .mat{font-family:var(--serif);font-size:18px;font-style:italic;color:var(--ink);border:1px solid var(--line);border-radius:40px;padding:10px 24px;background:var(--ivory);transition:transform .35s cubic-bezier(.16,1,.3,1),border-color .35s ease,color .35s ease,box-shadow .35s ease}
    .mat:hover{transform:translateY(-3px);border-color:var(--brass);color:var(--brass-dark);box-shadow:0 10px 26px rgba(35,35,31,.12)}
    .mat-btn{cursor:pointer;line-height:1;animation:matBreathe 2.8s ease-in-out infinite}
    .mat-btn:hover{animation-play-state:paused;background:var(--green);border-color:var(--green);color:var(--ivory);transform:translateY(-3px) scale(1.03)}
    @keyframes matBreathe{
      0%,100%{box-shadow:0 0 0 0 rgba(176,138,79,0);border-color:var(--line)}
      50%{box-shadow:0 8px 20px rgba(176,138,79,.20);border-color:var(--brass)}
    }

    /* Material modal */
    .mat-overlay{position:fixed;inset:0;z-index:120;display:flex;align-items:center;justify-content:center;padding:24px;opacity:0;transition:opacity .28s ease}
    .mat-overlay[hidden]{display:none}
    .mat-overlay.is-open{opacity:1}
    .mat-backdrop{position:absolute;inset:0;background:rgba(23,30,23,.55);backdrop-filter:blur(3px)}
    .mat-sheet{position:relative;z-index:1;width:100%;max-width:600px;max-height:88vh;background:var(--ivory);border-radius:14px;overflow:hidden;box-shadow:0 30px 80px rgba(20,20,16,.4);transform:translateY(18px) scale(.98);transition:transform .32s cubic-bezier(.16,1,.3,1)}
    .mat-overlay.is-open .mat-sheet{transform:none}
    .mat-x{position:absolute;top:12px;right:14px;z-index:3;width:38px;height:38px;border-radius:50%;border:none;background:rgba(246,241,231,.9);color:var(--ink);font-size:24px;line-height:1;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .2s ease}
    .mat-x:hover{background:#fff}
    .mat-scroll{max-height:88vh;overflow-y:auto;-webkit-overflow-scrolling:touch}
    .mat-ph{height:230px}
    .mat-body{padding:30px 36px 38px}
    .mat-body h3{font-size:32px;margin-top:8px}
    .mat-tag{font-family:var(--serif);font-style:italic;font-size:18px;color:var(--brass-dark);margin-top:8px}
    .mat-sec{margin-top:26px}
    .mat-sec h4{font-family:var(--sans);font-size:12px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:12px}
    .mat-sec ul{list-style:none;display:grid;gap:10px}
    .mat-sec li{position:relative;padding-left:22px;font-size:15.5px;font-weight:300;color:var(--ink)}
    .mat-sec li::before{content:'✦';position:absolute;left:0;top:0;color:var(--brass);font-size:13px}
    .mat-sec p{font-size:15.5px;font-weight:300;color:var(--muted);line-height:1.6}
    .mat-price{font-family:var(--serif)!important;font-size:26px!important;font-weight:600;color:var(--green)!important;margin-bottom:6px}
    .mat-note{font-size:13px!important;font-style:italic}
    .mat-cta{margin-top:30px;display:inline-block}

    @media(max-width:560px){
      .mat-body{padding:24px 22px 30px}
      .mat-body h3{font-size:26px}
      .mat-ph{height:180px}
    }

    .faq-list{max-width:820px;border-top:1px solid var(--line)}
    .faq-list details{border-bottom:1px solid var(--line);padding:4px 0;transition:border-color .08s linear,background-color .08s linear}
    .faq-list details:hover{border-color:var(--brass);background:rgba(176,138,79,.05)}
    .faq-list summary{cursor:pointer;list-style:none;padding:22px 0;font-family:var(--serif);font-size:22px;color:var(--ink);display:flex;justify-content:space-between;align-items:center;transition:color .08s linear}
    .faq-list summary:hover{color:var(--brass-dark)}
    .faq-list summary::-webkit-details-marker{display:none}
    .faq-list summary::after{content:'+';color:var(--brass-dark);font-family:var(--sans);font-weight:400}
    .faq-list details[open] summary::after{content:'–'}
    .faq-list details p{padding:0 0 24px;color:var(--muted);font-weight:300;font-size:16px;max-width:70ch}

    /* Related projects & reading — internal-link cluster */
    .related{border-top:1px solid var(--line);padding-top:56px}
    .rel-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:48px}
    .rel-col h2{font-size:clamp(24px,2.6vw,30px);margin-top:10px}
    .rel-list{list-style:none;margin-top:20px;display:grid;gap:2px}
    .rel-list li{border-top:1px solid var(--line);padding:14px 0;transition:border-color .08s linear}
    .rel-list li:hover{border-color:var(--brass)}
    .rel-list a{font-family:var(--serif);font-size:19px;color:var(--ink);display:inline-flex;align-items:center;gap:8px;transition:color .08s linear}
    .rel-list a span{color:var(--brass-dark);transition:transform .35s cubic-bezier(.16,1,.3,1);display:inline-block}
    .rel-list a:hover{color:var(--brass-dark)}
    .rel-list li:hover a span{transform:translateX(5px)}
    .rel-note{display:block;font-size:13.5px;color:var(--muted);font-weight:300;margin-top:3px}

    @media(max-width:1024px){
      .svc-intro-grid{grid-template-columns:1fr;align-items:stretch}
      .svc-intro-main{max-width:none;padding-right:0}
      .svc-intro-stats{margin:32px 0 0;width:100%;max-width:520px}
      .incl-grid{grid-template-columns:1fr;gap:34px;padding:clamp(48px,8vw,72px) 30px}
      .incl h2{margin-top:8px}
      .faq-list summary{font-size:19px}
    }
    @media(max-width:600px){
      .incl-grid{padding-left:18px;padding-right:18px}
      .svc-intro-stats{gap:14px}
      .faq-list summary{font-size:18px}
      .mat{font-size:16px;padding:9px 18px}
    }
    @media(prefers-reduced-motion:reduce){
      .mat{transition:none}
      .mat:hover{transform:none}
      .mat-btn{animation:none}
    }
  </style>

</BaseLayout>
