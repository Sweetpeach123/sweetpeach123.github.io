---
<div class="util">
  <div class="wrap">
    <div class="tags">
      <span><i>✦</i>State Licensed Building Contractor · CGC#________</span>
      <span><i>✦</i>ICPI Certified Installer</span>
      <span><i>✦</i>35+ years in South Florida</span>
    </div>
    <div>By appointment across Palm Beach County · <a href="tel:+19547791855">(954) 779-1855</a></div>
  </div>
</div>

<header>
  <div class="wrap nav">
    <a class="brand" href="/">
      <div class="mark">Perfect Pavers</div>
      <div class="sub">of Palm Beach</div>
    </a>
    <nav class="menu">
      <div class="menu-item">
        <a href="/#services">Residential <span class="caret">▾</span></a>
        <div class="drop">
          <div class="drop-inner">
            <ul>
              {services.map((s) => <li><a href={s.href}>{s.label}</a></li>)}
            </ul>
          </div>
        </div>
      </div>
      <a href="/commercial">Commercial</a>
      <a href="/portfolio">Portfolio</a>
      <div class="menu-item">
        <a href="/about/why-choose-us">About <span class="caret">▾</span></a>
        <div class="drop drop--right">
          <div class="drop-inner">
            <ul>
              {about.map((x) => <li><a href={x.href}>{x.label}</a></li>)}
            </ul>
          </div>
        </div>
