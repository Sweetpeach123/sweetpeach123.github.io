---
const services = [
  { label: 'Driveways', href: '/services/driveways/' },
  { label: 'Walkways', href: '/services/walkways/' },
  { label: 'Patios', href: '/services/patios/' },
  { label: 'Pool decks', href: '/services/pool-decks/' },
  { label: 'Outdoor living', href: '/services/outdoor-living/' },
  { label: 'Retaining & seating walls', href: '/services/retaining-seating-walls/' },
  { label: 'Natural stone', href: '/services/natural-stone/' },
  { label: 'Clean & seal', href: '/services/clean-seal/' },
];
const about = [
  { label: 'Why choose Perfect Pavers', href: '/about/why-choose-us/' },
  { label: 'Our process', href: '/about/our-process/' },
  { label: 'Service areas', href: '/service-areas/' },
  { label: 'Reviews', href: '/reviews/' },
  { label: 'FAQs', href: '/faqs/' },
  { label: 'Careers', href: '/careers/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Contact', href: '/contact/' },
];
---
<div class="topbar" id="topbar">
<div class="util">
  <div class="wrap">
    <div class="tags">
      <span><i>✦</i>State Certified General Contractor · CGC#1524492</span>
      <span><i>✦</i>CMHA Certified Installer</span>
      <span><i>✦</i>35+ years in South Florida</span>
    </div>
    <span class="util-license"><i>✦</i> State Licensed &amp; Insured</span>
    <div class="util-appt"><i>✦</i> Licensed &amp; Insured</div>
  </div>
</div>

<header>
  <div class="wrap nav">
    <a class="brand" href="/">
      <div class="mark">Perfect Pavers</div>
      <div class="sub">of Palm Beach</div>
    </a>
    <nav class="menu">
      <div class="menu-item">
        <a href="/#services">Services <span class="caret">▾</span></a>
        <div class="drop">
          <div class="drop-inner">
            <ul>
              {services.map((s) => <li><a href={s.href}>{s.label}</a></li>)}
            </ul>
          </div>
        </div>
      </div>
      <a href="/portfolio/">Portfolio</a>
      <div class="menu-item">
        <a href="/about/why-choose-us/">About <span class="caret">▾</span></a>
        <div class="drop drop--right">
          <div class="drop-inner">
            <ul>
              {about.map((x) => <li><a href={x.href}>{x.label}</a></li>)}
            </ul>
          </div>
        </div>
      </div>
      <a href="/financing/">Financing</a>
    </nav>
    <div class="nav-right">
      <a class="nav-phone" href="tel:+19547791855">(954) 779-1855</a>
      <a href="/contact/" class="btn btn-brass">Request a visit</a>
      <button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobileNav">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>
</div>

<div class="mobile-nav" id="mobileNav" hidden>
  <div class="mnav-backdrop" data-mnav-close></div>
  <nav class="mnav-panel" aria-label="Site">
    <div class="mnav-badge"><i>✦</i> State Licensed &amp; Insured</div>
    <button class="mnav-x" data-mnav-close aria-label="Close menu">&times;</button>
    <div class="mnav-body">
      <details class="mnav-group">
        <summary class="mnav-top">Services <span class="mnav-caret">▾</span></summary>
        <div class="mnav-sub">
          {services.map((s) => <a href={s.href}>{s.label}</a>)}
        </div>
      </details>
      <a class="mnav-top mnav-top--link" href="/portfolio/">Portfolio</a>
      <details class="mnav-group">
        <summary class="mnav-top">About <span class="mnav-caret">▾</span></summary>
        <div class="mnav-sub">
          {about.map((x) => <a href={x.href}>{x.label}</a>)}
        </div>
      </details>
      <a class="mnav-top mnav-top--link" href="/financing/">Financing</a>
      <div class="mnav-foot">
        <a class="mnav-phone" href="tel:+19547791855">✆&nbsp; (954) 779-1855</a>
        <a class="btn btn-brass" href="/contact/">Request a visit</a>
      </div>
    </div>
  </nav>
</div>

<script is:inline>
  (function () {
    const bar = document.getElementById('topbar');
    if (!bar) return;
    const util = 48; // height of the green certificate strip
    let last = window.scrollY;
    window.addEventListener('scroll', function () {
      const y = window.scrollY;
      if (y <= util) {
        bar.classList.remove('nudge-up');        // at the very top — show everything
      } else if (y > last + 2) {
        bar.classList.add('nudge-up');           // scrolling down — tuck the strip away
      } else if (y < last - 2) {
        bar.classList.remove('nudge-up');         // scrolling up — bring the strip back
      }
      last = y;
    }, { passive: true });
  })();
</script>

<script is:inline>
  (function () {
    const nav = document.getElementById('mobileNav');
    const toggle = document.getElementById('navToggle');
    if (!nav || !toggle) return;
    function open() {
      nav.hidden = false;
      requestAnimationFrame(() => nav.classList.add('is-open'));
      document.body.style.overflow = 'hidden';
      toggle.classList.add('is-active');
      toggle.setAttribute('aria-expanded', 'true');
    }
    function close() {
      nav.classList.remove('is-open');
      document.body.style.overflow = '';
      toggle.classList.remove('is-active');
      toggle.setAttribute('aria-expanded', 'false');
      setTimeout(() => { nav.hidden = true; }, 500);
    }
    toggle.addEventListener('click', () => (nav.hidden ? open() : close()));
    nav.querySelectorAll('[data-mnav-close], .mnav-panel a').forEach((el) =>
      el.addEventListener('click', close)
    );
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !nav.hidden) close();
    });

    // Animate the Services/About sub-menus open & closed with the same slow glide as the panel
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    nav.querySelectorAll('details.mnav-group').forEach(function (d) {
      var summary = d.querySelector('summary');
      var sub = d.querySelector('.mnav-sub');
      if (!summary || !sub) return;
      summary.addEventListener('click', function (e) {
        if (reduce) return;                 // instant toggle when motion is reduced
        e.preventDefault();
        if (d.open) {
          sub.style.height = sub.scrollHeight + 'px';
          requestAnimationFrame(function () { sub.style.height = '0px'; });
          sub.addEventListener('transitionend', function done() {
            d.open = false; sub.style.height = ''; sub.removeEventListener('transitionend', done);
          });
        } else {
          d.open = true;
          sub.style.height = '0px';
          requestAnimationFrame(function () { sub.style.height = sub.scrollHeight + 'px'; });
          sub.addEventListener('transitionend', function done() {
            sub.style.height = 'auto'; sub.removeEventListener('transitionend', done);
          });
        }
      });
    });
  })();
</script>

<style>
  /* Hamburger button — hidden on desktop, shown when the inline menu collapses */
  .nav-toggle{display:none;flex-direction:column;justify-content:center;gap:5px;width:44px;height:44px;padding:0 9px;background:none;border:0;cursor:pointer}
  .nav-toggle span{display:block;height:2px;width:100%;background:var(--ink);border-radius:2px;transition:transform .3s cubic-bezier(.16,1,.3,1),opacity .2s ease}
  .nav-toggle.is-active span:nth-child(1){transform:translateY(7px) rotate(45deg)}
  .nav-toggle.is-active span:nth-child(2){opacity:0}
  .nav-toggle.is-active span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
  @media(max-width:1024px){ .nav-toggle{display:inline-flex} }

  /* Slide-in drawer */
  .mobile-nav{position:fixed;inset:0;z-index:90;opacity:0;transition:opacity .4s ease}
  .mobile-nav[hidden]{display:none}
  .mobile-nav.is-open{opacity:1}
  .mnav-backdrop{position:absolute;inset:0;background:rgba(16,22,18,.5);backdrop-filter:blur(3px)}
  .mnav-panel{position:absolute;top:0;left:0;height:100%;width:min(75vw,340px);background:var(--ivory);box-shadow:24px 0 60px rgba(16,22,18,.3);padding:0 0 30px;overflow-y:auto;-webkit-overflow-scrolling:touch;transform:translateX(-100%);transition:transform .5s cubic-bezier(.16,1,.3,1);display:flex;flex-direction:column}
  .mobile-nav.is-open .mnav-panel{transform:none}
  /* Green licensed-&-insured band fills the top of the drawer */
  .mnav-badge{background:var(--green);color:var(--ivory);padding:20px 56px 20px 30px;font-family:var(--sans);font-size:14px;font-weight:400;letter-spacing:.05em;display:flex;align-items:center;gap:7px}
  .mnav-badge i{color:var(--brass);font-style:normal;font-size:12px}
  .mnav-x{position:absolute;top:13px;right:16px;width:42px;height:42px;border:0;background:none;font-size:28px;line-height:1;color:var(--ivory);cursor:pointer;z-index:2}
  .mnav-body{display:flex;flex-direction:column;flex:1;padding:14px 30px 0}
  /* Top-level rows — only these show until you expand a group */
  .mnav-top{position:relative;display:flex;justify-content:space-between;align-items:center;gap:12px;font-family:var(--serif);font-size:22px;color:var(--ink);padding:14px 0;cursor:pointer;list-style:none}
  .mnav-top::before{content:'';position:absolute;top:0;left:0;right:28px;height:1px;background:rgba(35,35,31,.09)}
  .mnav-top::-webkit-details-marker{display:none}
  .mnav-body>.mnav-group:first-child .mnav-top::before{display:none}
  .mnav-caret{font-size:13px;color:var(--brass-dark);transition:transform .5s cubic-bezier(.16,1,.3,1)}
  .mnav-group[open] .mnav-caret{transform:rotate(180deg)}
  .mnav-group[open] .mnav-top{color:var(--brass-dark)}
  .mnav-sub{display:flex;flex-direction:column;margin:0;border-left:1px solid var(--line);padding:2px 0 14px 16px;overflow:hidden;transition:height .5s cubic-bezier(.16,1,.3,1)}
  .mnav-sub a{padding:9px 0;font-size:15px;color:var(--muted)}
  .mnav-sub a:hover{color:var(--brass-dark)}
  .mnav-foot{margin-top:auto;padding-top:26px;display:flex;flex-direction:column;gap:14px}
  .mnav-phone{font-size:18px;font-weight:500;letter-spacing:.04em;color:var(--green)}
  .mnav-foot .btn{justify-content:center}
  @media(prefers-reduced-motion:reduce){
    .mobile-nav,.mnav-panel,.nav-toggle span{transition:none}
  }
</style>
