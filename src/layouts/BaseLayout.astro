---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  bodyClass?: string;
  canonical?: string;
  image?: string;        // absolute URL for social share previews
}

const {
  title = 'Perfect Pavers of Palm Beach',
  description = 'Premium paver driveways, pool decks, patios and outdoor living across Palm Beach County. State Certified General Contractor, CMHA certified, 35+ years in South Florida.',
  bodyClass = '',
  canonical,
  image,
} = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).href;
---
<!doctype html>
<html lang="en">
<head>
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-VEPMNPCFF3"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-VEPMNPCFF3');
  </script>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  {image && <meta property="og:image" content={image} />}
  <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
  <slot name="head" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
  <script is:inline>
    // Enable scroll-reveal before first paint (skip if user prefers reduced motion)
    if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.documentElement.classList.add('reveal-ready');
    }
  </script>
</head>
<body class={bodyClass}>
  <Header />
  <slot />
  <Footer />

  <button id="toTop" class="to-top" aria-label="Back to top" hidden>↑</button>
  <script is:inline>
    (function () {
      var btn = document.getElementById('toTop');
      if (!btn) return;
      var shown = false;
      btn.hidden = false;
      function onScroll() {
        var should = window.scrollY > 400;
        if (should !== shown) { shown = should; btn.classList.toggle('is-vis', should); }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
      var smooth = !matchMedia('(prefers-reduced-motion: reduce)').matches;
      btn.addEventListener('click', function () {
        window.scrollTo({ top: 0, behavior: smooth ? 'smooth' : 'auto' });
      });
    })();
  </script>

  <!-- GoHighLevel Number Pool: session-based dynamic phone-number tracking (loads on every page) -->
  <script is:inline src="https://backend.leadconnectorhq.com/appengine/loc/6O64IBH8EOdqNTcAlwLR/pool/hqUY5RAYaK7ku7HEoILc/number_pool.js"></script>
  <script is:inline src="https://backend.leadconnectorhq.com/appengine/js/user_session.js"></script>

  <script is:inline>
    (function () {
      if (!document.documentElement.classList.contains('reveal-ready')) return;
      var sels = ['.trust .cell', '.props .card', '.steps .step', '.promise li', '.incl-list li', '.rev-grid > div', '.cities li', '.svc-intro-stats .sis'];
      var items = [];
      sels.forEach(function (sel) {
        var els = document.querySelectorAll(sel);
        var counts = new Map();
        els.forEach(function (el) {
          var p = el.parentElement;
          var i = counts.get(p) || 0;
          counts.set(p, i + 1);
          el.style.transitionDelay = (i * 85) + 'ms';
          items.push(el);
        });
      });
      // Once an item has revealed, drop its stagger delay so hover highlights
      // fire instantly instead of waiting out the reveal delay.
      function clearDelay(el) {
        el.addEventListener('transitionend', function once() {
          el.style.transitionDelay = '0ms';
          el.removeEventListener('transitionend', once);
        });
      }
      if (!('IntersectionObserver' in window)) {
        items.forEach(function (el) { el.classList.add('is-in'); el.style.transitionDelay = '0ms'; });
        return;
      }
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { clearDelay(e.target); e.target.classList.add('is-in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -7% 0px' });
      items.forEach(function (el) { io.observe(el); });
    })();
  </script>
</body>
</html>
