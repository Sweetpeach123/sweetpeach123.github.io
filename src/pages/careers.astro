---
import BaseLayout from '../layouts/BaseLayout.astro';

const roles = [
  { k: 'Field', t: 'Paver & Hardscape Installer', p: 'Build bases, set pavers, run compaction and cutting. Experience helps, but we will train the right person who shows up on time and takes pride in clean work.' },
  { k: 'Field', t: 'Crew Leader / Foreman', p: 'Run a job site from base to final walkthrough, including the daily cleanup and client updates we are known for. For someone who leads by example.' },
  { k: 'Sales', t: 'Estimator / Sales Consultant', p: 'Measure properties, bring samples, and write the honest, all-in estimates that earn a homeowner’s trust. Local knowledge and a straight answer beat a hard sell.' },
  { k: 'Service', t: 'Clean & Seal Technician', p: 'Clean, re-sand, and seal paver surfaces with care. Detail-driven work that turns a one-time job into a customer for life.' },
];

const reasons = [
  { t: 'Year-round work', p: 'In South Florida there is no slow winter season. Our crews stay busy and paid through every month of the year.' },
  { t: 'An established company', p: 'Licensed, ICPI certified, and installing across two counties since 1988 — not a fly-by-night crew that folds after a bad season.' },
  { t: 'Treated like family', p: '“We treat people like family, not like numbers.” That goes for our customers and our team alike.' },
  { t: 'Room to grow', p: 'Several of our leads and estimators started on a crew. Do good work and the path up is real, not a slogan.' },
];
---
<BaseLayout
  title="Careers · Perfect Pavers of Palm Beach"
  description="Join a licensed, ICPI-certified paver company installing across Broward and Palm Beach County since 1988. Year-round work, real team, room to grow. Now hiring installers, crew leaders, estimators and clean & seal technicians.">

  <nav class="crumbs">
    <div class="wrap">
      <a href="/">Home</a> <span>/</span> <a href="/about/why-choose-us">About</a> <span>/</span> <strong>Careers</strong>
    </div>
  </nav>

  <section class="careers-hero">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Careers · South Florida</div>
      <h1>Build work that <em>lasts.</em></h1>
      <p class="lede">We are a small, established team that does pavers the right way and treats people like family. If you take pride in clean, lasting work, we would like to meet you.</p>
    </div>
  </section>

  <section class="block wrap">
    <div class="sec-head">
      <span class="sec-num">Why work here</span>
      <h2>A steady trade, with people worth staying for.</h2>
    </div>
    <div class="props why-grid">
      {reasons.map((r) => (
        <div class="card">
          <h3>{r.t}</h3>
          <p>{r.p}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="block wrap" style="padding-top:0">
    <div class="sec-head">
      <span class="sec-num">Open roles</span>
      <h2>Where we are hiring.</h2>
    </div>
    <div class="roles">
      {roles.map((r) => (
        <article class="role">
          <span class="role-k">{r.k}</span>
          <h3>{r.t}</h3>
          <p>{r.p}</p>
        </article>
      ))}
    </div>
    <p class="roles-note">Don&rsquo;t see your role? We are always glad to hear from skilled, reliable people. Send us a note anyway.</p>
  </section>

  <section class="cta">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">How to apply</div>
      <h2>Tell us about yourself.</h2>
      <p>Email a short note about your experience (a resume is welcome but not required) or give us a call. A real person on our team will get back to you.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a href="mailto:office@perfectpavers.com?subject=Careers%20%E2%80%94%20Application" class="btn btn-brass">Email office@perfectpavers.com</a>
        <a href="tel:+19547791855" class="btn btn-ghost" style="color:var(--ivory)">Call (954) 779-1855</a>
      </div>
    </div>
  </section>

  <style>
    .crumbs{border-bottom:1px solid var(--line);background:var(--ivory)}
    .crumbs .wrap{padding-top:16px;padding-bottom:16px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
    .crumbs a:hover{color:var(--brass-dark)}
    .crumbs span{margin:0 8px;color:var(--brass)}
    .crumbs strong{font-weight:500;color:var(--ink)}

    .careers-hero{background:var(--green);color:var(--ivory);padding:78px 0 66px}
    .careers-hero h1{font-size:62px;color:var(--ivory);margin-top:14px}
    .careers-hero h1 em{font-style:italic;color:var(--brass)}
    .careers-hero .lede{font-weight:300;opacity:.9;max-width:34em;margin-top:18px;font-size:18px}

    .why-grid{grid-template-columns:1fr 1fr}

    .roles{display:grid;grid-template-columns:1fr 1fr;gap:22px}
    .role{border:1px solid var(--line);border-radius:8px;background:var(--ivory);padding:26px 28px}
    .role-k{display:inline-block;font-family:var(--sans);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--brass-dark);margin-bottom:10px}
    .role h3{font-size:22px;margin-bottom:8px}
    .role p{font-size:14.5px;color:var(--muted);font-weight:300;line-height:1.65}
    .roles-note{margin-top:26px;font-size:15px;color:var(--muted);font-weight:300;font-family:var(--serif);font-style:italic}

    @media(max-width:980px){
      .careers-hero{padding:56px 0 48px}
      .careers-hero h1{font-size:42px}
      .roles{grid-template-columns:1fr}
    }
  </style>

</BaseLayout>
