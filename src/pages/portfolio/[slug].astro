---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { v } from '../../lib/asset.ts';

export function getStaticPaths() {
  const projects = {
  'hollywood-residence': {
    city: 'Hollywood',
    surface: 'Ivory Select travertine (French pattern)',
    title: 'Travertine pool deck upgrade',
    service: { href: '/services/pool-decks/', label: 'paver pool deck' },
    hero: '/images/portfolio/hollywood-residence-1.jpg',
    heroAlt: 'Ivory Select travertine pool deck in a French pattern in Hollywood',
    intro: 'Old, worn concrete pavers were removed and replaced with Premium Ivory Select travertine in a French pattern for a cooler, more elegant deck.',
    specs: { Location: 'Hollywood, FL', Surface: 'Ivory Select travertine', Scope: 'Pool deck · walkway transition', Size: '≈ 600 sq ft', Timeline: '5 working days' },
    body: [
      'The new travertine brings a timeless, natural-stone look and stays noticeably cooler underfoot, which is exactly what you want for poolside comfort and everyday barefoot use in the South Florida heat.',
      'The whole project was completed in just five days from start to finish, giving the backyard a fresh, elegant upgrade with minimal disruption to the homeowners.',
    ],
    work: [
      'Lifted and hauled away the existing worn concrete pavers',
      'Prepared and regraded the base for drainage and durability',
      'Installed travertine with a precise French pattern and tight joints',
      'Finished with professional pressure cleaning',
      'Applied a high-quality sealant to enrich color and protect the stone',
    ],
    gallery: [
      { src: '/images/portfolio/hollywood-residence-2.jpg', alt: 'Barefoot-friendly travertine pool deck in Hollywood' },
      { src: '/images/portfolio/hollywood-residence-3.jpg', alt: 'Travertine pool deck detail in Hollywood' },
    ],
  },
  'concrete-paver-and-drain': {
    city: 'Palm Beach Gardens',
    surface: 'Concrete pavers',
    title: 'Concrete paver driveway & drain',
    service: { href: '/services/driveways/', label: 'paver driveway' },
    hero: '/images/portfolio/concrete-paver-and-drain-1.jpg',
    heroAlt: 'Concrete paver driveway with integrated drainage in Palm Beach Gardens',
    intro: 'An old asphalt driveway transformed into a durable, stylish concrete paver driveway with an integrated drainage system in Palm Beach Gardens.',
    specs: { Location: 'Palm Beach Gardens, FL', Surface: 'Concrete pavers', Scope: 'Driveway · drainage system', Size: '≈ 600 sq ft', Timeline: '4–5 working days' },
    body: [
      'We replaced a worn asphalt driveway with a new concrete paver surface, upgrading both the look and the durability of the home’s entrance and boosting curb appeal for this Palm Beach Gardens property.',
      'A dedicated drainage solution was built into the installation to channel water away from the driveway, preventing pooling and edge sinking so the pavers stay level and stable through South Florida’s heavy rains.',
    ],
    work: [
      'Removed and disposed of the old asphalt driveway',
      'Prepared and compacted the base for pavers',
      'Installed concrete driveway pavers',
      'Integrated a drainage system to manage runoff',
      'Set edge restraints and sanded joints to finish',
    ],
    gallery: [
      { src: '/images/portfolio/concrete-paver-and-drain-2.jpg', alt: 'Paver driveway with improved drainage in Palm Beach Gardens' },
      { src: '/images/portfolio/concrete-paver-and-drain-3.jpg', alt: 'Concrete paver driveway detail in Palm Beach Gardens' },
      { src: '/images/portfolio/concrete-paver-and-drain-4.jpg', alt: 'Finished concrete paver driveway in Palm Beach Gardens' },
    ],
  },
  'pool-deck-clean-reseal': {
    city: 'Palm Beach',
    surface: 'Concrete pavers',
    title: 'Driveway clean & seal',
    service: { href: '/services/clean-seal/', label: 'clean & seal' },
    hero: '/images/portfolio/pool-deck-clean-reseal-1.jpg',
    heroAlt: 'Restored concrete paver driveway in Palm Beach',
    intro: 'A concrete paver driveway in Palm Beach brought back to life — pressure cleaned, re-sanded, and sealed to restore color and protection.',
    specs: { Location: 'Palm Beach, FL', Surface: 'Concrete pavers', Scope: 'Driveway · clean · re-sand · seal', Size: '≈ 800 sq ft', Timeline: '2–3 working days' },
    body: [
      'The paver driveway had faded and collected dirt and stains over the years, so we pressure cleaned the entire surface to lift the buildup and bring the original color back through.',
      'We then re-sanded all the joints for a stable, uniform finish and applied a high-quality sealant to enrich the color and protect the pavers against the weather and everyday traffic.',
    ],
    work: [
      'Pressure cleaned the pavers to remove dirt and stains',
      'Cleared built-up debris from the joints',
      'Re-sanded all joints for stability',
      'Applied a high-quality protective sealant',
      'Blocked off the driveway during curing',
    ],
    gallery: [
      { src: '/images/portfolio/pool-deck-clean-reseal-2.jpg', alt: 'Cleaned and sealed paver driveway in Palm Beach' },
      { src: '/images/portfolio/pool-deck-clean-reseal-3.jpg', alt: 'Restored paver driveway detail in Palm Beach' },
    ],
  },
  'miramar-pool-deck-restoration': {
    city: 'Miramar',
    surface: 'Concrete pavers',
    title: 'Pool deck restoration',
    service: { href: '/services/clean-seal/', label: 'clean & seal' },
    hero: '/images/portfolio/miramar-pool-deck-restoration-1.jpg',
    heroAlt: 'Restored concrete paver pool deck with seating area in Miramar',
    intro: 'A worn Miramar pool deck brought back to life — settled pavers lifted and re-leveled, then the surface cleaned and sealed.',
    specs: { Location: 'Miramar, FL', Surface: 'Concrete pavers', Scope: 'Pool deck · re-level · seal', Size: '≈ 650 sq ft', Timeline: '2–3 working days' },
    body: [
      'We refreshed a worn pool deck by lifting and re-leveling settled paver sections, resetting them on a stable base, and re-sanding the joints so the light-gray pavers sat flat and even around the pool again.',
      'The crew then cleaned and sealed the entire surface to lock in color and guard against moisture, while confirming proper grading and slope away from the pool and home to keep drainage working and prevent future base failure.',
    ],
    work: [
      'Lifted and re-leveled settled paver areas',
      'Reset pavers on a stabilized base',
      'Re-sanded and locked the paver joints',
      'Deep cleaned and sealed the deck surface',
      'Verified drainage and slope away from the pool',
    ],
    gallery: [
      { src: '/images/portfolio/miramar-pool-deck-restoration-2.jpg', alt: 'Restored pool deck pavers in Miramar' },
      { src: '/images/portfolio/miramar-pool-deck-restoration-3.jpg', alt: 'Re-leveled paver pool deck in Miramar' },
      { src: '/images/portfolio/miramar-pool-deck-restoration-4.jpg', alt: 'Sealed pool deck surface in Miramar' },
    ],
  },
  'north-lauderdale-residence': {
    city: 'North Lauderdale',
    surface: 'Concrete pavers',
    title: 'Paver driveway restoration',
    service: { href: '/services/clean-seal/', label: 'clean & seal' },
    hero: '/images/portfolio/north-lauderdale-residence-1.jpg',
    heroAlt: 'Curved paver driveway restoration in North Lauderdale',
    intro: 'A curved paver driveway restored through pressure cleaning, re-sanding, and sealing at a North Lauderdale residence.',
    specs: { Location: 'North Lauderdale, FL', Surface: 'Concrete pavers', Scope: 'Driveway · clean · re-sand · seal', Size: '≈ 600 sq ft', Timeline: '2 working days' },
    body: [
      'We started by thoroughly pressure cleaning the pavers to remove the dirt, debris, and stains that had built up on the curved driveway over time, restoring the original color and preparing the joints for the next stage.',
      'Later we returned to re-sand the joints for improved stability and a uniform finish, then applied a high-quality sealant and blocked off all entrances to protect the surface from foot and vehicle traffic during curing.',
    ],
    work: [
      'Pressure cleaned pavers to remove dirt and stains',
      'Removed built-up debris from the surface',
      'Re-sanded joints for stability',
      'Applied a high-quality sealant',
      'Blocked off entrances during curing',
    ],
    gallery: [
      { src: '/images/portfolio/north-lauderdale-residence-2.jpg', alt: 'Re-sanded paver driveway in North Lauderdale' },
      { src: '/images/portfolio/north-lauderdale-residence-3.jpg', alt: 'Paver driveway cleaning in North Lauderdale' },
      { src: '/images/portfolio/north-lauderdale-residence-4.jpg', alt: 'Sealed curved paver driveway in North Lauderdale' },
    ],
  },
};

  return Object.entries(projects).map(([slug, project]) => ({ params: { slug }, props: { project } }));
}

const p = Astro.props.project;
const site = Astro.site;
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', site).href },
    { '@type': 'ListItem', position: 2, name: 'Portfolio', item: new URL('/portfolio/', site).href },
    { '@type': 'ListItem', position: 3, name: p.title, item: new URL(Astro.url.pathname, site).href },
  ],
};
---
<BaseLayout
  title={`${p.title} · ${p.city} · Perfect Pavers`}
  description={p.intro ?? `A Perfect Pavers project in ${p.city}, Palm Beach County — coming soon.`}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbLd)} />

  <nav class="crumbs">
    <div class="wrap">
      <a href="/">Home</a> <span>/</span> <a href="/portfolio/">Portfolio</a> <span>/</span> <strong>{p.city}</strong>
    </div>
  </nav>

  {p.soon ? (
    <section class="block wrap proj-soon">
      <div class="proj-meta">{p.city} · Palm Beach County</div>
      <h1>{p.title}</h1>
      <p class="soon-tag">Project coming soon</p>
      <p class="soon-copy">We&rsquo;re putting this {p.city} project together right now &mdash; full photos and the story behind it are on the way. In the meantime, we&rsquo;d be glad to walk your property and talk through something similar.</p>
      <div class="soon-cta">
        <a href="/service-areas/" class="btn btn-ghost">Back to service areas</a>
        <a href="/contact/" class="btn btn-brass">Request a visit</a>
      </div>
    </section>
  ) : (
  <Fragment>
  <section class="block wrap proj-head">
    <div class="proj-meta">{p.city} &middot; {p.surface}</div>
    <h1>{p.title}</h1>
    <p class="lede">{p.intro}</p>
  </section>

  <section class="wrap proj-strip" style={`--cols:${1 + (p.gallery?.length ?? 0)}`}>
    {[{ src: p.hero, alt: p.heroAlt }, ...(p.gallery ?? [])].map((g) => (
      <button class="sph" type="button" aria-label={`Enlarge photo: ${g.alt}`}><img src={v(g.src)} alt={g.alt} loading="lazy" decoding="async" /></button>
    ))}
  </section>

  <div class="lbox" id="lbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Project photo viewer">
    <button class="lbox-close" type="button" aria-label="Close">&times;</button>
    <button class="lbox-nav lbox-prev" type="button" aria-label="Previous photo">&#8249;</button>
    <img class="lbox-img" id="lbox-img" src="" alt="" />
    <button class="lbox-nav lbox-next" type="button" aria-label="Next photo">&#8250;</button>
  </div>

  <section class="block wrap proj-grid">
    <div class="proj-body">
      <div class="sec-head"><span class="sec-num">The project</span><h2>What we built.</h2></div>
      {p.body.map((para) => <p>{para}</p>)}

      <h3 class="work-h">Scope of work</h3>
      <ul class="work-list">{p.work.map((w) => <li>{w}</li>)}</ul>
      {p.service && <p class="proj-service">This was a <a href={p.service.href}>{p.service.label}</a> project &mdash; see how we approach it.</p>}
    </div>

    <aside class="proj-specs">
      <dl>
        {Object.entries(p.specs).map(([k, v]) => (
          <div class="spec-row"><dt>{k}</dt><dd>{v}</dd></div>
        ))}
      </dl>
      <a href="/contact/" class="btn btn-brass spec-cta">Start a project like this</a>
    </aside>
  </section>

  <section class="cta">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Your free on-site visit</div>
      <h2>Want something like this in {p.city}?</h2>
      <p>Tell us the surface, the size, and your timeline. We&rsquo;ll be at your door within a day or two, no charge, no pressure.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a href="/contact/" class="btn btn-brass">Request a visit</a>
        <a href="tel:+19547791855" class="btn btn-ghost" style="color:var(--ivory)">Call (954) 779-1855</a>
      </div>
    </div>
  </section>
  </Fragment>
  )}

  <style>
    .crumbs{border-bottom:1px solid var(--line);background:var(--ivory)}
    .crumbs .wrap{padding-top:16px;padding-bottom:16px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
    .crumbs a:hover{color:var(--brass-dark)}
    .crumbs span{margin:0 8px;color:var(--brass)}
    .crumbs strong{font-weight:500;color:var(--ink)}

    .proj-head{padding-bottom:30px}
    .proj-meta{font-family:var(--sans);font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--brass-dark);margin-bottom:14px}
    .proj-head h1{font-size:clamp(36px,4.4vw,56px);line-height:1.05;letter-spacing:-.01em;margin:0}
    .proj-head .lede{font-family:var(--serif);font-size:clamp(19px,1.9vw,23px);line-height:1.5;font-weight:400;color:var(--ink);max-width:34em;margin:20px 0 0}

    .proj-strip{display:grid;grid-template-columns:repeat(var(--cols,4),minmax(0,148px));justify-content:center;gap:12px;max-width:none}
    .sph{border-radius:8px;overflow:hidden;height:112px;background:var(--ivory-2);padding:0;border:none;width:100%;cursor:zoom-in;font:inherit}
    .sph img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s cubic-bezier(.16,1,.3,1)}
    .sph:hover img,.sph:focus-visible img{transform:scale(1.06)}
    .sph:focus-visible{outline:2px solid var(--brass);outline-offset:2px}

    .lbox{position:fixed;inset:0;z-index:1000;display:none;align-items:center;justify-content:center;background:rgba(20,18,15,.93);padding:24px}
    .lbox.open{display:flex}
    .lbox-img{max-width:92vw;max-height:88vh;object-fit:contain;border-radius:6px;box-shadow:0 24px 70px rgba(0,0,0,.55)}
    .lbox-close{position:absolute;top:16px;right:22px;background:none;border:none;color:#fff;font-size:42px;line-height:1;cursor:pointer;opacity:.85}
    .lbox-close:hover{opacity:1}
    .lbox-nav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(255,255,255,.13);border:none;color:#fff;font-size:30px;width:52px;height:52px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;opacity:.9}
    .lbox-nav:hover{background:rgba(255,255,255,.26);opacity:1}
    .lbox-prev{left:20px}
    .lbox-next{right:20px}
    @media(max-width:600px){.lbox-nav{width:44px;height:44px;font-size:24px}.lbox-prev{left:10px}.lbox-next{right:10px}}

    .proj-grid{display:grid;grid-template-columns:1.5fr .9fr;gap:54px;align-items:start}
    .proj-body p{font-size:16.5px;color:var(--muted);font-weight:300;line-height:1.75;margin-top:16px}
    .work-h{font-size:20px;margin:30px 0 14px}
    .work-list{list-style:none;display:grid;gap:11px}
    .work-list li{position:relative;padding-left:24px;font-size:15.5px;color:var(--ink);font-weight:300;line-height:1.55}
    .work-list li::before{content:'✦';position:absolute;left:0;top:1px;color:var(--brass);font-size:12px}
    .proj-service{margin-top:24px;font-size:16px;color:var(--muted);font-weight:300}
    .proj-service a{color:var(--brass-dark);text-decoration:underline;text-underline-offset:3px}
    .proj-service a:hover{color:var(--green)}

    .proj-specs{position:sticky;top:108px;background:var(--ivory-2);border:1px solid var(--line);border-radius:10px;padding:26px 28px}
    .proj-specs dl{margin:0}
    .spec-row{display:flex;justify-content:space-between;gap:16px;padding:13px 0;border-bottom:1px solid var(--line)}
    .spec-row:last-of-type{border-bottom:none}
    .spec-row dt{font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);flex:0 0 auto}
    .spec-row dd{font-size:14.5px;color:var(--ink);text-align:right;font-weight:400}
    .spec-cta{margin-top:20px;width:100%;text-align:center}

    .proj-gallery{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;padding-top:0;max-width:720px;margin:0 auto}
    .gphoto{position:relative;display:block;border-radius:10px;overflow:hidden;height:220px}
    .gphoto img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .7s cubic-bezier(.16,1,.3,1)}
    .gphoto::after{display:none}
    .gphoto:hover img{transform:scale(1.05)}
    .gcap{position:absolute;left:0;right:0;bottom:0;display:flex;align-items:center;justify-content:space-between;gap:12px;padding:32px 22px 16px;font-family:var(--sans);font-size:13px;letter-spacing:.06em;color:var(--ivory);background:linear-gradient(to top,rgba(20,25,21,.78),rgba(20,25,21,0))}
    .garr{transition:transform .4s cubic-bezier(.16,1,.3,1)}
    .gphoto:hover .garr{transform:translateX(5px)}

    /* Coming soon */
    .proj-soon{padding-top:64px;padding-bottom:96px;text-align:center;max-width:none}
    .proj-soon .proj-meta{margin-bottom:16px}
    .proj-soon h1{font-size:clamp(34px,4vw,52px);line-height:1.06;margin:0}
    .soon-tag{display:inline-block;margin:22px 0 0;padding:7px 16px;border:1px solid var(--brass);border-radius:999px;font-family:var(--sans);font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--brass-dark)}
    .soon-copy{max-width:40em;margin:24px auto 0;font-size:17px;color:var(--muted);font-weight:300;line-height:1.7}
    .soon-cta{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-top:34px}

    @media(max-width:1024px){
      .proj-grid{grid-template-columns:1fr;gap:34px}
      .proj-specs{position:static}
    }
    @media(max-width:600px){
      .proj-grid{gap:26px}
      .proj-specs{padding:22px 18px}
      .proj-body p{font-size:15.5px}
      .proj-strip{gap:8px}
      .sph{height:74px}
      .proj-soon{padding-top:46px;padding-bottom:64px}
    }
  </style>

  <script>
    const strip = document.querySelector('.proj-strip');
    const box = document.getElementById('lbox');
    if (strip && box) {
      const items = [...strip.querySelectorAll('.sph img')];
      const bimg = document.getElementById('lbox-img');
      let idx = 0;
      const show = () => { const im = items[idx]; bimg.src = im.currentSrc || im.src; bimg.alt = im.alt; };
      const open = (i) => { idx = i; show(); box.classList.add('open'); box.setAttribute('aria-hidden', 'false'); document.body.style.overflow = 'hidden'; };
      const close = () => { box.classList.remove('open'); box.setAttribute('aria-hidden', 'true'); document.body.style.overflow = ''; };
      const step = (d) => { idx = (idx + d + items.length) % items.length; show(); };
      items.forEach((im, i) => im.parentElement.addEventListener('click', () => open(i)));
      box.querySelector('.lbox-close').addEventListener('click', close);
      box.querySelector('.lbox-prev').addEventListener('click', (e) => { e.stopPropagation(); step(-1); });
      box.querySelector('.lbox-next').addEventListener('click', (e) => { e.stopPropagation(); step(1); });
      box.addEventListener('click', (e) => { if (e.target === box) close(); });
      document.addEventListener('keydown', (e) => {
        if (!box.classList.contains('open')) return;
        if (e.key === 'Escape') close();
        else if (e.key === 'ArrowLeft') step(-1);
        else if (e.key === 'ArrowRight') step(1);
      });
    }
  </script>

</BaseLayout>
