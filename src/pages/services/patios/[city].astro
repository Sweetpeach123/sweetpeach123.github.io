---
import LocalServiceTemplate from '../../../components/LocalServiceTemplate.astro';
import { CITIES, type City } from '../../../data/cities';

export function getStaticPaths() {
  return CITIES.map((city) => ({ params: { city: city.slug }, props: { city } }));
}

const { city } = Astro.props as { city: City };

const SERVICE = { name: 'Paver patios', label: 'Patios', slug: 'patios' };

const SERVICES = [
  { label: 'Driveways', slug: 'driveways' },
  { label: 'Walkways', slug: 'walkways' },
  { label: 'Patios', slug: 'patios' },
  { label: 'Pool decks', slug: 'pool-decks' },
  { label: 'Outdoor living', slug: 'outdoor-living' },
  { label: 'Retaining & seating walls', slug: 'retaining-seating-walls' },
  { label: 'Natural stone', slug: 'natural-stone' },
  { label: 'Clean & seal', slug: 'clean-seal' },
];
const CITY_CHIPS = CITIES.map((c) => ({ label: c.name, slug: c.slug }));

// ---- Per-city patio copy (uniquely written off each city's real differentiators) ----
interface Local { lede: string; intro: string[]; localNote: string; faqs: { q: string; a: string }[]; }
const LOCAL: Record<string, Local> = {
  'boca-raton': {
    lede: 'In East Boca the back yard is where the house lives — but the coastal salt and summer storms wear on an old slab, and a paver patio takes both far better.',
    intro: [
      'Boca Raton is one of South Florida\'s most established communities, and the back patios on those 1970s–90s homes through East Boca, the Boca Islands and Old Floresta are usually a cracked concrete slab or a small pad that was never built for entertaining. We remove the failing slab, build a proper compacted base, and lay a paver patio sized for the way you actually use the yard — dining, lounging and the grill.',
      'This close to the ocean and the canals, salt air and afternoon downpours are relentless. We favor travertine and cool-toned pavers that stay comfortable underfoot in the summer heat, and we grade the surface so storm water runs away from the house and the slab foundation instead of pooling at the back door.',
      'Whether you are on a non-HOA street in East Boca or inside a gated club like Royal Palm Yacht & Country Club, we handle the paperwork — the City of Boca Raton permit, the drainage slope, and the architectural review submittal for the clubs that require it.',
    ],
    localNote: "Canal-front and ocean-side lots in Boca often carry drainage requirements and a low door threshold — we set the patio slope so heavy rain runs to the yard or swale, never back toward the foundation.",
    faqs: [
      { q: 'Will a paver patio get too hot to walk on in the Boca summer?', a: 'Not if the material is chosen for it. Travertine and lighter cool-toned pavers reflect heat and stay comfortable underfoot even in July, which is why we lean toward them for back patios this close to the coast.' },
      { q: 'My old concrete patio is cracked and stains — can you build over it?', a: 'Laying pavers over a failing slab just moves the problem. We remove the concrete, build a fresh compacted base, and set the patio to drain away from the house, so you get a surface that outlasts the old slab by decades.' },
      { q: 'Do you work inside the gated communities in Boca Raton?', a: 'Yes. We regularly prepare the architectural review board package for gated clubs like Royal Palm Yacht & Country Club, then pull the City of Boca Raton permit once the community signs off.' },
      { q: 'What does a paver patio cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  jupiter: {
    lede: "Jupiter's waterfront and golf homes were built for outdoor living, and a paver patio that ties the lanai to the pool is where that yard finally comes together — the ARB approval is on us.",
    intro: [
      "From Admirals Cove to the Loxahatchee Club, most of Jupiter's target homes are 1990s–2000s builds inside gated golf and waterfront communities, and the back yard is the whole point of living here. The original patios are dated rather than destroyed, so the job is as much about the look — matching the community palette and connecting the lanai, the pool deck and an outdoor kitchen into one space — as it is about the base.",
      'The catch in Jupiter is the architectural review board. Nearly every community here has one, and it decides the color, pattern and border you are allowed on a patio. We prepare the ARB submittal with the paver spec and drawings so it clears the first time, then pull the Town of Jupiter permit.',
      'On the water — the Intracoastal, the inlet, the canals — salt and screen-enclosure footers both matter. We build the base and the lanai tie-ins so the enclosure sits solid, and we seal for the salt so the patio holds its color season after season.',
    ],
    localNote: 'Most Jupiter patios run through a community architectural review board before the Town permit — we manage both, and set the footers and grading to the community rules and any screen-enclosure requirements.',
    faqs: [
      { q: 'Will you handle the architectural review board approval for my Jupiter patio?', a: 'Yes — that is a standard part of the job here. We prepare the ARB package (paver color, pattern, border and drawings), get the community sign-off, and only then order material and pull the Town of Jupiter permit.' },
      { q: 'Can you tie the patio into my screen enclosure and pool deck?', a: 'That is a common Jupiter project. We build the footers for a lanai or screen enclosure, connect the patio to the pool deck in one continuous surface, and match the paver to the community palette so it reads as one designed space.' },
      { q: 'Can you match the paver style my community requires?', a: 'We build to the community approved palette. Bring us the guidelines or the ARB requirements and we spec a patio that meets them while still looking custom to your home.' },
      { q: 'What does a paver patio cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  'palm-beach-gardens': {
    lede: "PGA National, BallenIsles, Frenchman's Creek — the Gardens' golf homes have the yards, and a paver patio built to the community palette turns the back of the house into the entertaining space it was meant to be.",
    intro: [
      "Palm Beach Gardens grew up around golf — PGA National, BallenIsles, Frenchman's Creek, Mirasol — and those 1990s–2000s homes have reached the age where the back patio looks tired next to the yard around it. A new paver patio, laid to expand the entertaining space and connect to the pool, is the single biggest lift you can give the back of a Gardens home.",
      'The design guidelines here are strict. Communities in the Gardens often dictate the color family and the pattern to keep the streetscape and the golf-course views consistent, so the work is picking a paver that satisfies the committee and still sets your yard apart. We build that into the plan from the start.',
      'Under the surface it is the same discipline every time — proper excavation, a compacted rock base for the sandy soil, edge restraints and a slope that carries water away from the house. We pull the City of Palm Beach Gardens permit and prepare the community submittal.',
    ],
    localNote: 'Gardens golf communities typically require design-committee approval on patio color and pattern before work starts — we prepare that submittal alongside the City permit and grade drainage away from the slab.',
    faqs: [
      { q: 'Does my Palm Beach Gardens community have to approve the patio?', a: 'Almost certainly yes — communities like PGA National and BallenIsles run design committees that approve color and pattern. We prepare and submit that package for you, then pull the City permit once it clears.' },
      { q: 'Can you expand my small existing patio into a real entertaining space?', a: 'Yes. Expanding a builder-grade slab into a larger patio that connects to the pool and an outdoor kitchen is one of the most common Gardens projects — we tie the new work into the grading so the whole surface drains as one.' },
      { q: 'Our community pavers are faded and uneven — replace or reset?', a: 'If the base is sound we can lift, re-level and reseal; if the base has failed or the field has settled unevenly, a rebuild is the lasting fix. We tell you honestly which one your patio needs at the on-site visit.' },
      { q: 'What does a paver patio cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  wellington: {
    lede: "Out in Wellington's equestrian estates the back yards are large, and a paver patio is really an outdoor room — big enough to entertain, graded across the acreage, built to last.",
    intro: [
      'Wellington is a different kind of patio job. Out on the acreage of Palm Beach Point, the Aero Club and Grand Prix Village, the back yards are large and the patio is an outdoor entertaining room — a wide surface for dining and lounging that often steps out to a pool and an outdoor kitchen. The scale is the opportunity, and it is where a paver patio pulls furthest ahead of a poured slab that would crack across a run that size.',
      'We build these to hold their line over a large footprint. That means proper excavation, a compacted rock base and edge restraints across the whole area, so a big patio stays flat and level instead of settling in the middle the way a wide slab does. On acreage we also plan the drainage over a much larger area so summer rain never pools by the house.',
      'The equestrian villages have their own rules while much of the acreage is non-HOA, so we confirm which applies before we design. Either way we pull the Village of Wellington permit and grade the full run.',
    ],
    localNote: 'Estate patios cover a large footprint — we build a full compacted base with edge restraints so a wide surface stays flat, and grade drainage across the acreage away from the house.',
    faqs: [
      { q: 'Can you build a large entertaining patio on an estate lot?', a: 'That is a big part of what we do in Wellington. A wide patio that connects to a pool and outdoor kitchen is where pavers really shine — we build the base and edge restraints across the whole footprint so a large surface stays flat instead of settling like a poured slab.' },
      { q: 'Will a big paver patio settle unevenly over time?', a: 'Not when the base is built for the size. We excavate and compact the full area and set edge restraints around the whole field, so the patio holds its line — and any single piece that ever moves can be lifted and reset with no visible patch.' },
      { q: 'Is there an approval step in my Wellington neighborhood?', a: 'It depends on your street — much of the acreage is non-HOA, while the equestrian villages have their own rules. We confirm which applies before we design, then pull the Village of Wellington permit either way.' },
      { q: 'What does a paver patio cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  'west-palm-beach': {
    lede: 'In El Cid, SoSo and Flamingo Park the homes date to the 1920s–40s, and a courtyard-style paver patio has to suit the period, not fight it.',
    intro: [
      "West Palm Beach's target streets — El Cid, SoSo, Flamingo Park, Prospect Park — are historic, with Spanish and Mediterranean homes from the 1920s through the 40s. A back patio here has to suit the architecture: clay brick and warm-toned pavers laid in a classic pattern read right in a courtyard setting where a plain gray slab looks out of place.",
      'Several of these neighborhoods sit in city historic districts, so the design should stay in step with the period. There is no HOA to answer to, but there is a look worth protecting — we help you pick a paver and pattern that turns the back yard into a courtyard that lifts the home rather than modernizing away its character.',
      'The lots are older and often smaller, and the mature trees and original grading make the base work matter. We excavate around the roots, build a proper compacted base, set the slope away from the house, and pull the City of West Palm Beach permit.',
    ],
    localNote: 'Older in-town lots have mature tree roots and original grading to work around, and some streets fall in a historic district — we design the patio to the period and build the base to handle the roots and settling.',
    faqs: [
      { q: 'What paver suits a historic El Cid or Flamingo Park courtyard?', a: 'Clay brick and warm-toned pavers in a herringbone or running-bond pattern read true to the 1920s–40s architecture. We help you choose a finish that turns the back yard into a courtyard that looks original to the house rather than bolted on.' },
      { q: "Is there an approval process in West Palm Beach's historic neighborhoods?", a: 'There is no HOA, but some streets are in a city historic district where exterior changes are reviewed. We keep the design period-appropriate, pull the City of West Palm Beach permit, and handle any historic-district paperwork that applies.' },
      { q: 'Can you build a patio around the mature trees in my yard?', a: 'Yes. Older in-town lots come with established roots, so we plan the excavation and the base to work around them and set the drainage away from the house — the patio stays stable and the trees stay healthy.' },
      { q: 'What does a paver patio cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  'delray-beach': {
    lede: 'Around Lake Ida and the beach the homes are older and the salt air is constant — a sealed paver patio, graded away from the house, takes the coast better than concrete ever will.',
    intro: [
      "Delray's strength is the east side — Lake Ida, the beach district, Del-Ida Park — where established homes sit close to the water and the back yard is where you actually live. Many of these patios are original to homes from the 1950s through 80s: small, cracked and well past their life for the way people entertain outdoors today.",
      'This close to the ocean, salt and heavy summer rain wear a patio down fast. Concrete stains and spalls; a sealed paver patio in travertine or a cool-toned finish shrugs off the salt, stays comfortable underfoot in the heat, and can be rinsed and resealed to look new. We grade the surface so summer downpours run to the yard, away from older homes with low thresholds.',
      'The good news on the east side is simplicity — most of these streets are non-HOA, so approval is usually just the city permit. We pull the City of Delray Beach permit, build the base for the sandy coastal soil, and grade the drainage away from the home.',
    ],
    localNote: 'Coastal east-side lots deal with salt and high summer rain — we seal for the salt, favor cool-underfoot travertine, and build the slope to move heavy rain to the yard, away from older homes with low thresholds.',
    faqs: [
      { q: 'Does salt air near the Delray beach hurt a paver patio?', a: 'Far less than it hurts concrete. We seal the pavers so salt and storm runoff bead off, and because the surface is individual units, any piece that ever weathers or settles near the water can be lifted and reset — no visible patch.' },
      { q: 'Will the patio stay cool enough to use in the summer?', a: 'That is what travertine and cool-toned pavers are for. They reflect heat and stay comfortable underfoot even in the peak of a Delray summer, which is why we favor them for coastal back patios.' },
      { q: "I'm on a non-HOA street near Lake Ida — what approval do I need?", a: 'Usually just the city permit. Most of the Lake Ida and beach-district streets have no HOA, so we simply pull the City of Delray Beach permit, handle the drainage requirement if one applies, and get to work.' },
      { q: 'What does a paver patio cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  'boynton-beach': {
    lede: "Along the Intracoastal and Boynton's eastern streets, back patios sit on damp ground and take the salt — a sealed paver patio, built for the water table, handles both.",
    intro: [
      "Boynton Beach's best hardscape work is on the water and to the east — the Intracoastal waterfront, Harbor Estates, Chapel Hill, Lake Eden. Many of these homes are 1960s–90s builds whose original back patios have cracked and settled, and they are ready to become a real space for entertaining by the water.",
      'Near the Intracoastal, salt and a high water table both work against a slab. We build the base for ground that stays damp, seal the pavers against the salt, and set the drainage so summer downpours run to the yard instead of pooling by the back door or the seawall.',
      'Boynton is a mix — some waterfront pockets are non-HOA, some newer streets run an HOA. We confirm which applies to you, prepare the HOA submittal if there is one, and pull the City of Boynton Beach permit either way.',
    ],
    localNote: 'Waterfront lots near the Intracoastal sit on a higher water table — we build the base for damp ground, seal against salt, and grade the patio so heavy rain drains to the yard, away from the home and the seawall.',
    faqs: [
      { q: 'My Boynton home backs onto the Intracoastal — does the water table matter for a patio?', a: 'It does. A high water table near the water makes a solid, well-compacted base essential, which is exactly what we build. Pavers over that base handle the damp ground and let you reset any section that ever settles by the seawall.' },
      { q: 'Can you build the patio to drain away from the seawall and the house?', a: 'Yes — grading is the heart of a waterfront patio. We set the slope so summer downpours run to the yard rather than pooling at the back door or draining toward the seawall, and we seal the pavers against the salt.' },
      { q: 'Is there an HOA approval step in Boynton Beach?', a: 'It depends on your street — waterfront pockets are often non-HOA, while newer communities have one. We check first, prepare the HOA package if it is needed, and pull the City of Boynton Beach permit regardless.' },
      { q: 'What does a paver patio cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
};

const local = LOCAL[city.slug];
const permit = city.permitAuthority.replace('the ', '').replace(/^./, (m) => m.toUpperCase());
const handles = [
  `A compacted rock base built for ${city.name}'s sandy soil, with the patio graded to drain away from the house and slab`,
  city.hoa === 'none'
    ? 'Any city or historic-district review kept period-appropriate'
    : city.hoa === 'hoa'
    ? 'Your HOA / architectural review board submittal prepared and shepherded through'
    : 'HOA or non-HOA — we confirm your street and handle whichever applies',
  `${permit} permit pulled, with drainage, slope and any screen-enclosure footers built to local code`,
];

const data = {
  seoTitle: `Paver Patios in ${city.name}, FL · Perfect Pavers of Palm Beach`,
  seoDescription: `Paver patios in ${city.name} — cool travertine, drainage graded off the house, screen-enclosure footers. ${permit} permit and ${city.hoa === 'none' ? 'district' : 'HOA/ARB'} approval handled. Free on-site visit.`,
  service: SERVICE,
  city,
  lede: local.lede,
  intro: local.intro,
  localNote: local.localNote,
  handles,
  faqs: local.faqs,
  heroImg: '/images/local-hero-patios.jpg',
  heroAlt: `Paver patio in ${city.name}, Palm Beach County`,
  heroBg: '/images/local-hero-patios.jpg',
  services: SERVICES,
  cities: CITY_CHIPS,
};
---
<LocalServiceTemplate {...data} />
