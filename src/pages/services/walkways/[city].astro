---
import LocalServiceTemplate from '../../../components/LocalServiceTemplate.astro';
import { CITIES, type City } from '../../../data/cities';

export function getStaticPaths() {
  return CITIES.map((city) => ({ params: { city: city.slug }, props: { city } }));
}

const { city } = Astro.props as { city: City };

const SERVICE = { name: 'Paver walkways', label: 'Walkways', slug: 'walkways' };

const SERVICES = [
  { label: 'Driveways', slug: 'driveways' },
  { label: 'Walkways', slug: 'walkways' },
  { label: 'Patios', slug: 'patios' },
  { label: 'Pool decks', slug: 'pool-decks' },
  { label: 'Outdoor living', slug: 'outdoor-living' },
  { label: 'Retaining & seating walls', slug: 'retaining-seating-walls' },
  { label: 'Natural stone', slug: 'natural-stone' },
  { label: 'Clean & seal', slug: 'clean-seal' },
];
const CITY_CHIPS = CITIES.map((c) => ({ label: c.name, slug: c.slug }));

// ---- Per-city walkway copy (uniquely written off each city's real differentiators) ----
interface Local { lede: string; intro: string[]; localNote: string; faqs: { q: string; a: string }[]; }
const LOCAL: Record<string, Local> = {
  'boca-raton': {
    lede: 'In East Boca, the front walk was poured with the house in the 1970s or 80s, and four decades of roots and settling later it is cracked, uneven and ready for pavers.',
    intro: [
      'Boca Raton is one of South Florida\'s most established communities, and through East Boca, the Boca Islands and Old Floresta most homes date to the 1970s through 90s. The entry walks that came with those houses have heaved where mature tree roots pushed under them and cracked where the ground settled — the kind of lip that catches a toe. We remove the old path, build a proper compacted base, and lay a paver walkway that stays even and trip-safe.',
      'This close to the ocean and the canals, salt air is hard on a walk. Sealed pavers shrug off the salt and the afternoon storms, and if a section ever settles near a tree or the seawall we lift and reset those units rather than patching a slab you can never hide. We can also match the new front walk to your driveway or entry so the whole approach reads as one design.',
      'Whether you are on a non-HOA street in East Boca or inside a gated club like Royal Palm Yacht & Country Club, we handle the paperwork — the City of Boca Raton permit, the drainage detail, and the architectural review submittal for the clubs that require it.',
    ],
    localNote: "Boca's older lots have big shade trees whose roots heave a path over time — we cut and prepare the base to run the walkway around them and set a slope so water sheds off the surface instead of pooling.",
    faqs: [
      { q: 'My front walk buckled over a tree root — can you fix it for good?', a: 'Yes. We remove the heaved section, address the root and rebuild a compacted base so the walkway sits flat and stays that way. Because a paver walk is individual units, any spot that ever moves can be lifted and reset with no visible patch.' },
      { q: 'Can you match my new walkway to the driveway in Boca?', a: 'That is a common request here. We spec the walkway in the same paver family, color and pattern as your driveway or entry so the front of the house reads as one continuous design rather than mismatched pieces.' },
      { q: 'Do you work inside the gated communities in Boca Raton?', a: 'Yes. We prepare the architectural review board package for gated clubs like Royal Palm Yacht & Country Club, then pull the City of Boca Raton permit once the community signs off.' },
      { q: 'What does a paver walkway cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  jupiter: {
    lede: "Jupiter's waterfront and golf homes went up in the 1990s and 2000s, and the front walk and garden paths sit inside a community with its own approval board — we take that off your plate.",
    intro: [
      "From Admirals Cove to the Loxahatchee Club, most of Jupiter's target homes are 1990s–2000s builds inside gated golf and waterfront communities. The entry walks are dated rather than destroyed, so the job here is as much about the look — matching the community palette and lifting curb appeal at the front door — as it is about the base.",
      'The catch in Jupiter is the architectural review board. Nearly every community here has one, and it decides the color, pattern and border you are allowed on a walkway just as it does on a driveway. We prepare the ARB submittal with the paver spec and drawings so it clears the first time, then pull the Town of Jupiter permit.',
      'On the water — the Intracoastal, the inlet, the canals — salt is relentless, so we seal the walk to hold its color and set a border that reads clean against the lawn. Travertine and warm-toned pavers in a classic pattern take a garden path and entry from builder-plain to custom, and light borders well for path lighting at night.',
    ],
    localNote: 'Most Jupiter walkways run through a community architectural review board before the Town permit — we manage both, keep the color and pattern inside the approved palette, and set the border to suit path lighting.',
    faqs: [
      { q: 'Will you handle the architectural review board approval for a walkway in my Jupiter community?', a: 'Yes — that is a standard part of the job here. We prepare the ARB package (paver color, pattern, border and drawings), get the community sign-off, and only then order material and pull the Town of Jupiter permit.' },
      { q: 'Can you match the paver style my community requires?', a: 'We build to the community approved palette. Bring us the guidelines or the ARB requirements and we spec an entry walk and garden path that meet them while still looking custom to your home.' },
      { q: 'Can the walkway be set up for path lighting?', a: 'Yes. We lay a defined border and can coordinate the layout so low-voltage path lights sit cleanly along the edge, which reads especially well on the longer garden paths in the golf and waterfront communities here.' },
      { q: 'What does a paver walkway cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  'palm-beach-gardens': {
    lede: "PGA National, BallenIsles, Frenchman's Creek — the Gardens' golf communities are old enough now that the front walk and garden paths are ready for a redo.",
    intro: [
      "Palm Beach Gardens grew up around golf — PGA National, BallenIsles, Frenchman's Creek, Mirasol — and those 1990s–2000s homes have reached the age where the pavers or concrete of the front walk look tired. A fresh paver walkway is a fast, high-impact lift at the front door in a community where every house is judged against its neighbor.",
      'The design guidelines here are strict. Communities in the Gardens often dictate the color family and the pattern to keep the streetscape consistent, so the work is picking a paver that satisfies the committee and still sets your entry apart. We build that into the plan from the start and tie the walk into your driveway or entry so it all matches.',
      'Under the surface it is the same discipline every time — proper excavation, a compacted rock base for the sandy soil, edge restraints so the path holds its line, and a slope that carries water off the surface. We pull the City of Palm Beach Gardens permit and prepare the community submittal.',
    ],
    localNote: 'Gardens golf communities typically require design-committee approval on color and pattern before work starts — we prepare that submittal alongside the City permit and match the walkway to your existing driveway or entry.',
    faqs: [
      { q: 'Does my Palm Beach Gardens community have to approve the walkway?', a: 'Almost certainly yes — communities like PGA National and BallenIsles run design committees that approve color and pattern on hardscape. We prepare and submit that package for you, then pull the City permit once it clears.' },
      { q: 'Can you match the walkway to the driveway we already have?', a: 'Yes, and it is the right call in a design-controlled community. We spec the walkway in the same paver family and pattern so the driveway, entry and front walk read as one coordinated approach.' },
      { q: 'Our community walkway pavers are faded and uneven — replace or reset?', a: 'If the base is sound we can lift, re-level and reseal; if the base has failed or the path has settled unevenly, a rebuild is the lasting fix. We tell you honestly which one your walkway needs at the on-site visit.' },
      { q: 'What does a paver walkway cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  wellington: {
    lede: "Out in Wellington's equestrian estates the approaches are long — a walkway can run from a circular drive to the front door, or thread a garden path across acreage.",
    intro: [
      'Wellington is a different kind of walkway job. Out on the acreage of Palm Beach Point, the Aero Club and Grand Prix Village, the front walk often runs a real distance — from a circular drive up to the entry, or as a garden path linking the house to a barn, ring or guest area. Scale is the whole point, and a paver walk carries it in a way a poured strip cannot.',
      'On an estate lot the base and the grading matter over a much larger area. We excavate and compact a proper base so the long run stays flat, set edge restraints so the path holds its line across the lawn, and grade the drainage so water sheds off rather than pooling along the walk. Natural stone and travertine in a classic pattern suit these longer approaches.',
      'A generous paver walkway is a statement on an estate, and it is where the look pulls furthest ahead of plain concrete. We confirm whether your equestrian village has its own rules, prepare that submittal if it does, and pull the Village of Wellington permit before we grade the run.',
    ],
    localNote: 'Estate walkways run long across acreage — we build a base and edge restraints that keep a lengthy path flat and true, and grade drainage across the full run so water sheds off instead of pooling.',
    faqs: [
      { q: 'Can you build a long walkway from the circular drive to the front door?', a: 'That is a big part of what we do in Wellington. Long approaches and garden paths are where a paver walkway really shines — we compact the base along the whole run and set edge restraints so a lengthy path stays flat and holds its line.' },
      { q: 'Do I need equestrian-village approval for a walkway here?', a: 'It depends on your neighborhood — much of Wellington is non-HOA acreage, but the equestrian villages have their own rules. We confirm first, prepare that submittal if one is needed, and pull the Village of Wellington permit either way.' },
      { q: 'Will pavers stay even over a long garden path?', a: 'Yes, when the base is done right. We compact a proper base and lock the edges so the run does not spread or heave, and because a paver walk is individual units, any spot that ever settles can be lifted and reset with no visible patch.' },
      { q: 'What does a paver walkway cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  'west-palm-beach': {
    lede: 'In El Cid, SoSo and Flamingo Park the homes date to the 1920s–40s — the front walk should fit the period, not fight it.',
    intro: [
      "West Palm Beach's target streets — El Cid, SoSo, Flamingo Park, Prospect Park — are historic, with Spanish and Mediterranean homes from the 1920s through the 40s. A front walk here has to suit the architecture: clay brick and warm-toned pavers laid in a herringbone or running-bond pattern read right at the entry where a plain gray path looks out of place.",
      'Several of these neighborhoods sit in city historic districts, so the design should stay in step with the period. There is no HOA to answer to, but there is a look worth protecting — we help you pick a paver and pattern for the entry walk and garden paths that lift a historic home rather than modernizing away its character.',
      'The lots are older and often narrower, with mature trees whose roots heave an old walk and original grading that pushes water the wrong way. We excavate, build a proper compacted base, run the path around the roots, set the slope off the surface, and pull the City of West Palm Beach permit.',
    ],
    localNote: 'Older in-town lots have mature tree roots that buckle a path and narrow side yards for garden runs — we design the walk to the period, route it around the roots, and build the base to handle the settling.',
    faqs: [
      { q: 'What paver suits a historic El Cid or Flamingo Park front walk?', a: 'Clay brick and warm-toned pavers in a herringbone or running-bond pattern read true to the 1920s–40s architecture. We help you choose a finish for the entry walk that looks original to the house rather than bolted on.' },
      { q: 'My old brick walk has heaved over tree roots — can you fix it?', a: 'Yes. We take up the buckled path, work around the root, and rebuild a compacted base so the walk sits flat and trip-safe. A paver walkway can then be reset unit by unit if the ground ever moves again — no cracked slab to replace.' },
      { q: "Is there an approval process in West Palm Beach's historic neighborhoods?", a: 'There is no HOA, but some streets are in a city historic district where exterior changes are reviewed. We keep the design period-appropriate, pull the City of West Palm Beach permit, and handle any historic-district paperwork that applies.' },
      { q: 'What does a paver walkway cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  'delray-beach': {
    lede: 'Around Lake Ida and the beach the homes are older and the salt air is constant — a sealed paver walkway takes it better than concrete ever will.',
    intro: [
      "Delray's strength is the east side — Lake Ida, the beach district, Del-Ida Park — where established homes sit close to the water. These coastal streets have a character of their own, and many of the front walks are original to homes from the 1950s through 80s, cracked and uneven after decades of roots and settling.",
      'This close to the ocean, salt and heavy summer rain wear a walk down fast. Concrete stains and spalls; a sealed paver walkway shrugs off the salt, and if a section settles near a tree or the water we reset those units rather than patching a slab. Travertine and warm-toned pavers give the entry and garden paths a coastal look that stays even and trip-safe.',
      'The good news on the east side is simplicity — most of these streets are non-HOA, so approval is usually just the city permit. We pull the City of Delray Beach permit, build the base for the sandy coastal soil, run the walk around mature roots, and grade the drainage off the surface.',
    ],
    localNote: 'Coastal east-side lots deal with salt, high summer rain and big shade trees — we seal for the salt, route the walk around roots, and set the slope so heavy rain sheds off instead of pooling on the path.',
    faqs: [
      { q: 'Does salt air near the Delray beach hurt a paver walkway?', a: 'Far less than it hurts concrete. We seal the pavers so salt and storm runoff bead off, and because the surface is individual units, any piece that ever weathers or settles near the water can be lifted and reset — no visible patch.' },
      { q: 'My front walk near Lake Ida is cracked and uneven — replace it?', a: 'Usually yes. An old walk that has heaved over roots or settled is past patching; we remove it, build a compacted base and lay a paver walkway that sits flat and stays trip-safe, with any future movement fixed by a simple reset.' },
      { q: "I'm on a non-HOA street near the beach — what approval do I need?", a: 'Usually just the city permit. Most of the Lake Ida and beach-district streets have no HOA, so we simply pull the City of Delray Beach permit, handle the drainage requirement if one applies, and get to work.' },
      { q: 'What does a paver walkway cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  'boynton-beach': {
    lede: "Along the Intracoastal and Boynton's eastern streets, front walks see salt and settle near the water — pavers handle both and stay even.",
    intro: [
      "Boynton Beach's best hardscape work is on the water and to the east — the Intracoastal waterfront, Harbor Estates, Chapel Hill, Lake Eden. Many of these homes are 1960s–90s builds whose original front walks have cracked and settled, and a paver walkway is the upgrade that resets both the look and the footing at the entry.",
      'Near the Intracoastal, salt and a high water table both work against a slab. We build the base for ground that stays damp, seal the pavers against the salt, and set a slope and edge so the path sheds summer downpours instead of pooling by the door. On narrow side-yard runs we lay the walk to keep a clean, even line to the back.',
      'Boynton is a mix — some waterfront pockets are non-HOA, some newer streets run an HOA. We confirm which applies to you, prepare the HOA submittal if there is one, and pull the City of Boynton Beach permit either way. We can also match the new walk to your driveway or entry.',
    ],
    localNote: 'Waterfront lots near the Intracoastal sit on a higher water table — we build the base for damp ground, seal against salt, and grade the walk so heavy rain sheds off instead of pooling at the entry.',
    faqs: [
      { q: 'My Boynton home backs onto the Intracoastal — does the water table matter for a walkway?', a: 'It does. A high water table near the water makes a solid, well-compacted base essential, which is exactly what we build. Pavers over that base handle the damp ground and let you reset any section that ever settles by the seawall.' },
      { q: 'Can you run a narrow walkway down the side yard to the back?', a: 'Yes. Side-yard runs are a common request here — we lay the path to a clean, even line and set the edges so it holds up, giving you a trip-safe route from the front to the pool or dock in back.' },
      { q: 'Is there an HOA approval step in Boynton Beach?', a: 'It depends on your street — waterfront pockets are often non-HOA, while newer communities have one. We check first, prepare the HOA package if it is needed, and pull the City of Boynton Beach permit regardless.' },
      { q: 'What does a paver walkway cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
};

const local = LOCAL[city.slug];
const permit = city.permitAuthority.replace('the ', '').replace(/^./, (m) => m.toUpperCase());
const handles = [
  `A trip-safe, even paver walkway on a compacted base built for ${city.name}'s sandy soil and mature tree roots`,
  city.hoa === 'none'
    ? 'Any city or historic-district review kept period-appropriate'
    : city.hoa === 'hoa'
    ? 'Your HOA / architectural review board submittal prepared and shepherded through'
    : 'HOA or non-HOA — we confirm your street and handle whichever applies',
  `${permit} permit pulled, with drainage and slope built to local code`,
];

const data = {
  seoTitle: `Paver Walkways in ${city.name}, FL · Perfect Pavers of Palm Beach`,
  seoDescription: `Custom paver walkways in ${city.name} — front entry walks and garden paths, trip-safe and even. ${permit} permit and ${city.hoa === 'none' ? 'district' : 'HOA/ARB'} approval handled. Free on-site visit.`,
  service: SERVICE,
  city,
  lede: local.lede,
  intro: local.intro,
  localNote: local.localNote,
  handles,
  faqs: local.faqs,
  heroImg: '/images/local-hero-walkways.jpg',
  heroAlt: `Paver walkway in ${city.name}, Palm Beach County`,
  heroBg: '/images/local-hero-walkways.jpg',
  services: SERVICES,
  cities: CITY_CHIPS,
};
---
<LocalServiceTemplate {...data} />
