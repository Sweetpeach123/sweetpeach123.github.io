---
import LocalServiceTemplate from '../../../components/LocalServiceTemplate.astro';
import { CITIES, type City } from '../../../data/cities';

export function getStaticPaths() {
  return CITIES.map((city) => ({ params: { city: city.slug }, props: { city } }));
}

const { city } = Astro.props as { city: City };

const SERVICE = { name: 'Paver driveways', label: 'Driveways', slug: 'driveways' };

const SERVICES = [
  { label: 'Driveways', slug: 'driveways' },
  { label: 'Walkways', slug: 'walkways' },
  { label: 'Patios', slug: 'patios' },
  { label: 'Pool decks', slug: 'pool-decks' },
  { label: 'Outdoor living', slug: 'outdoor-living' },
  { label: 'Retaining & seating walls', slug: 'retaining-seating-walls' },
  { label: 'Natural stone', slug: 'natural-stone' },
  { label: 'Clean & seal', slug: 'clean-seal' },
];
const CITY_CHIPS = CITIES.map((c) => ({ label: c.name, slug: c.slug }));

// ---- Per-city driveway copy (uniquely written off each city's real differentiators) ----
interface Local { lede: string; intro: string[]; localNote: string; faqs: { q: string; a: string }[]; }
const LOCAL: Record<string, Local> = {
  'boca-raton': {
    lede: 'In East Boca, a lot of driveways were poured when the house went up in the 1970s or 80s — four decades of sun, salt and settling later, they are ready for pavers.',
    intro: [
      'Boca Raton is one of South Florida\'s most established communities, and a large share of its homes — through East Boca, the Boca Islands and Old Floresta — date to the 1970s through 90s. A concrete driveway that old has usually cracked, spalled at the surface, or sunk where the ground settled near a canal. We remove the failing slab, build a proper compacted base, and lay a paver driveway that flexes with the ground instead of cracking with it.',
      'This close to the ocean and the canals, salt air is relentless on a driveway. Sealed pavers shrug off the salt and the afternoon storms, and if a section ever settles near the seawall we lift and reset those pavers rather than patching a slab you can never hide.',
      'Whether you are on a non-HOA street in East Boca or inside a gated club like Royal Palm Yacht & Country Club, we handle the paperwork — the City of Boca Raton permit, the drainage slope, and the architectural review submittal for the clubs that require it.',
    ],
    localNote: "Boca's coastal lots often carry drainage and swale requirements, and canal-front homes can have a low door threshold — we build the slope so water runs to the street or the swale, never back toward the house.",
    faqs: [
      { q: 'Do you work inside the gated communities in Boca Raton?', a: 'Yes. We regularly prepare the architectural review board package for gated clubs like Royal Palm Yacht & Country Club, then pull the City of Boca Raton permit once the community signs off.' },
      { q: 'My driveway is original to my 1980s East Boca home — can it be saved?', a: 'Usually the honest answer is no. A slab that old has cracked and settled, and laying pavers over failing concrete just moves the problem. We remove it, build a fresh compacted base, and you get a driveway that outlasts the next slab by decades.' },
      { q: 'Will pavers crack like my concrete driveway?', a: 'No. Concrete is a single rigid slab, so when the ground shifts it cracks. A paver driveway is individual units over a compacted base, so it flexes with the ground and stays intact — and any piece can be lifted and reset with no visible patch.' },
      { q: 'What does a paver driveway cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  jupiter: {
    lede: "Jupiter's waterfront and golf homes went up in the 1990s and 2000s, and most sit inside a gated community with its own approval board — we take that off your plate.",
    intro: [
      "From Admirals Cove to the Loxahatchee Club, most of Jupiter's target homes are 1990s–2000s builds inside gated golf and waterfront communities. The original driveways are dated rather than destroyed, so the job here is as much about the look — matching the community palette and lifting curb appeal — as it is about the base.",
      'The catch in Jupiter is the architectural review board. Nearly every community here has one, and it decides the color, pattern and border you are allowed. We prepare the ARB submittal with the paver spec and drawings so it clears the first time, then pull the Town of Jupiter permit.',
      'On the water — the Intracoastal, the inlet, the canals — salt and boat-trailer weight both matter. We build the base for the load and seal for the salt, so the apron by the garage holds up to the trailer and the driveway holds its color.',
    ],
    localNote: 'Most Jupiter projects run through a community architectural review board before the Town permit — we manage both, and build the drainage to the community grading rules.',
    faqs: [
      { q: 'Will you handle the architectural review board approval in my Jupiter community?', a: 'Yes — that is a standard part of the job here. We prepare the ARB package (paver color, pattern, border and drawings), get the community sign-off, and only then order material and pull the Town of Jupiter permit.' },
      { q: 'Can you match the paver style my community requires?', a: 'We build to the community approved palette. Bring us the guidelines or the ARB requirements and we spec a driveway that meets them while still looking custom to your home.' },
      { q: 'Will pavers crack like my concrete driveway?', a: 'No. A paver driveway is individual units over a compacted base, so it flexes with the ground instead of cracking like a rigid slab — and any piece can be lifted and reset with no visible patch.' },
      { q: 'What does a paver driveway cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  'palm-beach-gardens': {
    lede: "PGA National, BallenIsles, Frenchman's Creek — the Gardens' golf communities are old enough now that the whole front of the house is ready for a redo.",
    intro: [
      "Palm Beach Gardens grew up around golf — PGA National, BallenIsles, Frenchman's Creek, Mirasol — and those 1990s–2000s homes have reached the age where the pavers or concrete out front look tired. A new paver driveway is the single biggest lift you can give the curb appeal in a community where every house is judged against its neighbor.",
      'The design guidelines here are strict. Communities in the Gardens often dictate the color family and the pattern to keep the streetscape consistent, so the work is picking a paver that satisfies the committee and still sets your home apart. We build that into the plan from the start.',
      'Under the surface it is the same discipline every time — proper excavation, a compacted rock base for the sandy soil, edge restraints and a slope that carries water away. We pull the City of Palm Beach Gardens permit and prepare the community submittal.',
    ],
    localNote: 'Gardens golf communities typically require design-committee approval on color and pattern before work starts — we prepare that submittal alongside the City permit.',
    faqs: [
      { q: 'Does my Palm Beach Gardens community have to approve the driveway?', a: 'Almost certainly yes — communities like PGA National and BallenIsles run design committees that approve color and pattern. We prepare and submit that package for you, then pull the City permit once it clears.' },
      { q: 'Our community pavers are faded and uneven — replace or reset?', a: 'If the base is sound we can lift, re-level and reseal; if the base has failed or the field has settled unevenly, a rebuild is the lasting fix. We tell you honestly which one your driveway needs at the on-site visit.' },
      { q: 'Will pavers crack like my concrete driveway?', a: 'No. A paver driveway is individual units over a compacted base, so it flexes with the ground instead of cracking like a rigid slab — and any piece can be lifted and reset with no visible patch.' },
      { q: 'What does a paver driveway cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  wellington: {
    lede: "Out in Wellington's equestrian estates the driveways are long, the aprons are big, and horse trailers are heavy — this is base-and-load engineering, not just surface.",
    intro: [
      'Wellington is a different kind of driveway job. Out on the acreage of Palm Beach Point, the Aero Club and Grand Prix Village, driveways run long — often a circular drive plus a service apron — and they carry real weight: trucks, horse trailers, feed deliveries. Get the base wrong and you see ruts within a season.',
      'We build these for the load. That means deeper excavation, a thicker compacted rock base and the right paver thickness where trailers turn and park, so the surface stays flat under weight that would rut a thin residential build. On acreage we also plan the drainage across a much larger area.',
      'The scale is the opportunity — a long paver driveway on an estate lot is a statement, and it is where pavers pull the furthest ahead of a poured strip that would crack end to end. We pull the Village of Wellington permit and grade the whole run.',
    ],
    localNote: 'Estate driveways carry trailer and truck loads over long runs — we build a deeper base and thicker pavers at the turns and aprons, and grade drainage across the full acreage.',
    faqs: [
      { q: 'My driveway has to take horse trailers and trucks — will pavers hold up?', a: 'Yes, when they are built for it. We increase the base depth and use a thicker paver at the aprons and turning areas so the surface carries trailer and truck weight without rutting — and any spot that ever moves can be reset, unlike a cracked concrete strip.' },
      { q: 'Can you do a long circular driveway on an acre-plus lot?', a: 'That is a big part of what we do in Wellington. Long runs and circular drives are where a paver driveway really shines — we grade the drainage across the whole lot and build the base for the loads an estate driveway actually sees.' },
      { q: 'Will pavers crack like my concrete driveway?', a: 'No. A paver driveway is individual units over a compacted base, so it flexes with the ground instead of cracking like a rigid slab — and any piece can be lifted and reset with no visible patch.' },
      { q: 'What does a paver driveway cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  'west-palm-beach': {
    lede: 'In El Cid, SoSo and Flamingo Park the homes date to the 1920s–40s — the driveway has to fit the period, not fight it.',
    intro: [
      "West Palm Beach's target streets — El Cid, SoSo, Flamingo Park, Prospect Park — are historic, with Spanish and Mediterranean homes from the 1920s through the 40s. A driveway here has to suit the architecture: clay brick and warm-toned pavers laid in a classic pattern read right where a plain gray slab looks out of place.",
      'Several of these neighborhoods sit in city historic districts, so the design should stay in step with the period. There is no HOA to answer to, but there is a look worth protecting — we help you pick a paver and pattern that lifts a historic home rather than modernizing away its character.',
      'The lots are older and often narrower, and the mature trees and original grading make the base work matter. We excavate, build a proper compacted base, set the slope away from the house, and pull the City of West Palm Beach permit.',
    ],
    localNote: 'Older in-town lots have mature tree roots and original grading to work around, and some streets fall in a historic district — we design to the period and build the base to handle the roots and settling.',
    faqs: [
      { q: 'What paver suits a historic El Cid or Flamingo Park home?', a: 'Clay brick and warm-toned pavers in a herringbone or running-bond pattern read true to the 1920s–40s architecture. We help you choose a finish that looks original to the house rather than bolted on.' },
      { q: "Is there an approval process in West Palm Beach's historic neighborhoods?", a: 'There is no HOA, but some streets are in a city historic district where exterior changes are reviewed. We keep the design period-appropriate, pull the City of West Palm Beach permit, and handle any historic-district paperwork that applies.' },
      { q: 'Will pavers crack like my concrete driveway?', a: 'No. A paver driveway is individual units over a compacted base, so it flexes with the ground instead of cracking like a rigid slab — and any piece can be lifted and reset with no visible patch.' },
      { q: 'What does a paver driveway cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  'delray-beach': {
    lede: 'Around Lake Ida and the beach the homes are older and the salt air is constant — a sealed paver driveway takes it better than concrete ever will.',
    intro: [
      "Delray's strength is the east side — Lake Ida, the beach district, Del-Ida Park — where established homes sit close to the water. These coastal streets have a character all their own, and many of the driveways are original to homes from the 1950s through 80s and well past their life.",
      'This close to the ocean, salt and heavy summer rain wear a driveway down fast. Concrete stains and spalls; a sealed paver driveway shrugs off the salt, and if a section settles near the water we reset those pavers rather than patching a slab. It stays looking new with an occasional rinse and reseal.',
      'The good news on the east side is simplicity — most of these streets are non-HOA, so approval is usually just the city permit. We pull the City of Delray Beach permit, build the base for the sandy coastal soil, and grade the drainage away from the home.',
    ],
    localNote: 'Coastal east-side lots deal with salt and high summer rain — we seal for the salt and build the slope to move heavy rain to the swale or street, away from older homes with low thresholds.',
    faqs: [
      { q: 'Does salt air near the Delray beach hurt a paver driveway?', a: 'Far less than it hurts concrete. We seal the pavers so salt and storm runoff bead off, and because the surface is individual units, any piece that ever weathers or settles near the water can be lifted and reset — no visible patch.' },
      { q: "I'm on a non-HOA street near Lake Ida — what approval do I need?", a: 'Usually just the city permit. Most of the Lake Ida and beach-district streets have no HOA, so we simply pull the City of Delray Beach permit, handle the drainage requirement if one applies, and get to work.' },
      { q: 'Will pavers crack like my concrete driveway?', a: 'No. A paver driveway is individual units over a compacted base, so it flexes with the ground instead of cracking like a rigid slab — and any piece can be lifted and reset with no visible patch.' },
      { q: 'What does a paver driveway cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
  'boynton-beach': {
    lede: "Along the Intracoastal and Boynton's eastern streets, driveways see salt and settle near the water — pavers handle both.",
    intro: [
      "Boynton Beach's best hardscape work is on the water and to the east — the Intracoastal waterfront, Harbor Estates, Chapel Hill, Lake Eden. Many of these homes are 1960s–90s builds whose original driveways have cracked and settled, and they are ready for an upgrade.",
      'Near the Intracoastal, salt and a high water table both work against a slab. We build the base for ground that stays damp, seal the pavers against the salt, and set the drainage so summer downpours run off instead of pooling by the garage.',
      'Boynton is a mix — some waterfront pockets are non-HOA, some newer streets run an HOA. We confirm which applies to you, prepare the HOA submittal if there is one, and pull the City of Boynton Beach permit either way.',
    ],
    localNote: 'Waterfront lots near the Intracoastal sit on a higher water table — we build the base for damp ground, seal against salt, and grade so heavy rain drains away from the home.',
    faqs: [
      { q: 'My Boynton home backs onto the Intracoastal — does the water table matter?', a: 'It does. A high water table near the water makes a solid, well-compacted base essential, which is exactly what we build. Pavers over that base handle the damp ground and let you reset any section that ever settles by the seawall.' },
      { q: 'Is there an HOA approval step in Boynton Beach?', a: 'It depends on your street — waterfront pockets are often non-HOA, while newer communities have one. We check first, prepare the HOA package if it is needed, and pull the City of Boynton Beach permit regardless.' },
      { q: 'Will pavers crack like my concrete driveway?', a: 'No. A paver driveway is individual units over a compacted base, so it flexes with the ground instead of cracking like a rigid slab — and any piece can be lifted and reset with no visible patch.' },
      { q: 'What does a paver driveway cost?', a: 'It depends on size, material and site prep, which is why the on-site visit and written estimate are free and itemized. Financing through Wisetack is available so the budget does not decide the timeline.' },
    ],
  },
};

const local = LOCAL[city.slug];
const permit = city.permitAuthority.replace('the ', '').replace(/^./, (m) => m.toUpperCase());
const handles = [
  `Removal of the failing driveway and a compacted rock base built for ${city.name}'s sandy soil`,
  city.hoa === 'none'
    ? 'Any city or historic-district review kept period-appropriate'
    : city.hoa === 'hoa'
    ? 'Your HOA / architectural review board submittal prepared and shepherded through'
    : 'HOA or non-HOA — we confirm your street and handle whichever applies',
  `${permit} permit pulled, with drainage and slope built to local code`,
];

const data = {
  seoTitle: `Paver Driveways in ${city.name}, FL · Perfect Pavers`,
  seoDescription: `Custom paver driveways in ${city.name} — proper rock base, drainage and edge restraints. ${permit} permit and ${city.hoa === 'none' ? 'district' : 'HOA/ARB'} approval handled. Free on-site visit.`,
  service: SERVICE,
  city,
  lede: local.lede,
  intro: local.intro,
  localNote: local.localNote,
  handles,
  faqs: local.faqs,
  heroImg: '/images/pf-driveway.jpg',
  heroAlt: `Paver driveway in ${city.name}, Palm Beach County`,
  heroBg: '/images/local-hero-driveways.jpg',
  services: SERVICES,
  cities: CITY_CHIPS,
};
---
<LocalServiceTemplate {...data} />
