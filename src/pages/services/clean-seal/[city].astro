const local = LOCAL[city.slug];
const permit = city.permitAuthority.replace('the ', '').replace(/^./, (m) => m.toUpperCase());
const handles = [
  `Deep cleaning that lifts the mold, weeds, ants and ground-in grime off pavers in ${city.name}'s ${city.setting}`,
  'Joints re-sanded with polymeric sand that hardens to lock out weeds and ants',
  'Sealing in your choice of finish — a matte natural look or a wet-look enhancer — to protect the color against sun and salt',
];

const data = {
  seoTitle: `Paver Cleaning & Sealing in ${city.name}, FL · Perfect Pavers of Palm Beach`,
  seoDescription: `Restore faded pavers in ${city.name} — deep clean, re-sand the joints with polymeric sand, and seal matte or wet-look. Low-disruption, no teardown. Free on-site visit.`,
  service: SERVICE,
  city,
  lede: local.lede,
  intro: local.intro,
  localNote: local.localNote,
  handles,
  faqs: local.faqs,
  heroImg: '/images/local-hero-clean-seal.jpg',
  heroAlt: `Cleaned and sealed pavers in ${city.name}, Palm Beach County`,
  heroBg: '/images/local-hero-clean-seal.jpg',
  services: SERVICES,
  cities: CITY_CHIPS,
};
---
<LocalServiceTemplate {...data} />
