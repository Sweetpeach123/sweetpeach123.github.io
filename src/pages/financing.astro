---
import BaseLayout from '../layouts/BaseLayout.astro';

const steps = [
  { n: '01', t: 'Get your written estimate', meta: 'Free, itemized', p: 'It starts the same honest way every project does: a free on-site visit and a full written estimate with the base, drainage, and restraints already included.' },
  { n: '02', t: 'Apply in minutes', meta: 'Soft credit check', p: 'Check your options through Wisetack with a quick application. Seeing your rate is a soft credit check that does not affect your credit score.' },
  { n: '03', t: 'Choose your monthly plan', meta: 'Terms that fit', p: 'Pick the monthly payment and term that work for your budget. Clear terms, no hidden fees, and no prepayment penalty if you pay it off early.' },
  { n: '04', t: 'We build, you pay monthly', meta: 'Do it right, once', p: 'With the budget handled, you can build it right the first time — full base, proper drainage, and the materials you actually want.' },
];

const benefits = [
  { k: 'No surprises', t: 'See your rate, no impact', p: 'Checking your options is a soft credit check. It will not affect your credit score, so there is no risk in finding out what you qualify for.' },
  { k: 'Flexible', t: 'Monthly payments that fit', p: 'Spread the cost over comfortable monthly payments instead of one large sum, and keep your savings where they belong.' },
  { k: 'Fair', t: 'No fees, no penalties', p: 'No hidden fees and no prepayment penalty. Pay your project off early whenever you like, with nothing extra owed.' },
];

const faqs = [
  { q: 'Who provides the financing?', a: 'We partner with Wisetack and Jobber, established financing platforms used by home-service contractors across the country. The lending is handled by them; we simply make it easy to apply.' },
  { q: 'Will checking my rate hurt my credit?', a: 'No. Seeing what you prequalify for is a soft credit check, which does not affect your credit score. A hard check only happens if you choose to move forward with a loan.' },
  { q: 'What can I finance?', a: 'Any of our work — driveways, walkways, patios, pool decks, outdoor living, walls, natural stone, and clean-and-seal. Projects generally start at $1,200.' },
  { q: 'Is there a penalty for paying early?', a: 'No. There is no prepayment penalty. You can pay off the balance early at any time without any additional fee.' },
  { q: 'How long does approval take?', a: 'The application takes just a few minutes and most people see their options right away. Once you choose a plan, we can get your project on the schedule.' },
];
---
<BaseLayout
  title="Financing · Flexible Monthly Payments · Perfect Pavers of Palm Beach"
  description="Flexible monthly financing for paver driveways, pool decks, patios and outdoor living in Palm Beach County, through Wisetack and Jobber. Checking your rate is a soft credit check with no impact to your score.">

  <nav class="crumbs">
    <div class="wrap">
      <a href="/">Home</a> <span>/</span> <strong>Financing</strong>
    </div>
  </nav>

  <section class="fin-hero">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Financing available</div>
      <h1>Don&rsquo;t let the budget decide the <em>timeline.</em></h1>
      <p class="lede">Flexible monthly financing through Wisetack and Jobber means you can do it right the first time: full base, proper drainage, and the materials you actually want.</p>
      <div class="hero-cta" style="margin-top:30px;display:flex;gap:14px;flex-wrap:wrap">
        <a href="/contact" class="btn btn-brass">Request your free estimate</a>
        <a href="tel:+19547791855" class="btn btn-ghost">Call (954) 779-1855</a>
      </div>
    </div>
  </section>

  <section class="block wrap">
    <div class="sec-head">
      <span class="sec-num">Why finance</span>
      <h2>Build it right, pay over time.</h2>
    </div>
    <div class="props">
      {benefits.map((b) => (
        <div class="card">
          <div class="k">{b.k}</div>
          <h3>{b.t}</h3>
          <p>{b.p}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="block wrap" style="padding-top:0">
    <div class="sec-head">
      <span class="sec-num">How it works</span>
      <h2>From estimate to easy monthly payments.</h2>
    </div>
    <div class="steps">
      {steps.map((s) => (
        <div class="step">
          <div class="n">{s.n}</div>
          <h3>{s.t}</h3>
          <p>{s.p}</p>
          <span class="tag">{s.meta}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="partners">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Our financing partners</div>
      <h2>Backed by names you can trust.</h2>
      <div class="partner-grid">
        <div class="partner">
          <h3>Wisetack</h3>
          <p>Simple, transparent consumer financing built for home-service projects. Check your rate with a soft credit pull, choose a monthly plan, and pay with no hidden fees and no prepayment penalty.</p>
        </div>
        <div class="partner">
          <h3>Jobber</h3>
          <p>The platform we use to send your written estimate, schedule the work, and offer convenient payment options — so the whole process, from quote to payment, stays clear and in one place.</p>
        </div>
      </div>
      <p class="partner-note">Financing is subject to approval by our lending partners. Checking your options is a soft credit check that does not affect your credit score. Terms and availability are set by the lender.</p>
    </div>
  </section>

  <section class="block wrap faq">
    <div class="sec-head">
      <span class="sec-num">Questions</span>
      <h2>Good to know.</h2>
    </div>
    <div class="faq-list">
      {faqs.map((f) => (
        <details>
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="cta">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Ready when you are</div>
      <h2>Let&rsquo;s walk your property.</h2>
      <p>Start with a free on-site visit and a written estimate. We&rsquo;ll show you the monthly options so the budget never decides the timeline.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a href="/contact" class="btn btn-brass">Request a visit</a>
        <a href="tel:+19547791855" class="btn btn-ghost" style="color:var(--ivory)">Call (954) 779-1855</a>
      </div>
    </div>
  </section>

  <style>
    .crumbs{border-bottom:1px solid var(--line);background:var(--ivory)}
    .crumbs .wrap{padding-top:16px;padding-bottom:16px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
    .crumbs a:hover{color:var(--brass-dark)}
    .crumbs span{margin:0 8px;color:var(--brass)}
    .crumbs strong{font-weight:500;color:var(--ink)}

    .fin-hero{background:var(--green);color:var(--ivory);padding:78px 0 66px}
    .fin-hero h1{font-size:clamp(34px,5.4vw,58px);line-height:1.06;color:var(--ivory);margin-top:14px;max-width:15em}
    .fin-hero h1 em{font-style:italic;color:var(--brass)}
    .fin-hero .lede{font-weight:300;opacity:.9;max-width:38em;margin-top:18px;font-size:18px}

    .partners{background:var(--ivory-2)}
    .partners .wrap{padding:96px 40px}
    .partner-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:34px}
    .partner{background:var(--ivory);border:1px solid var(--line);border-radius:10px;padding:34px 36px}
    .partner h3{font-size:28px;margin-bottom:12px}
    .partner p{font-size:15.5px;color:var(--muted);font-weight:300;line-height:1.7}
    .partner-note{font-size:13px;color:var(--muted);font-weight:300;font-style:italic;margin-top:26px;max-width:70ch}

    .faq-list{max-width:820px;border-top:1px solid var(--line)}
    .faq-list details{border-bottom:1px solid var(--line);padding:4px 0}
    .faq-list summary{cursor:pointer;list-style:none;padding:22px 0;font-family:var(--serif);font-size:22px;color:var(--ink);display:flex;justify-content:space-between;align-items:center}
    .faq-list summary::-webkit-details-marker{display:none}
    .faq-list summary::after{content:'+';color:var(--brass-dark);font-family:var(--sans);font-weight:400}
    .faq-list details[open] summary::after{content:'–'}
    .faq-list details p{padding:0 0 24px;color:var(--muted);font-weight:300;font-size:16px;max-width:70ch}

    @media(max-width:1024px){
      .fin-hero{padding:56px 0 48px}
      .partners .wrap{padding:60px 22px}
      .partner-grid{grid-template-columns:1fr}
      .faq-list summary{font-size:19px}
    }

    @media(max-width:600px){
      .fin-hero{padding:44px 0 38px}
      .partners .wrap{padding:48px 18px}
      .partner{padding:26px 22px}
      .partner h3{font-size:24px}
      .faq-list summary{font-size:17px;padding:18px 0}
      .faq-list details p{font-size:15px}
    }
  </style>

</BaseLayout>
