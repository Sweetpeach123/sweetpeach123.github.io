---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  { label: 'Driveways', href: '/services/driveways', img: '/images/svc-driveways.webp', alt: 'Paver driveway installation' },
  { label: 'Walkways', href: '/services/walkways', img: '/images/svc-walkways.jpg', alt: 'Paver walkway' },
  { label: 'Patios', href: '/services/patios', img: '/images/svc-patios.webp', alt: 'Travertine paver patio' },
  { label: 'Pool decks', href: '/services/pool-decks', img: '/images/svc-pooldecks.jpg', alt: 'Travertine pool deck' },
  { label: 'Outdoor living', href: '/services/outdoor-living', img: '/images/svc-outdoor.jpg', alt: 'Outdoor kitchen and living space' },
  { label: 'Retaining & seating walls', href: '/services/retaining-seating-walls', img: '/images/svc-walls.webp', alt: 'Retaining and seating wall' },
  { label: 'Natural stone', href: '/services/natural-stone', img: '/images/svc-naturalstone.webp', alt: 'Natural stone installation' },
  { label: 'Clean & seal', href: '/services/clean-seal', img: '/images/svc-cleanseal.jpg', alt: 'Paver cleaning and sealing' },
];

const cities = ['West Palm Beach','Boca Raton','Boynton Beach','Delray Beach','Palm Beach Gardens','Lake Worth Beach','Riviera Beach','Greenacres','Wellington','Jupiter','Atlantis','Westlake'];
---
<BaseLayout
  title="Perfect Pavers of Palm Beach · Driveways, Pool Decks & Outdoor Living"
  description="Premium paver driveways, pool decks, patios and outdoor living across Palm Beach County. State Licensed Building Contractor, ICPI certified, 35+ years in South Florida. Free on-site visit."
  bodyClass="wide">

  <section class="wrap hero">
    <div class="hero-text">
      <div class="eyebrow">Pavers &amp; natural stone · Palm Beach County</div>
      <h1>Pavers worthy of <em>the address.</em></h1>
      <p class="lede">For more than thirty-five years, Palm Beach&rsquo;s finest properties have trusted us for driveways, pool decks, and outdoor living, installed to a standard you can stand on for decades.</p>
      <div class="hero-cta">
        <a href="/contact" class="btn btn-brass">Request your on-site visit</a>
        <a href="tel:+19547791855" class="btn btn-ghost">Call (954) 779-1855</a>
      </div>
    </div>
    <div class="hero-img">
      <div class="ph" data-label="Travertine forecourt · Palm Beach estate">
        <img src="/images/hero-estate.jpg" alt="Travertine paver forecourt and entrance of a modern Palm Beach estate" width="1600" height="1000" fetchpriority="high" />
      </div>
      <div class="hero-badge">
        <div class="n">35+</div>
        <div class="t">Years &amp; thousands of South Florida projects</div>
      </div>
    </div>
  </section>

  <section class="trust">
    <div class="wrap">
      <div class="cell"><div class="ic">✦</div><h4>Proven, not promised</h4><p>35+ years and real, named projects across Palm Beach, with no stock photos.</p></div>
      <div class="cell"><div class="ic">✦</div><h4>Licensed &amp; certified</h4><p>State Licensed Building Contractor (CGC#________) and ICPI, a rare combination.</p></div>
      <div class="cell"><div class="ic">✦</div><h4>Fully transparent</h4><p>Free on-site visit, full written estimate, and zero hidden change orders.</p></div>
      <div class="cell"><div class="ic">✦</div><h4>Built to last</h4><p>Proper rock base, drainage and edge restraints, plus a 5-year workmanship upgrade.</p></div>
    </div>
  </section>

  <section class="block wrap">
    <div class="sec-head">
      <span class="sec-num">01 · Why Palm Beach trusts us</span>
      <h2>A contractor you can actually reach, before and after the check clears.</h2>
    </div>
    <div class="props">
      <div class="card">
        <div class="k">On your terms</div>
        <h3>On-site within 1&ndash;2 days</h3>
        <p>Most installers take four weeks to show up. We measure your property and bring real material samples to your door within a day or two.</p>
      </div>
      <div class="card">
        <div class="k">No surprises</div>
        <h3>One transparent estimate</h3>
        <p>Rock base, drainage, and edge restraints are written in, not added later. The number we quote is the number you pay.</p>
      </div>
      <div class="card">
        <div class="k">Still here later</div>
        <h3>We don&rsquo;t disappear</h3>
        <p>Daily site cleanup, updates at every stage, a final walkthrough, and a team that answers the phone years after the install.</p>
      </div>
    </div>
  </section>

  <section id="services" class="block wrap">
    <div class="sec-head">
      <span class="sec-num">02 · What we install</span>
      <h2>Seven surfaces, one standard of finish.</h2>
    </div>
    <div class="services">
      {services.map((s) => (
        <a class="svc" href={s.href}>
          <div class="ph" data-label={s.label}><img loading="lazy" decoding="async" alt={s.alt} src={s.img} width="600" height="460" /></div>
          <h3>{s.label}</h3>
          <span class="arrow">Explore <i>→</i></span>
        </a>
      ))}
    </div>
  </section>

  <section class="promise">
    <div class="wrap">
      <div>
        <div class="eyebrow" style="color:var(--brass)">03 · The Perfect Pavers promise</div>
        <h2>The honest estimate is the whole pitch.</h2>
        <p class="lede">For every good contractor in South Florida, there are ten who cut corners on the base, vanish after the deposit, or bury change orders in the fine print. We built the opposite of that.</p>
        <a href="/about/our-process" class="btn btn-brass" style="margin-top:30px">See how we price</a>
      </div>
      <ul>
        <li><span class="mk">i.</span><div><b>Free on-site visit &amp; samples</b><p>Most trades charge for the first visit. We bring the showroom to your driveway at no cost.</p></div></li>
        <li><span class="mk">ii.</span><div><b>Everything included, in writing</b><p>Excavation, 4&ndash;6&Prime; rock base, drainage, edge restraints, specified up front and never billed as &ldquo;extras.&rdquo;</p></div></li>
        <li><span class="mk">iii.</span><div><b>Warranty you can upgrade to 5 years</b><p>Add extra base and hidden restraints and we extend workmanship coverage to five full years.</p></div></li>
        <li><span class="mk">iv.</span><div><b>Refer a friend, both win $150</b><p>You receive a $150 check, they receive a $150 discount. We name the number publicly.</p></div></li>
      </ul>
    </div>
  </section>

  <section class="block wrap">
    <div class="sec-head center">
      <span class="sec-num">04 · How it works</span>
      <h2>From first call to final walkthrough.</h2>
    </div>
    <div class="steps">
      <div class="step"><div class="n">01</div><h3>On-site visit</h3><p>We measure, talk through ideas, and bring material samples to your home.</p><span class="tag">Within 1&ndash;2 days</span></div>
      <div class="step"><div class="n">02</div><h3>Written estimate</h3><p>A full line-item breakdown: base, drainage, restraints, materials, labor.</p><span class="tag">In 24&ndash;48 hours</span></div>
      <div class="step"><div class="n">03</div><h3>Installation</h3><p>Permits and HOA handled, wet-cutting for less dust, daily cleanup and updates.</p><span class="tag">Branded, licensed crew</span></div>
      <div class="step"><div class="n">04</div><h3>Final walkthrough</h3><p>We review every detail with you, then stand behind it with our warranty.</p><span class="tag">We don&rsquo;t disappear</span></div>
    </div>
  </section>

  <section class="block portfolio">
    <div class="wrap">
      <div class="sec-head">
        <span class="sec-num">05 · Recent work</span>
        <h2>Real Palm Beach projects, named.</h2>
      </div>
      <div class="pf-grid">
        <a class="pf" href="/portfolio"><div class="ph" data-label="Before / after"><img loading="lazy" decoding="async" alt="Pool deck transformation in Boca Raton" src="/images/pf-pooldeck.jpg" width="700" height="600" /></div><div class="loc">Boca Raton · Travertine</div><h3>Resort-style pool deck</h3></a>
        <a class="pf" href="/portfolio"><div class="ph" data-label="Before / after"><img loading="lazy" decoding="async" alt="Paver driveway replacement in Palm Beach Gardens" src="/images/pf-driveway.jpg" width="700" height="600" /></div><div class="loc">Palm Beach Gardens · Concrete paver</div><h3>Circular motorcourt driveway</h3></a>
        <a class="pf" href="/portfolio"><div class="ph" data-label="Before / after"><img loading="lazy" decoding="async" alt="Outdoor kitchen and lounge in Delray Beach" src="/images/pf-outdoor.jpg" width="700" height="600" /></div><div class="loc">Delray Beach · Porcelain</div><h3>Outdoor kitchen &amp; lounge</h3></a>
      </div>
      <div style="margin-top:46px"><a href="/portfolio" class="btn btn-ghost">View the full portfolio</a></div>
    </div>
  </section>

  <section class="block wrap reviews">
    <div class="wrap" style="padding:0">
      <div>
        <div class="stars">★★★★★</div>
        <h2 style="font-size:40px;margin-top:14px">What neighbors say</h2>
        <p style="color:var(--muted);margin-top:14px;font-weight:300">Backed by verified Google reviews across Palm Beach County.</p>
        <a href="/reviews" class="btn btn-ghost" style="margin-top:24px">Read all reviews</a>
      </div>
      <div class="rev-grid">
        <div><p class="quote">&ldquo;They came out two days after I called, and the price never moved an inch from the estimate.&rdquo;</p><div class="by">Homeowner · West Palm Beach</div></div>
        <div><p class="quote">&ldquo;The driveway looks like it belongs on a million-dollar property. Neighbors keep asking who did it.&rdquo;</p><div class="by">Homeowner · Boca Raton</div></div>
      </div>
    </div>
  </section>

  <section class="area">
    <div class="wrap" style="padding:96px 40px">
      <div>
        <div class="eyebrow" style="color:var(--brass)">06 · Service area</div>
        <h2>Palm Beach County is all we do.</h2>
        <p style="opacity:.85;font-weight:300;margin-top:18px;max-width:30em">No travel charge to any city we serve. One county, one team, full attention, and genuine knowledge of local code, from swale requirements to door-threshold drainage.</p>
      </div>
      <ul class="cities">
        {cities.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </section>

  <section class="block wrap fin">
    <div class="pill">Financing available</div>
    <h2>Don&rsquo;t let the budget decide the timeline.</h2>
    <p>Flexible monthly financing through Wisetack and Jobber means you can do it right the first time: full base, proper drainage, and the materials you actually want.</p>
  </section>

  <section class="cta">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Your free on-site visit</div>
      <h2>Let&rsquo;s walk your property.</h2>
      <p>Tell us the surface, the size, and your timeline. We&rsquo;ll be at your door within a day or two, samples in hand, no charge, no pressure.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a href="/contact" class="btn btn-brass">Request a visit</a>
        <a href="tel:+19547791855" class="btn btn-ghost" style="color:var(--ivory)">Call (954) 779-1855</a>
      </div>
    </div>
  </section>

</BaseLayout>
