---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  { label: 'Driveways', href: '/services/driveways/', img: '/images/pf-driveway.jpg', alt: 'Neatly laid paver driveway leading to a modern white Palm Beach home' },
  { label: 'Walkways', href: '/services/walkways/', img: '/images/svc-walkways.jpg', alt: 'Paver walkway' },
  { label: 'Patios', href: '/services/patios/', img: '/images/pf-outdoor.jpg', alt: 'Travertine paver patio overlooking the water in Palm Beach' },
  { label: 'Pool decks', href: '/services/pool-decks/', img: '/images/svc-pooldecks.jpg', alt: 'Travertine pool deck' },
  { label: 'Outdoor living', href: '/services/outdoor-living/', img: '/images/svc-outdoor.jpg', alt: 'Paver terrace and outdoor living space' },
  { label: 'Retaining & seating walls', href: '/services/retaining-seating-walls/', img: '/images/svc-walls.webp', alt: 'Retaining and seating wall' },
  { label: 'Natural stone', href: '/services/natural-stone/', img: '/images/svc-naturalstone.jpg', alt: 'Travertine natural stone patio' },
  { label: 'Clean & seal', href: '/services/clean-seal/', img: '/images/svc-cleanseal.jpg', alt: 'Paver cleaning and sealing' },
];

const cities = ['West Palm Beach','Boca Raton','Boynton Beach','Delray Beach','Palm Beach Gardens','Lake Worth Beach','Riviera Beach','Greenacres','Wellington','Jupiter','Atlantis','Westlake'];
---
<BaseLayout
  title="Perfect Pavers of Palm Beach · Driveways, Pool Decks & Outdoor Living"
  description="Premium paver driveways, pool decks, patios and outdoor living across Palm Beach County. State Certified General Contractor, CMHA certified, 35+ years in South Florida. Free on-site visit.">

  <section class="wrap hero">
    <div class="hero-text">
      <div class="eyebrow">Pavers &amp; natural stone · <span class="nb">Palm Beach County</span></div>
      <h1>Pavers worthy of <em>the address.</em></h1>
      <p class="lede">For more than thirty-five years, Palm Beach&rsquo;s finest properties have trusted us for driveways, pool decks, and outdoor living, installed to a standard you can stand on for decades.</p>
      <div class="hero-cta">
        <a href="/contact/" class="btn btn-brass">Request your on-site visit</a>
        <a href="tel:+19547791855" class="btn btn-ghost">Call (954) 779-1855</a>
      </div>
    </div>
    <div class="hero-img">
      <div class="ph" data-label="Paver driveway · Palm Beach estate">
        <img src="/images/hero-driveway.jpg" alt="Paver driveway leading to a modern white Palm Beach estate framed by royal palms" width="552" height="600" fetchpriority="high" />
      </div>
      <div class="hero-badge">
        <div class="n">35+</div>
        <div class="t">Years &amp; thousands of South Florida projects</div>
      </div>
    </div>
  </section>

  <section class="trust">
    <div class="wrap">
      <div class="cell"><h4>35 years. Ask around.</h4><p>We&rsquo;ve built driveways and patios across Palm Beach for over three decades. Want to see one near you? Just ask &mdash; we&rsquo;ll point you to a real address.</p></div>
      <div class="cell"><h4>Licensed &amp; certified</h4><p>State Certified General Contractor (CGC#1524492) and CMHA, a rare combination.</p></div>
      <div class="cell"><h4>Fully transparent</h4><p>Free on-site visit, full written estimate, and zero hidden change orders.</p></div>
      <div class="cell"><h4>Built to last</h4><p>Proper rock base, drainage and edge restraints, plus a 5-year workmanship upgrade.</p></div>
    </div>
  </section>

  <section class="block wrap">
    <div class="sec-head">
      <span class="sec-num">01 · Why Palm Beach trusts us</span>
      <h2>A contractor you can reach, before and after the check clears.</h2>
    </div>
    <div class="props">
      <div class="card">
        <div class="k">On your terms</div>
        <h3>On-site within 1&ndash;2 days</h3>
        <p>Most installers take four weeks to show up. We measure your property and walk through the details within a day or two.</p>
      </div>
      <div class="card">
        <div class="k">No surprises</div>
        <h3>One transparent estimate</h3>
        <p>Rock base, drainage, and edge restraints are written in, not added later. The number we quote is the number you pay.</p>
      </div>
      <div class="card">
        <div class="k">Still here later</div>
        <h3>We don&rsquo;t disappear</h3>
        <p>Daily site cleanup, updates at every stage, a final walkthrough, and a team that answers the phone years after the install.</p>
      </div>
    </div>
  </section>

  <section id="services" class="block wrap">
    <div class="sec-head">
      <span class="sec-num">02 · What we install</span>
      <h2>Seven surfaces, one standard of finish.</h2>
    </div>
    <div class="services">
      {services.map((s) => (
        <a class="svc" href={s.href}>
          <div class="ph" data-label={s.label}><img loading="lazy" decoding="async" alt={s.alt} src={s.img} width="600" height="460" /></div>
          <span class="arrow">Explore <i>→</i></span>
        </a>
      ))}
    </div>
  </section>

  <section class="promise">
    <div class="wrap">
      <div>
        <div class="eyebrow" style="color:var(--brass)">03 · The Perfect Pavers promise</div>
        <h2>The honest estimate is the whole pitch.</h2>
        <p class="lede">For every good contractor in South Florida, there are ten who cut corners on the base, vanish after the deposit, or bury change orders in the fine print. We built the opposite of that.</p>
        <a href="/about/our-process/" class="btn btn-brass" style="margin-top:30px">See how we price</a>
      </div>
      <ul>
        <li><span class="mk">I.</span><div><b>Free on-site visit</b><p>Most trades charge you just to show up. We come out, measure the space, and walk through the details so we can build you a clean, accurate estimate. No charge.</p></div></li>
        <li><span class="mk">II.</span><div><b>Everything included, in writing</b><p>Excavation, 4&ndash;6&Prime; rock base, drainage, edge restraints, specified up front and never billed as &ldquo;extras.&rdquo;</p></div></li>
        <li><span class="mk">III.</span><div><b>Warranty you can upgrade to 5 years</b><p>Standard coverage is 1 year on workmanship. Add extra rock base and hidden edge restraints during installation, and we extend that to 5 full years.</p></div></li>
        <li><span class="mk">IV.</span><div><b>Refer a friend, both win $150</b><p>You get a $150 check. Your friend gets $150 off their project. That&rsquo;s the whole deal.</p></div></li>
      </ul>
    </div>
  </section>

  <section class="block wrap">
    <div class="sec-head center">
      <span class="sec-num">04 · How it works</span>
      <h2>From first call to final walkthrough.</h2>
    </div>
    <div class="steps">
      <div class="step"><div class="n">01</div><h3>On-site visit</h3><p>We measure the space, talk through your ideas, and answer questions on the spot.</p><span class="tag">Within 1&ndash;2 days</span></div>
      <div class="step"><div class="n">02</div><h3>Written estimate</h3><p>A full line-item breakdown: base, drainage, restraints, materials, labor.</p><span class="tag">In 48&ndash;72 hours</span></div>
      <div class="step"><div class="n">03</div><h3>Installation</h3><p>Permits and HOA handled, wet-cutting for less dust, daily cleanup and updates.</p><span class="tag">Branded, licensed crew</span></div>
      <div class="step"><div class="n">04</div><h3>Final walkthrough</h3><p>We review every detail with you, then stand behind it with our warranty.</p><span class="tag">We don&rsquo;t disappear</span></div>
    </div>
  </section>

  <section class="block portfolio">
    <div class="wrap">
      <div class="sec-head">
        <span class="sec-num">05 · Recent work</span>
        <h2>Real Palm Beach projects, named.</h2>
      </div>
      <div class="pf-grid">
        <a class="pf" href="/portfolio/"><div class="ph" data-label="Before / after"><img loading="lazy" decoding="async" alt="Pool deck transformation in Boca Raton" src="/images/pf-pooldeck.jpg" width="700" height="600" /></div><div class="loc">Boca Raton · Travertine</div><h3>Resort-style pool deck</h3></a>
        <a class="pf" href="/portfolio/"><div class="ph"><img loading="lazy" decoding="async" alt="Paver pool deck and terrace overlooking the water at sunset in Manalapan" src="/images/pf-coast.jpg" width="700" height="600" /></div><div class="loc">Manalapan · Travertine</div><h3>Oceanfront pool terrace</h3></a>
        <a class="pf" href="/portfolio/"><div class="ph"><img loading="lazy" decoding="async" alt="Estate water garden in Palm Beach" src="/images/pf-estate.jpg" width="700" height="600" /></div><div class="loc">Palm Beach · Natural stone</div><h3>Estate garden terrace</h3></a>
      </div>
      <div style="margin-top:46px"><a href="/portfolio/" class="btn btn-ghost">View the full portfolio</a></div>
    </div>
  </section>

  <section class="block wrap reviews">
    <div class="wrap" style="padding:0">
      <div>
        <div class="stars">★★★★★</div>
        <h2 style="font-size:40px;margin-top:14px">What neighbors say</h2>
        <p style="color:var(--muted);margin-top:14px;font-weight:300">Rated 5.0 on Google across Palm Beach County.</p>
        <a href="/reviews/" class="btn btn-ghost" style="margin-top:24px">Read all reviews</a>
      </div>
      <div class="rev-grid">
        <div><p class="quote">&ldquo;Fast professional service. My driveway looks amazing. Wish I could give more stars &mdash; 12 out of 10.&rdquo;</p><div class="by">Fred G. · Google review</div></div>
        <div><p class="quote">&ldquo;Driveway extension was done quicker than expected. No issues and no back and forth. Well done!&rdquo;</p><div class="by">Denis Khmel · Google review</div></div>
      </div>
    </div>
  </section>

  <section class="area">
    <div class="wrap">
      <div>
        <div class="eyebrow" style="color:var(--brass)">06 · Service area</div>
        <h2>Palm Beach County is all we do.</h2>
        <p style="opacity:.85;font-weight:300;margin-top:18px;max-width:30em">No travel charge to any city we serve. One county, one team, full attention, and genuine knowledge of local code, from swale requirements to door-threshold drainage.</p>
      </div>
      <ul class="cities">
        {cities.map((c) => <li>{c}</li>)}
      </ul>
    </div>
  </section>

  <section class="block wrap fin">
    <a href="/financing/" class="pill pill-anim">Financing available</a>
    <h2>Don&rsquo;t let the budget decide the timeline.</h2>
    <p>Flexible monthly financing through Wisetack means you can do it right the first time: full base, proper drainage, and the materials you had in mind.</p>
    <a href="/financing/" class="btn btn-brass" style="margin-top:30px">Explore financing options</a>
  </section>

  <section class="cta">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Your free on-site visit</div>
      <h2>Let&rsquo;s walk your property.</h2>
      <p>Tell us the surface, the size, and your timeline. We&rsquo;ll be at your door within a day or two, no charge, no pressure.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a href="/contact/" class="btn btn-brass">Request a visit</a>
        <a href="tel:+19547791855" class="btn btn-ghost" style="color:var(--ivory)">Call (954) 779-1855</a>
      </div>
    </div>
  </section>

</BaseLayout>
