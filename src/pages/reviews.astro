---
import BaseLayout from '../layouts/BaseLayout.astro';

// Real Google Business Profile for Perfect Pavers of Palm Beach.
const googleReviews = 'https://maps.app.goo.gl/FNafrxFtDnwKBzsY8';
const googleRating = '5.0';

// Real five-star reviews from the Google Business Profile (verbatim).
const reviews = [
  { q: `Perfect Pavers of Palm Beach is a highly recommended, full-service company. They consistently take excellent care of my customers and provide outstanding communication and service from start to finish. It’s always great to work with Damon Corn!`, n: 'Amanda Raggio', m: 'Google review' },
  { q: `Driveway extension was done quicker than expected. No issues and no back and forth. Well done!`, n: 'Denis Khmel', m: 'Google review' },
  { q: `We love working with Perfect Pavers. They are always very responsive and get back with us quickly when we call them. Not only do they do great work, I can depend on Robert to complete jobs efficiently and know our clients will be happy at the end of the project.`, n: 'Todd Pinkston', m: 'Google review' },
  { q: `I highly recommend Perfect Pavers of Palm Beach. They were efficient, reliable and timely. My husband and I both loved our salesman, Robert. He was extremely knowledgeable and trustworthy. We couldn’t have asked for a better experience.`, n: 'Jennifer Alembik', m: 'Google review' },
  { q: `Excellent! Robert was very professional, knowledgeable, and available during each phase of the project. All my concerns and questions were answered in a timely manner. I highly recommend him and this company.`, n: 'Arlene', m: 'Google review' },
  { q: `You can depend on this company! I love that when we need to do a project on the house I can call either Robert or Damon and they will take care of it. They help me pick the right materials and answer all of my questions. They are very clean and polite. Robert even came back himself to move furniture back onto the deck and wash it down once it was completed. We were recommended to his company from a neighbor and we will pass on the recommendation.`, n: 'Verified homeowner', m: 'Google review' },
  { q: `Fast professional service. My driveway looks amazing. Robert was more than helpful. Wish I could give more stars — 12 out of 10. Would definitely recommend.`, n: 'Fred G.', m: 'Google review' },
  { q: `They were very easy to work with and very customer friendly. They respected my time, were always on time, and made sure they cleaned up. They did a beautiful job and I have been enjoying it ever since.`, n: 'Tina Daleo', m: 'Google review' },
  { q: `Robert and his crew were a pleasure and very professional to work with. I will use them on all our construction projects and will highly recommend them to all my friends and colleagues.`, n: 'Billy DeMaio', m: 'Google review' },
  { q: `Called for an estimate and they emailed me a reasonable quote in a few days. Damon was my point person and stayed in touch, kept me informed every step, and the quality was better than expected. The night they finished it was raining and Damon was there supervising the crew. Robert, one of the owners, stopped by to make sure I was pleased. Bottom line, I’d use them again — a pleasure when you find a good firm to work with.`, n: 'Arnold Goldner', m: 'Google review' },
  { q: `Had the pool area and walkways redone. Robert helped when we had questions and didn’t overcomplicate things. Happy with how it turned out.`, n: 'Anna M.', m: 'Google review' },
];
---
<BaseLayout
  title="Reviews · What Palm Beach Homeowners Say · Perfect Pavers"
  description="Verified reviews from Palm Beach County homeowners on Perfect Pavers — honest estimates, on-time crews, permits handled, and paver work that lasts.">

  <nav class="crumbs">
    <div class="wrap">
      <a href="/">Home</a> <span>/</span> <strong>Reviews</strong>
    </div>
  </nav>

  <section class="rev-hero">
    <div class="wrap">
      <a class="g-badge" href={googleReviews} target="_blank" rel="noopener">
        <span class="stars">★★★★★</span>
        <span class="g-badge-t">Rated {googleRating} on Google &middot; read them all <span aria-hidden="true">→</span></span>
      </a>
      <h1>What neighbors <em>say.</em></h1>
      <p class="lede">For every good contractor in South Florida there are ten who cut corners. These are the homeowners who found the difference across Palm Beach County.</p>
      <div class="rev-cta">
        <a href="/contact/" class="btn btn-brass">Request your free visit</a>
        <a href="tel:+19547791855" class="btn btn-ghost">Call (954) 779-1855</a>
      </div>
    </div>
  </section>

  <section class="block wrap">
    <div class="review-grid">
      {reviews.map((r) => (
        <figure class="review">
          <div class="stars sm">★★★★★</div>
          <blockquote>{r.q}</blockquote>
          <figcaption>
            <span class="r-name">{r.n}</span>
            <span class="r-meta">{r.m}</span>
          </figcaption>
        </figure>
      ))}
    </div>
    <div class="rev-more">
      <a href={googleReviews} target="_blank" rel="noopener" class="btn btn-ghost">See more reviews on Google <span aria-hidden="true">→</span></a>
    </div>
  </section>

  <section class="cta">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Join them</div>
      <h2>Let&rsquo;s earn your five stars.</h2>
      <p>Tell us the surface, the size, and your timeline. We&rsquo;ll be at your door within a day or two, samples in hand, no charge, no pressure.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a href="/contact/" class="btn btn-brass">Request a visit</a>
        <a href="/portfolio/" class="btn btn-ghost" style="color:var(--ivory)">See our work</a>
      </div>
    </div>
  </section>

  <style>
    .crumbs{border-bottom:1px solid var(--line);background:var(--ivory)}
    .crumbs .wrap{padding-top:16px;padding-bottom:16px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
    .crumbs a:hover{color:var(--brass-dark)}
    .crumbs span{margin:0 8px;color:var(--brass)}
    .crumbs strong{font-weight:500;color:var(--ink)}

    .rev-hero{background:var(--green);color:var(--ivory);padding:74px 0 64px}
    .rev-hero .stars{font-size:24px}
    .rev-hero h1{font-size:clamp(38px,7vw,58px);line-height:1.06;color:var(--ivory);margin-top:14px}
    .rev-hero h1 em{font-style:italic;color:var(--brass)}
    .rev-hero .lede{font-weight:300;opacity:.9;max-width:42em;margin-top:18px;font-size:18px}
    .rev-cta{display:flex;gap:14px;flex-wrap:wrap;margin-top:28px}

    .g-badge{display:inline-flex;align-items:center;gap:13px;text-decoration:none;margin-bottom:4px}
    .g-badge .stars{font-size:24px}
    .g-badge-t{font-family:var(--sans);font-size:13px;letter-spacing:.06em;text-transform:uppercase;color:var(--ivory);opacity:.92;border-bottom:1px solid transparent;padding-bottom:2px;transition:opacity .15s ease,border-color .15s ease}
    .g-badge:hover .g-badge-t{opacity:1;border-color:var(--brass)}
    .g-badge-t span{color:var(--brass);display:inline-block;transition:transform .3s cubic-bezier(.16,1,.3,1)}
    .g-badge:hover .g-badge-t span{transform:translateX(4px)}

    .rev-more{text-align:center;margin-top:10px}

    .review-grid{columns:3;column-gap:24px}
    .review{break-inside:avoid;margin:0 0 24px;border:1px solid var(--line);border-radius:10px;background:var(--ivory);padding:26px 28px}
    .stars.sm{font-size:15px;letter-spacing:2px}
    .review blockquote{font-family:var(--serif);font-size:17.5px;line-height:1.55;color:var(--ink);margin:14px 0 18px}
    .review figcaption{display:flex;flex-direction:column;gap:4px}
    .r-name{font-size:14px;font-weight:500;color:var(--ink)}
    .r-meta{font-family:var(--sans);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--brass-dark)}

    @media(max-width:1024px){
      .rev-hero{padding:54px 0 46px}
      .review-grid{columns:2}
    }
    @media(max-width:600px){
      .rev-hero{padding:46px 0 38px}
      .rev-hero .lede{font-size:16px}
      .review-grid{columns:1}
      .review{padding:22px 20px}
    }
  </style>

</BaseLayout>
