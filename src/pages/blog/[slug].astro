---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Build one page per published post. Drafts are included only in `astro dev`,
// never in a production build.
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true
  );
  return posts.map((post) => ({ params: { slug: post.data.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, heroImage, pubDate } = post.data;

const canonical = new URL(`/blog/${post.data.slug}/`, Astro.site).href;
const ogImage = new URL(heroImage, Astro.site).href;
const dateLabel = new Intl.DateTimeFormat('en-US', {
  month: 'long', day: 'numeric', year: 'numeric', timeZone: 'America/New_York',
}).format(pubDate);

// Default Article JSON-LD generated from frontmatter. To use your own
// schema.json instead, replace the object below with its contents.
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: ogImage,
  datePublished: pubDate.toISOString(),
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  author: { '@type': 'Organization', name: 'Perfect Pavers of Palm Beach' },
  publisher: {
    '@type': 'Organization',
    name: 'Perfect Pavers of Palm Beach',
    url: 'https://sweetpeach123.github.io',
  },
};
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: new URL('/blog/', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: title, item: canonical },
  ],
};
---
<BaseLayout title={title} description={description} canonical={canonical} image={ogImage}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />

  <nav class="crumbs">
    <div class="wrap">
      <a href="/">Home</a> <span>/</span> <a href="/blog/">Blog</a> <span>/</span> <strong>{title}</strong>
    </div>
  </nav>

  <article class="post">
    <header class="post-head wrap">
      <div class="eyebrow" style="color:var(--brass-dark)">Journal &middot; {dateLabel}</div>
      <h1>{title}</h1>
      <p class="post-dek">{description}</p>
    </header>

    <div class="wrap">
      <div class="post-hero ph" data-label="">
        <img src={heroImage} alt={title} width="1200" height="700" fetchpriority="high" />
      </div>
    </div>

    <div class="wrap post-wrap">
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>

  <section class="cta">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Have a project in mind?</div>
      <h2>Let&rsquo;s walk your property.</h2>
      <p>Tell us the surface, the size, and your timeline. We&rsquo;ll be at your door within a day or two, no charge, no pressure.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a href="/contact/" class="btn btn-brass">Request a visit</a>
        <a href="tel:+17547326599" class="btn btn-ghost" style="color:var(--ivory)">Call (754) 732-6599</a>
      </div>
    </div>
  </section>

  <style>
    .crumbs{border-bottom:1px solid var(--line);background:var(--ivory)}
    .crumbs .wrap{padding-top:16px;padding-bottom:16px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
    .crumbs a:hover{color:var(--brass-dark)}
    .crumbs span{margin:0 8px;color:var(--brass)}
    .crumbs strong{font-weight:500;color:var(--ink);text-transform:none;letter-spacing:0}

    .post-head{max-width:780px;padding-top:clamp(40px,6vw,72px);padding-bottom:clamp(20px,3vw,30px)}
    .post-head h1{font-size:clamp(32px,5vw,56px);line-height:1.06;margin:14px 0 0}
    .post-dek{font-family:var(--serif);font-style:italic;font-size:clamp(18px,2.4vw,23px);color:var(--muted);line-height:1.5;margin-top:18px}

    .post-hero{height:clamp(220px,42vw,500px);border-radius:6px;margin:clamp(18px,3vw,30px) 0 0}
    .post-hero::after{display:none}

    .post-wrap{display:flex;justify-content:center;padding-top:clamp(40px,6vw,64px);padding-bottom:clamp(56px,9vw,104px)}

    /* Article typography */
    .prose{max-width:720px;width:100%;font-size:17px;line-height:1.75;color:var(--ink);font-weight:300}
    .prose :global(h2){font-family:var(--serif);font-weight:500;font-size:clamp(26px,3.4vw,36px);line-height:1.12;margin:46px 0 14px;letter-spacing:.005em}
    .prose :global(h3){font-family:var(--serif);font-weight:500;font-size:clamp(21px,2.6vw,26px);line-height:1.18;margin:34px 0 10px}
    .prose :global(p){margin:0 0 20px}
    .prose :global(a){color:var(--brass-dark);text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px}
    .prose :global(a:hover){color:var(--green)}
    .prose :global(ul),.prose :global(ol){margin:0 0 22px;padding-left:24px}
    .prose :global(li){margin:0 0 9px}
    .prose :global(li::marker){color:var(--brass)}
    .prose :global(strong){font-weight:500;color:var(--ink)}
    .prose :global(blockquote){margin:26px 0;padding:6px 0 6px 22px;border-left:3px solid var(--brass);font-family:var(--serif);font-style:italic;font-size:21px;color:var(--muted)}
    .prose :global(img){border-radius:6px;margin:26px 0}
    .prose :global(hr){border:0;border-top:1px solid var(--line);margin:40px 0}
    .prose :global(figcaption){font-size:13px;color:var(--muted);text-align:center;margin-top:-16px}

    /* Comparison table — readable on desktop, horizontally scrollable on phones */
    .prose :global(.table-scroll),
    .prose :global(table){margin:30px 0}
    .prose :global(table){
      width:100%;border-collapse:collapse;font-family:var(--sans);font-size:15px;
      border:1px solid var(--line);background:var(--ivory)
    }
    .prose :global(thead){background:var(--green);color:var(--ivory)}
    .prose :global(th),.prose :global(td){
      text-align:left;padding:13px 16px;border-bottom:1px solid var(--line);border-right:1px solid var(--line);vertical-align:top
    }
    .prose :global(th){font-weight:500;letter-spacing:.02em;font-size:13px;text-transform:uppercase}
    .prose :global(thead th){border-right:1px solid rgba(246,241,231,.18);border-bottom:0}
    .prose :global(tbody tr:nth-child(even)){background:var(--ivory-2)}
    .prose :global(tbody td:first-child){font-weight:500;color:var(--ink)}
    .prose :global(th:last-child),.prose :global(td:last-child){border-right:0}
    .prose :global(tbody tr:last-child td){border-bottom:0}

    @media(max-width:600px){
      .prose{font-size:16px}
      /* let a wide comparison table scroll sideways instead of overflowing */
      .prose :global(table){display:block;overflow-x:auto;-webkit-overflow-scrolling:touch;white-space:nowrap;font-size:14px}
      .prose :global(td),.prose :global(th){padding:11px 13px}
    }
  </style>
</BaseLayout>
