---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  { href: '/portfolio/hollywood-residence/', img: '/images/portfolio/hollywood-residence-1.jpg', loc: 'Hollywood · Travertine', title: 'Travertine pool deck upgrade', desc: 'Worn concrete pavers replaced with Ivory Select travertine in a French pattern — cooler underfoot.', price: 'From $16,000', alt: 'Ivory travertine pool deck in Hollywood' },
  { href: '/portfolio/concrete-paver-and-drain/', img: '/images/portfolio/concrete-paver-and-drain-1.jpg', loc: 'Palm Beach Gardens · Concrete pavers', title: 'Concrete paver driveway & drain', desc: 'An old asphalt driveway rebuilt in concrete pavers with an integrated drainage system.', price: 'From $12,500', alt: 'Concrete paver driveway with drainage in Palm Beach Gardens' },
  { href: '/portfolio/pool-deck-clean-reseal/', img: '/images/portfolio/pool-deck-clean-reseal-1.jpg', loc: 'Palm Beach · Concrete pavers', title: 'Driveway clean & seal', desc: 'A faded concrete paver driveway pressure cleaned, re-sanded, and sealed to restore its color.', price: 'From $3,200', alt: 'Restored concrete paver driveway in Palm Beach' },
  { href: '/portfolio/miramar-pool-deck-restoration/', img: '/images/portfolio/miramar-pool-deck-restoration-1.jpg', loc: 'Miramar · Concrete pavers', title: 'Pool deck restoration', desc: 'Settled pavers lifted and re-leveled, then cleaned and sealed to bring this pool deck back to life.', price: 'From $3,800', alt: 'Restored concrete paver pool deck in Miramar' },
  { href: '/portfolio/north-lauderdale-residence/', img: '/images/portfolio/north-lauderdale-residence-1.jpg', loc: 'North Lauderdale · Pavers', title: 'Paver driveway restoration', desc: 'A curved paver driveway pressure-cleaned, re-sanded, and sealed for a fresh, protected finish.', price: 'From $2,600', alt: 'Curved paver driveway in North Lauderdale' },
];
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Portfolio', item: new URL('/portfolio/', Astro.site).href },
  ],
};
---
<BaseLayout
  title="Portfolio · Paver Projects Across Palm Beach County · Perfect Pavers"
  description="A look at paver driveways, pool decks, patios and outdoor living we’ve built across Palm Beach County — Boca Raton, Delray Beach, West Palm Beach and beyond.">
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbLd)} />

  <nav class="crumbs">
    <div class="wrap">
      <a href="/">Home</a> <span>/</span> <strong>Portfolio</strong>
    </div>
  </nav>

  <section class="port-hero">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Our work</div>
      <h1>Our work across <em>Palm Beach County.</em></h1>
      <p class="lede">Driveways, pool decks, patios, and outdoor spaces built across the county. Tap any project to see how it came together.</p>
    </div>
  </section>

  <section class="block wrap">
    <div class="port-grid">
      {projects.map((p) => (
        <a class="pcard" href={p.href}>
          <div class="pcard-ph">
            <img loading="lazy" decoding="async" src={p.img} alt={p.alt} width="400" height="320" />
            {p.soon && <span class="pf-soon">Coming soon</span>}
          </div>
          <div class="pcard-body">
            <div class="pcard-top">
              <div class="loc">{p.loc}</div>
              <h3>{p.title}</h3>
              <p class="pcard-desc">{p.desc}</p>
            </div>
            <div class="pcard-foot">
              <span class="pcard-price">{p.price}</span>
              <span class="pcard-more">View project <span aria-hidden="true">→</span></span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="cta">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Your project next?</div>
      <h2>Let&rsquo;s build something that lasts.</h2>
      <p>Tell us the surface, the size, and your timeline. We&rsquo;ll be at your door within a day or two, no charge, no pressure.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a href="/contact/" class="btn btn-brass">Request a visit</a>
        <a href="/service-areas/" class="btn btn-ghost" style="color:var(--ivory)">See where we work</a>
      </div>
    </div>
  </section>

  <style>
    .crumbs{border-bottom:1px solid var(--line);background:var(--ivory)}
    .crumbs .wrap{padding-top:16px;padding-bottom:16px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
    .crumbs a:hover{color:var(--brass-dark)}
    .crumbs span{margin:0 8px;color:var(--brass)}
    .crumbs strong{font-weight:500;color:var(--ink)}

    .port-hero{background:var(--green);color:var(--ivory);padding:78px 0 66px}
    .port-hero h1{font-size:clamp(34px,6vw,58px);line-height:1.06;color:var(--ivory);margin-top:14px;max-width:15em}
    .port-hero h1 em{font-style:italic;color:var(--brass)}
    .port-hero .lede{font-weight:300;opacity:.9;max-width:38em;margin-top:18px;font-size:18px}

    .port-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:28px}
    .pcard{display:flex;align-items:stretch;border:1px solid var(--line);border-radius:10px;overflow:hidden;background:var(--ivory);transition:transform .5s cubic-bezier(.16,1,.3,1),box-shadow .5s cubic-bezier(.16,1,.3,1)}
    .pcard:hover{transform:translateY(-3px);box-shadow:0 18px 44px rgba(35,35,31,.12)}
    .pcard-ph{position:relative;flex:0 0 40%;overflow:hidden}
    .pcard-ph img{width:100%;height:100%;min-height:220px;object-fit:cover;display:block;transition:transform .8s cubic-bezier(.16,1,.3,1)}
    .pcard:hover .pcard-ph img{transform:scale(1.05)}
    .pf-soon{position:absolute;top:12px;left:12px;background:rgba(23,33,28,.82);color:var(--ivory);font-family:var(--sans);font-size:10px;letter-spacing:.13em;text-transform:uppercase;padding:5px 11px;border-radius:999px}

    .pcard-body{flex:1;display:flex;flex-direction:column;justify-content:space-between;gap:8px;padding:22px 26px}
    .pcard .loc{font-family:var(--sans);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--brass-dark)}
    .pcard h3{font-size:21px;margin-top:3px;line-height:1.14}
    .pcard-desc{font-size:15px;color:var(--muted);font-weight:300;line-height:1.55;margin-top:7px;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
    .pcard-foot{display:flex;align-items:center;justify-content:space-between;gap:12px;border-top:1px solid var(--line);padding-top:9px}
    .pcard-price{font-family:var(--serif);font-size:17px;font-weight:600;color:var(--green);line-height:1}
    .pcard-more{font-family:var(--sans);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--brass-dark);white-space:nowrap}
    .pcard-more span{display:inline-block;transition:transform .4s cubic-bezier(.16,1,.3,1)}
    .pcard:hover .pcard-more span{transform:translateX(5px)}

    @media(max-width:1024px){
      .port-hero{padding:56px 0 48px}
      .port-grid{grid-template-columns:1fr}
    }
    @media(max-width:600px){
      .port-hero{padding:46px 0 38px}
      .pcard{flex-direction:column}
      .pcard-ph{flex:0 0 auto}
      .pcard-ph img{min-height:140px}
      .pcard-body{padding:14px 16px}
    }
    @media(prefers-reduced-motion:reduce){
      .pcard,.pcard-ph img,.pcard-more span{transition:none}
    }
  </style>

</BaseLayout>
