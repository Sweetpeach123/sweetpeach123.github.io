---
import BaseLayout from '../layouts/BaseLayout.astro';

const cities = [
  'West Palm Beach', 'Boca Raton', 'Boynton Beach', 'Delray Beach',
  'Palm Beach Gardens', 'Greenacres', 'Lake Worth Beach', 'Riviera Beach',
  'Atlantis', 'Westlake', 'Belle Glade', 'Pahokee', 'South Bay',
];

const spotlights = [
  { t: 'Boca Raton', p: 'Estate driveways, travertine pool decks, and outdoor kitchens built to the city’s exacting standards.', href: '/portfolio/boca-raton-travertine-pool-deck' },
  { t: 'Delray Beach', p: 'Coastal patios and walkways designed for salt air, sun, and year-round entertaining.', href: '/portfolio/delray-beach-coastal-patio' },
  { t: 'West Palm Beach', p: 'From historic neighborhoods to new builds — paver surfaces that lift the whole property.', href: '/portfolio/west-palm-beach-paver-driveway' },
];
---
<BaseLayout
  title="Service Areas · Palm Beach County · Perfect Pavers"
  description="Perfect Pavers installs premium paver driveways, pool decks, patios and outdoor living throughout Palm Beach County — Boca Raton, Delray Beach, West Palm Beach, Boynton Beach and beyond. No additional travel charge.">

  <nav class="crumbs">
    <div class="wrap">
      <a href="/">Home</a> <span>/</span> <a href="/about/why-choose-us">About</a> <span>/</span> <strong>Service areas</strong>
    </div>
  </nav>

  <section class="areas-hero">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Service areas</div>
      <h1>All of Palm Beach County, <em>one trusted crew.</em></h1>
      <p class="lede">From the barrier-island estates to the western communities, we install across Palm Beach County with the same care, the same local knowledge, and no extra travel charge.</p>
    </div>
  </section>

  <section class="block wrap">
    <div class="areas-intro">
      <div class="sec-head">
        <span class="sec-num">Where we work</span>
        <h2>One county, full attention.</h2>
      </div>
      <p>Palm Beach County is all we do. That means we know the local code, the sandy soil, the swale and drainage rules, and the municipalities by name. We are not a crew that drives down from three counties away once a month — we are here, and we stay close to every job until it is done right.</p>
    </div>

    <ul class="city-grid">
      {cities.map((c) => (
        <li class="city"><span class="city-mk" aria-hidden="true">✦</span>{c}</li>
      ))}
    </ul>
    <p class="city-note">No additional travel charge to any community in Palm Beach County. Don&rsquo;t see your town? <a href="/contact">Ask us</a> — if it&rsquo;s in the county, we likely cover it.</p>
  </section>

  <section class="block wrap" style="padding-top:0">
    <div class="sec-head">
      <span class="sec-num">Local focus</span>
      <h2>A few of the places we love to build.</h2>
    </div>
    <div class="spotlights">
      {spotlights.map((s) => (
        <a class="spot" href={s.href}>
          <h3>{s.t}</h3>
          <p>{s.p}</p>
          <span class="spot-more">View the project <span aria-hidden="true">→</span></span>
        </a>
      ))}
    </div>
  </section>

  <section class="cta">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Your free on-site visit</div>
      <h2>Let&rsquo;s walk your property.</h2>
      <p>Tell us the surface, the size, and your timeline. We&rsquo;ll be at your door within a day or two, samples in hand, no charge, no pressure.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a href="/contact" class="btn btn-brass">Request a visit</a>
        <a href="tel:+19547791855" class="btn btn-ghost" style="color:var(--ivory)">Call (954) 779-1855</a>
      </div>
    </div>
  </section>

  <style>
    .crumbs{border-bottom:1px solid var(--line);background:var(--ivory)}
    .crumbs .wrap{padding-top:16px;padding-bottom:16px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
    .crumbs a:hover{color:var(--brass-dark)}
    .crumbs span{margin:0 8px;color:var(--brass)}
    .crumbs strong{font-weight:500;color:var(--ink)}

    .areas-hero{background:var(--green);color:var(--ivory);padding:78px 0 66px}
    .areas-hero h1{font-size:60px;line-height:1.05;color:var(--ivory);margin-top:14px;max-width:16em}
    .areas-hero h1 em{font-style:italic;color:var(--brass)}
    .areas-hero .lede{font-weight:300;opacity:.9;max-width:36em;margin-top:18px;font-size:18px}

    .areas-intro{max-width:62ch;margin-bottom:42px}
    .areas-intro p{font-size:17px;color:var(--muted);font-weight:300;line-height:1.7;margin-top:22px}

    .city-grid{list-style:none;display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line);border:1px solid var(--line);border-radius:8px;overflow:hidden}
    .city{display:flex;align-items:center;gap:12px;background:var(--ivory);padding:20px 22px;font-family:var(--serif);font-size:19px;color:var(--ink);transition:background .4s ease,color .4s ease}
    .city:hover{background:var(--ivory-2);color:var(--green)}
    .city-mk{color:var(--brass);font-size:12px}
    .city-note{margin-top:22px;font-size:14.5px;color:var(--muted);font-weight:300}
    .city-note a{color:var(--brass-dark);text-decoration:underline;text-underline-offset:3px}

    .spotlights{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
    .spot{display:block;border:1px solid var(--line);border-left:3px solid var(--brass);border-radius:8px;background:var(--ivory);padding:28px 30px;transition:transform .5s cubic-bezier(.16,1,.3,1),box-shadow .5s cubic-bezier(.16,1,.3,1)}
    .spot:hover{transform:translateY(-3px);box-shadow:0 18px 44px rgba(35,35,31,.12)}
    .spot h3{font-size:24px;margin-bottom:10px;color:var(--ink)}
    .spot p{font-size:14.5px;color:var(--muted);font-weight:300;line-height:1.65}
    .spot-more{display:inline-block;margin-top:16px;font-family:var(--sans);font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--brass-dark)}
    .spot-more span{display:inline-block;transition:transform .4s cubic-bezier(.16,1,.3,1)}
    .spot:hover .spot-more span{transform:translateX(5px)}

    @media(max-width:980px){
      .areas-hero{padding:56px 0 48px}
      .areas-hero h1{font-size:40px}
      .city-grid{grid-template-columns:repeat(2,1fr)}
      .spotlights{grid-template-columns:1fr}
    }
    @media(max-width:560px){
      .city-grid{grid-template-columns:1fr}
      .city{font-size:18px}
    }
  </style>

</BaseLayout>
