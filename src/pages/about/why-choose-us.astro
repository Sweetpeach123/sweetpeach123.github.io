---
import BaseLayout from '../../layouts/BaseLayout.astro';

const values = [
  { mk: 'I.', h: 'The estimate is the price', p: 'Base, drainage, and edge restraints are written in up front, never billed later as "extras." The number we quote is the number you pay.' },
  { mk: 'II.', h: 'We answer the phone', p: 'Before the deposit and years after the final paver is set. A real local team, not a call center two states away.' },
  { mk: 'III.', h: 'Built beneath the surface', p: 'A proper rock base, real drainage, and hidden restraints are what keep a driveway flat for decades. We do not cut there.' },
  { mk: 'IV.', h: 'One county, full attention', p: 'Palm Beach County is all this division does — here, we know the local code, the soil, and the municipalities by name. For service in Broward County, visit <a href="https://www.perfectpavers.com" target="_blank" rel="noopener">www.perfectpavers.com</a>.' },
];
---
<BaseLayout
  title="Why Choose Perfect Pavers · About Us"
  description="Installing premium pavers across Broward and Palm Beach County since 1988. State Certified General Contractor, CMHA certified, honest written estimates and a team that answers the phone years after the install.">

  <nav class="crumbs">
    <div class="wrap">
      <a href="/">Home</a> <span>/</span> <a href="/about/why-choose-us/">About</a> <span>/</span> <strong>Why choose us</strong>
    </div>
  </nav>

  <section class="block wrap about-top">
    <h1>Why choose Perfect Pavers</h1>
    <p class="lede">For more than three decades, South Florida homeowners have trusted us to install pavers that stay flat for years &mdash; and to still answer the phone long after the work is done.</p>
    <div class="about-copy">
      <p>Perfect Pavers has installed premium paver driveways, pool decks, and patios across Broward and Palm Beach County since 1988. We are a State Certified General Contractor and CMHA Certified Installer &mdash; a combination very few paver crews in Florida hold. It means we pull our own permits, build to code over a proper rock base, and put every line of your estimate in writing. No vanishing after the deposit, no surprise change orders, and no corners cut beneath the surface.</p>
    </div>
  </section>

  <section class="wrap stats-strip">
    <div class="stat"><span class="stat-n">1988</span><span class="stat-l">In South Florida since</span></div>
    <div class="stat"><span class="stat-n">1&ndash;5&nbsp;yr</span><span class="stat-l">Workmanship warranty, upgradable</span></div>
    <div class="stat"><span class="stat-n">37</span><span class="stat-l">Cities across Broward &amp; Palm Beach</span></div>
    <div class="stat"><span class="stat-n">1&ndash;2&nbsp;days</span><span class="stat-l">To your free on-site visit</span></div>
    <div class="stat"><span class="stat-n">CMHA</span><span class="stat-l">Certified &amp; State Licensed</span></div>
  </section>

  <section class="block wrap team-section">
    <figure class="team-photo">
      <img src="/images/team.jpg" alt="The Perfect Pavers team in their South Florida showroom, with natural stone samples on the wall" width="1280" height="853" loading="lazy" decoding="async" />
      <figcaption>The team behind every project &mdash; in our South Florida showroom.</figcaption>
    </figure>
  </section>

  <section class="block wrap" style="padding-top:0">
    <div class="sec-head">
      <span class="sec-num">What sets us apart</span>
      <h2>The difference is what you don&rsquo;t have to worry about.</h2>
    </div>
    <div class="props">
      <div class="card">
        <div class="k">On your terms</div>
        <h3>On-site within 1&ndash;2 days</h3>
        <p>Most installers take four weeks to show up. We measure your property and walk through the details within a day or two.</p>
      </div>
      <div class="card">
        <div class="k">No surprises</div>
        <h3>One transparent estimate</h3>
        <p>Every line &mdash; base, drainage, edge restraints &mdash; is in the written estimate before you sign. Nothing gets invented once the work is underway.</p>
      </div>
      <div class="card">
        <div class="k">Tidy from day one</div>
        <h3>A crew you barely notice</h3>
        <p>Wet-cut to keep dust down, the site swept every evening, updates at each stage, and a final walkthrough before we call it done.</p>
      </div>
    </div>
  </section>

  <section class="promise">
    <div class="wrap">
      <div>
        <div class="eyebrow" style="color:var(--brass)">What we stand for</div>
        <h2>Four promises we put in writing.</h2>
        <p class="lede">For every good contractor in South Florida, there are ten who cut corners on the base, vanish after the deposit, or bury change orders in the fine print. We built the opposite of that.</p>
        <a href="/about/our-process/" class="btn btn-brass" style="margin-top:30px">See how we work</a>
      </div>
      <ul>
        {values.map((v) => (
          <li><span class="mk">{v.mk}</span><div><b>{v.h}</b><p set:html={v.p}></p></div></li>
        ))}
      </ul>
    </div>
  </section>

  <section class="cta">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Your free on-site visit</div>
      <h2>Let&rsquo;s walk your property.</h2>
      <p>Tell us the surface, the size, and your timeline. We&rsquo;ll be at your door within a day or two, no charge, no pressure.</p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a href="/contact/" class="btn btn-brass">Request a visit</a>
        <a href="tel:+15618348880" class="btn btn-ghost" style="color:var(--ivory)">Call (561) 834-8880</a>
      </div>
    </div>
  </section>

  <style>
    .crumbs{border-bottom:1px solid var(--line);background:var(--ivory)}
    .crumbs .wrap{padding-top:16px;padding-bottom:16px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
    .crumbs a:hover{color:var(--brass-dark)}
    .crumbs span{margin:0 8px;color:var(--brass)}
    .crumbs strong{font-weight:500;color:var(--ink)}

    :global(.promise li p a){color:var(--brass);text-decoration:underline;text-underline-offset:2px}
    :global(.promise li p a:hover){color:var(--ivory)}

    /* Intro — no hero image, starts at the top */
    .about-top{padding-bottom:46px;text-align:center}
    .about-top h1{font-size:clamp(40px,5vw,62px);line-height:1.04;letter-spacing:-.02em;margin:0}
    .about-top .lede{font-family:var(--serif);font-size:clamp(20px,2vw,25px);line-height:1.45;font-weight:400;color:var(--ink);max-width:30em;margin:24px auto 0}
    .about-copy{max-width:66ch;margin:26px auto 0}
    .about-copy p{font-size:17px;color:var(--muted);font-weight:300;line-height:1.7}

    /* Numbers in a row */
    .stats-strip{display:flex;flex-wrap:wrap;justify-content:space-between;gap:32px;padding-top:36px;padding-bottom:36px;border-top:1px solid var(--line);border-bottom:1px solid var(--line)}
    .stats-strip .stat{flex:1 1 150px;text-align:center}
    .stats-strip .stat-n{display:block;font-family:var(--serif);font-weight:600;color:var(--green);line-height:1;letter-spacing:-.01em;font-size:clamp(30px,3.4vw,44px)}
    .stats-strip .stat-l{display:block;margin-top:12px;font-family:var(--sans);font-size:11px;font-weight:400;letter-spacing:.13em;text-transform:uppercase;color:var(--muted);line-height:1.55}

    /* Team photo */
    .team-section{padding-top:64px}
    .team-photo{margin:0 auto;max-width:85%}
    .team-photo img{display:block;width:100%;height:auto;border-radius:10px}
    .team-photo figcaption{margin-top:16px;text-align:center;font-family:var(--sans);font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}

    @media(max-width:1024px){
      .about-top{padding-bottom:38px}
      .team-photo{max-width:100%}
      .stats-strip{gap:28px 20px}
      .stats-strip .stat{flex:1 1 28%}
    }

    @media(max-width:600px){
      .about-top{padding-bottom:30px}
      .about-top .lede{margin-top:18px}
      .about-copy{margin-top:22px}
      .stats-strip{gap:24px 16px}
      .stats-strip .stat{flex:1 1 40%}
      .team-section{padding-top:44px}
    }
  </style>

</BaseLayout>
