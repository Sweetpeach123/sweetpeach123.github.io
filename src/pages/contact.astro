---
import BaseLayout from '../layouts/BaseLayout.astro';

const reassurance = [
  { k: 'No cost', t: 'A genuinely free on-site visit', p: 'Most trades charge for the first visit. We measure the space and walk through the details at no cost and no pressure.' },
  { k: 'Fast', t: 'We arrive within 1–2 days', p: 'While other installers take four weeks to show up, we measure your property within a day or two.' },
  { k: 'Honest', t: 'One transparent estimate', p: 'Rock base, drainage and edge restraints are written in, and the number we quote is the number you pay.' },
];
---
<BaseLayout
  title="Request a Free On-Site Visit · Perfect Pavers of Palm Beach"
  description="Book a free, no-pressure on-site visit for paver driveways, pool decks, patios and outdoor living anywhere in Palm Beach County. Free on-site visit within 1–2 days.">

  <section class="contact-hero">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Free on-site visit · Palm Beach County</div>
      <h1>Let&rsquo;s walk your <em>property.</em></h1>
      <p class="lede">Tell us the surface, the size, and your timeline. We&rsquo;ll be at your door within a day or two, no charge, no pressure.</p>
    </div>
  </section>

  <section class="block wrap contact-grid">
    <aside class="contact-aside">
      <ul class="reassure">
        {reassurance.map((r) => (
          <li>
            <span class="rk">{r.k}</span>
            <h3>{r.t}</h3>
            <p>{r.p}</p>
          </li>
        ))}
      </ul>

      <div class="aside-cred">
        <span><i>✦</i> State Certified General Contractor · CGC#1524492</span>
        <span><i>✦</i> CMHA Certified Installer</span>
        <span><i>✦</i> 35+ years in South Florida</span>
      </div>

      <div class="aside-call">
        <div class="ac-label">Prefer to talk now?</div>
        <a href="tel:+19547791855" class="ac-num">(954) 779-1855</a>
        <div class="ac-meta">By appointment across Palm Beach County</div>
      </div>
    </aside>

    <div class="form-panel">
      <div class="form-head">
        <h2>Request your estimate</h2>
        <p>A few quick details and we&rsquo;ll be in touch to schedule your visit.</p>
      </div>
      <div class="form-embed">
        <iframe
          src="https://api.leadconnectorhq.com/widget/form/h4stiwk4vz9UqDkcE6Pk"
          style="width:100%;border:none;border-radius:4px;height:1170px"
          id="inline-h4stiwk4vz9UqDkcE6Pk"
          data-layout="{'id':'INLINE'}"
          data-trigger-type="alwaysShow"
          data-trigger-value=""
          data-activation-type="alwaysActivated"
          data-activation-value=""
          data-deactivation-type="neverDeactivate"
          data-deactivation-value=""
          data-form-name="PPPB Lead Form"
          data-height="1170"
          data-layout-iframe-id="inline-h4stiwk4vz9UqDkcE6Pk"
          data-form-id="h4stiwk4vz9UqDkcE6Pk"
          title="PPPB Lead Form"
          scrolling="no">
        </iframe>
      </div>
    </div>
  </section>

  <script is:inline src="https://link.msgsndr.com/js/form_embed.js"></script>

  <style>
    .contact-hero{background:var(--green);color:var(--ivory);padding:78px 0 66px}
    .contact-hero h1{font-size:clamp(34px,6vw,62px);color:var(--ivory);margin-top:14px}
    .contact-hero h1 em{font-style:italic;color:var(--brass)}
    .contact-hero .lede{font-weight:300;opacity:.9;max-width:34em;margin-top:18px;font-size:18px}

    .contact-grid{display:grid;grid-template-columns:.82fr 1.18fr;gap:60px;align-items:stretch;padding-top:72px;padding-bottom:104px}
    .contact-aside{display:flex;flex-direction:column}

    .reassure{list-style:none;display:grid;gap:30px;margin-top:54px}
    .reassure li{border-left:2px solid var(--brass);padding-left:22px}
    .reassure .rk{font-family:var(--serif);font-style:italic;font-size:15px;color:var(--brass-dark)}
    .reassure h3{font-size:24px;margin:4px 0 8px}
    .reassure p{font-size:14.5px;color:var(--muted);font-weight:300}

    .aside-call{margin-top:auto;margin-bottom:34px;padding:28px 30px;background:var(--ivory-2);border-radius:6px}
    .ac-label{font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
    .ac-num{display:inline-block;font-family:var(--serif);font-size:38px;font-weight:600;color:var(--green);margin:6px 0 4px}
    .ac-meta{font-size:13px;color:var(--muted);font-weight:300}

    .aside-cred{margin-top:80px;display:grid;gap:10px;font-size:13px;color:var(--ink)}
    .aside-cred i{color:var(--brass);font-style:normal;margin-right:8px}

    .form-panel{background:#fff;border:1px solid var(--line);border-radius:10px;padding:34px 34px 24px;box-shadow:0 1px 0 rgba(35,35,31,.03)}
    .form-head h2{font-size:32px}
    .form-head p{color:var(--muted);font-weight:300;margin-top:6px}
    .form-embed{margin-top:18px}
    .form-embed iframe{display:block;width:100%;max-width:100%}

    @media(max-width:1024px){
      .contact-hero{padding:56px 0 48px}
      .contact-grid{grid-template-columns:1fr;gap:40px;padding-top:48px;padding-bottom:64px}
      .form-panel{padding:22px 18px 16px}
      .aside-call{margin-top:34px}
    }

    @media(max-width:600px){
      .contact-hero{padding:44px 0 36px}
      .contact-hero .lede{font-size:16px}
      .contact-grid{gap:30px;padding-top:36px;padding-bottom:46px;padding-left:18px;padding-right:18px}
      .reassure{margin-top:36px;gap:24px}
      .reassure h3{font-size:21px}
      .aside-cred{margin-top:44px}
      .aside-call{margin-top:30px;margin-bottom:24px;padding:22px 20px}
      .ac-num{font-size:30px}
      .form-panel{padding:20px 16px 14px}
    }
  </style>

</BaseLayout>
