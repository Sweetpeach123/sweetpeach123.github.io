---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Apply · Careers · Perfect Pavers of Palm Beach"
  description="Apply to join Perfect Pavers of South Florida. Fill out our quick job application and a real person on our team will get back to you.">

  <nav class="crumbs">
    <div class="wrap">
      <a href="/">Home</a> <span>/</span> <a href="/about/why-choose-us/">About</a> <span>/</span> <a href="/careers/">Careers</a> <span>/</span> <strong>Apply</strong>
    </div>
  </nav>

  <section class="apply-hero">
    <div class="wrap">
      <div class="eyebrow" style="color:var(--brass)">Job application</div>
      <h1>Apply to join <em>the team.</em></h1>
      <p class="lede" id="apply-for">Fill out the short form below and a real person on our team will get back to you. A resume is welcome but not required.</p>
    </div>
  </section>

  <section class="block wrap apply-wrap">
    <div class="form-card">
      <iframe
        src="https://api.leadconnectorhq.com/widget/form/NNjDcRBy4UWDjR4CwVUe"
        style="width:100%;min-height:1181px;border:none;border-radius:8px"
        id="inline-NNjDcRBy4UWDjR4CwVUe"
        data-layout="{'id':'INLINE'}"
        data-trigger-type="alwaysShow"
        data-trigger-value=""
        data-activation-type="alwaysActivated"
        data-activation-value=""
        data-deactivation-type="neverDeactivate"
        data-deactivation-value=""
        data-form-name="Job Application"
        data-height="1181"
        data-layout-iframe-id="inline-NNjDcRBy4UWDjR4CwVUe"
        data-form-id="NNjDcRBy4UWDjR4CwVUe"
        title="Job Application">
      </iframe>
    </div>
    <p class="apply-alt">Prefer email? Write to <a href="mailto:office@perfectpavers.com?subject=Careers%20%E2%80%94%20Application">office@perfectpavers.com</a> or call <a href="tel:+17547326599">(754) 732-6599</a>.</p>
  </section>

  <script is:inline src="https://link.msgsndr.com/js/form_embed.js"></script>
  <script is:inline>
    (function () {
      var titles = {
        'field-sales-assistant': 'Field Sales Assistant',
        'in-home-sales-consultant': 'In-Home Sales Consultant',
      };
      try {
        var role = new URLSearchParams(window.location.search).get('role');
        if (role && titles[role]) {
          var el = document.getElementById('apply-for');
          if (el) el.innerHTML = 'You’re applying for <strong>' + titles[role] + '</strong>. Fill out the short form below and a real person on our team will get back to you.';
        }
      } catch (e) {}
    })();
  </script>

  <style>
    .crumbs{border-bottom:1px solid var(--line);background:var(--ivory)}
    .crumbs .wrap{padding-top:16px;padding-bottom:16px;font-size:12px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
    .crumbs a:hover{color:var(--brass-dark)}
    .crumbs span{margin:0 8px;color:var(--brass)}
    .crumbs strong{font-weight:500;color:var(--ink)}

    .apply-hero{background:var(--green);color:var(--ivory);padding:70px 0 58px}
    .apply-hero h1{font-size:clamp(38px,6.5vw,58px);color:var(--ivory);margin-top:14px}
    .apply-hero h1 em{font-style:italic;color:var(--brass)}
    .apply-hero .lede{font-weight:300;opacity:.9;max-width:44em;margin-top:18px;font-size:18px}
    .apply-hero .lede :global(strong){color:var(--ivory);font-weight:500}

    .form-card{max-width:760px;margin:0 auto;background:var(--ivory);border:1px solid var(--line);border-radius:12px;padding:16px}
    .apply-alt{max-width:760px;margin:22px auto 0;text-align:center;font-size:15px;color:var(--muted);font-weight:300}
    .apply-alt a{color:var(--brass-dark);text-decoration:underline;text-underline-offset:2px}
    .apply-alt a:hover{color:var(--green)}

    @media(max-width:1024px){ .apply-hero{padding:52px 0 44px} }
    @media(max-width:600px){ .apply-hero{padding:44px 0 36px} .form-card{padding:10px} }
  </style>

</BaseLayout>
